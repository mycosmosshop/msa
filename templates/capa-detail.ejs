<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DÖF: <%= capa.capa_number %> - <%= branding.company_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  <style>
    :root {
      --primary-color: <%= branding.primary_color %>;
      --secondary-color: <%= branding.secondary_color %>;
    }
    
    body {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      min-height: 100vh;
      padding: 30px 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .container {
      max-width: 1200px;
    }
    
    .card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      margin-bottom: 20px;
    }
    
    .card-header {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      color: white;
      border-radius: 15px 15px 0 0 !important;
      padding: 20px 30px;
    }
    
    .info-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-bottom: 20px;
    }
    
    .info-item {
      background: #f8f9fa;
      padding: 15px;
      border-radius: 10px;
    }
    
    .info-label {
      font-size: 12px;
      color: #666;
      margin-bottom: 5px;
      text-transform: uppercase;
      font-weight: 600;
    }
    
    .info-value {
      font-size: 16px;
      color: #333;
      font-weight: 600;
    }
    
    .status-badge {
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      display: inline-block;
    }
    
    .status-open { background: #fee; color: #c33; }
    .status-in_progress { background: #ffc; color: #993; }
    .status-completed { background: #cfc; color: #393; }
    .status-closed { background: #ddd; color: #666; }
    .status-overdue { background: #f33; color: white; }
    
    .btn-primary {
      background: var(--primary-color);
      border: none;
    }
    
    .btn-primary:hover {
      background: var(--secondary-color);
    }
    
    .form-section {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 10px;
      margin-bottom: 20px;
    }
    
    .section-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="card">
      <div class="card-header">
        <div style="display: flex; justify-content: space-between; align-items: center;">
          <div>
            <h2 style="margin: 0;">📋 <%= capa.capa_number %></h2>
            <p style="margin: 5px 0 0 0; opacity: 0.9;">
              <%= study.study_name %>
            </p>
          </div>
          <div style="display: flex; gap: 10px;">
            <a href="results.html?id=<%= study.id %>" class="btn btn-light">
              📊 MSA Sonuçları
            </a>
            <a href="capa-list.html" class="btn btn-light">
              📋 Tüm DÖF'ler
            </a>
            <a href="index.html?view=studies" class="btn btn-light">
              ← Çalışmalarıma Dön
            </a>
          </div>
        </div>
      </div>
      
      <div class="card-body">
        <!-- MSA Study Details -->
        <div class="form-section" style="margin-bottom: 25px;">
          <div class="section-title">
            <i class="bi bi-clipboard-data"></i> MSA Çalışma Detayları
          </div>
          <div class="info-grid">
            <% if (study.gauge_name) { %>
            <div class="info-item">
              <div class="info-label">Ölçüm Cihazı Adı</div>
              <div class="info-value">
                <i class="bi bi-tools" style="color: var(--primary-color);"></i>
                <%= study.gauge_name %>
              </div>
            </div>
            <% } %>
            
            <% if (study.gauge_number) { %>
            <div class="info-item">
              <div class="info-label">Cihaz Seri Numarası</div>
              <div class="info-value">
                <i class="bi bi-hash" style="color: var(--primary-color);"></i>
                <%= study.gauge_number %>
              </div>
            </div>
            <% } %>
            
            <% if (study.part_name) { %>
            <div class="info-item">
              <div class="info-label">Parça Adı</div>
              <div class="info-value">
                <i class="bi bi-box-seam" style="color: var(--primary-color);"></i>
                <%= study.part_name %>
              </div>
            </div>
            <% } %>
            
            <% if (study.characteristic) { %>
            <div class="info-item">
              <div class="info-label">Ölçülen Özellik</div>
              <div class="info-value">
                <i class="bi bi-rulers" style="color: var(--primary-color);"></i>
                <%= study.characteristic %>
              </div>
            </div>
            <% } %>
            
            <% if (study.tolerance) { %>
            <div class="info-item">
              <div class="info-label">Tolerans (Spesifikasyon)</div>
              <div class="info-value">
                <i class="bi bi-arrows-expand" style="color: var(--primary-color);"></i>
                <%= study.tolerance %>
              </div>
            </div>
            <% } %>
            
            <% if (study.location) { %>
            <div class="info-item">
              <div class="info-label">Konum/Lokasyon</div>
              <div class="info-value">
                <i class="bi bi-geo-alt" style="color: var(--primary-color);"></i>
                <%= study.location %>
              </div>
            </div>
            <% } %>
            
            <% if (study.performed_by) { %>
            <div class="info-item">
              <div class="info-label">Çalışmayı Yapan</div>
              <div class="info-value">
                <i class="bi bi-person" style="color: var(--primary-color);"></i>
                <%= study.performed_by %>
              </div>
            </div>
            <% } %>
            
            <% if (study.study_date) { %>
            <div class="info-item">
              <div class="info-label">Çalışma Tarihi</div>
              <div class="info-value">
                <i class="bi bi-calendar" style="color: var(--primary-color);"></i>
                <%= new Date(study.study_date).toLocaleDateString('tr-TR') %>
              </div>
            </div>
            <% } %>
          </div>
        </div>
        
        <!-- Status & Basic Info -->
        <div class="info-grid">
          <div class="info-item">
            <div class="info-label">Durum</div>
            <div class="info-value">
              <% 
                let statusClass = 'status-' + capa.status;
                let statusText = '';
                if (capa.status === 'open') statusText = '🔴 Açık';
                else if (capa.status === 'in_progress') statusText = '🟡 Devam Ediyor';
                else if (capa.status === 'completed') statusText = '🟢 Tamamlandı';
                else if (capa.status === 'closed') statusText = '⚫ Kapatıldı';
                else if (capa.status === 'overdue') statusText = '⚠️ Gecikmiş';
              %>
              <span class="status-badge <%= statusClass %>"><%= statusText %></span>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-label">Sorun Tipi</div>
            <div class="info-value">
              <% if (capa.issue_type === 'grr_unacceptable') { %>
                <span class="badge bg-danger">GRR Kabul Edilemez (%GRR > 30%)</span>
              <% } else if (capa.issue_type === 'grr_marginal') { %>
                <span class="badge bg-warning text-dark">GRR Marjinal (10-30%)</span>
              <% } else if (capa.issue_type === 'ndc_low') { %>
                <span class="badge bg-danger">NDC Düşük (NDC < 5)</span>
              <% } else { %>
                <%= capa.issue_type %>
              <% } %>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-label">%GRR Değeri</div>
            <% 
              const grrVal = capa.grr_value ? parseFloat(capa.grr_value) : null;
              const grrColor = grrVal > 30 ? '#d33' : grrVal > 10 ? '#d93' : '#3d3';
            %>
            <div class="info-value" style="color: <%= grrColor %>;">
              <%= grrVal !== null && !isNaN(grrVal) ? grrVal.toFixed(2) + '%' : '-' %>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-label">NDC Değeri</div>
            <% 
              const ndcVal = capa.ndc_value !== null && capa.ndc_value !== undefined ? parseFloat(capa.ndc_value) : null;
              const ndcColor = ndcVal !== null && ndcVal < 5 ? '#d33' : '#3d3';
            %>
            <div class="info-value" style="color: <%= ndcColor %>;">
              <%= ndcVal !== null && !isNaN(ndcVal) ? ndcVal.toFixed(2) : '-' %>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-label">Oluşturan</div>
            <div class="info-value">
              <%= capa.creator_name %><br>
              <small style="color: #999;"><%= new Date(capa.created_at).toLocaleDateString('tr-TR') %></small>
            </div>
          </div>
          
          <div class="info-item">
            <div class="info-label">Termin Tarihi</div>
            <div class="info-value">
              <%= capa.due_date ? new Date(capa.due_date).toLocaleDateString('tr-TR') : 'Belirlenmedi' %>
            </div>
          </div>
        </div>
        
        <!-- Issue Description -->
        <div class="form-section">
          <div class="section-title">
            🔍 Sorun Açıklaması
          </div>
          <div style="background: white; padding: 15px; border-radius: 8px; white-space: pre-line;">
            <%= capa.issue_description %>
          </div>
        </div>
        
        <!-- Form -->
        <form id="capaForm">
          <!-- Root Cause Analysis -->
          <div class="form-section">
            <div class="section-title">
              🔬 Kök Neden Analizi
            </div>
            <div class="mb-3">
              <label class="form-label">Kök Neden</label>
              <textarea class="form-control" name="root_cause" rows="4" 
                        placeholder="Soruna neden olan temel faktörleri açıklayın..."
              ><%= capa.root_cause || '' %></textarea>
            </div>
            <div class="mb-3">
              <label class="form-label">Kök Neden Belirleme Tarihi</label>
              <input type="date" class="form-control" name="root_cause_date" 
                     value="<%= capa.root_cause_date ? new Date(capa.root_cause_date).toISOString().split('T')[0] : '' %>">
            </div>
          </div>
          
          <!-- Corrective Action -->
          <div class="form-section">
            <div class="section-title">
              🔧 Düzeltici Faaliyet
            </div>
            <div class="mb-3">
              <label class="form-label">Düzeltici Aksiyon Planı</label>
              <textarea class="form-control" name="corrective_action" rows="4" 
                        placeholder="Mevcut sorunu düzeltmek için yapılacak aksiyonlar..."
              ><%= capa.corrective_action || '' %></textarea>
            </div>
          </div>
          
          <!-- Preventive Action -->
          <div class="form-section">
            <div class="section-title">
              🛡️ Önleyici Faaliyet
            </div>
            <div class="mb-3">
              <label class="form-label">Önleyici Aksiyon Planı</label>
              <textarea class="form-control" name="preventive_action" rows="4" 
                        placeholder="Benzer sorunların tekrarını önlemek için yapılacak aksiyonlar..."
              ><%= capa.preventive_action || '' %></textarea>
            </div>
          </div>
          
          <!-- Assignment & Dates -->
          <div class="form-section">
            <div class="section-title">
              👤 Atama ve Tarihler
            </div>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Sorumlu Kişi</label>
                <select class="form-select" name="responsible_email">
                  <option value="">Seçiniz...</option>
                  <% users.forEach(u => { %>
                    <option value="<%= u.id %>" <%= capa.responsible_email == u.id ? 'selected' : '' %>>
                      <%= u.name || u.email %>
                    </option>
                  <% }); %>
                </select>
              </div>
              
              <div class="col-md-6 mb-3">
                <label class="form-label">Termin Tarihi</label>
                <input type="date" class="form-control" name="due_date" 
                       value="<%= capa.due_date ? new Date(capa.due_date).toISOString().split('T')[0] : '' %>">
              </div>
            </div>
            
            <div class="mb-3">
              <label class="form-label">Durum</label>
              <select class="form-select" name="status">
                <option value="open" <%= capa.status === 'open' ? 'selected' : '' %>>🔴 Açık</option>
                <option value="in_progress" <%= capa.status === 'in_progress' ? 'selected' : '' %>>🟡 Devam Ediyor</option>
                <option value="completed" <%= capa.status === 'completed' ? 'selected' : '' %>>🟢 Tamamlandı</option>
                <option value="closed" <%= capa.status === 'closed' ? 'selected' : '' %>>⚫ Kapatıldı</option>
              </select>
            </div>
          </div>
          
          <!-- Effectiveness Verification -->
          <div class="form-section">
            <div class="section-title">
              ✅ Etkinlik Doğrulama
            </div>
            <div class="mb-3">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="effectiveness_verified" 
                       id="effectivenessCheck" <%= capa.effectiveness_verified ? 'checked' : '' %>>
                <label class="form-check-label" for="effectivenessCheck">
                  Aksiyonların etkinliği doğrulandı
                </label>
              </div>
            </div>
            <div class="mb-3">
              <label class="form-label">Etkinlik Notları</label>
              <textarea class="form-control" name="effectiveness_notes" rows="3" 
                        placeholder="Aksiyonların etkinliğinin nasıl doğrulandığını açıklayın..."
              ><%= capa.effectiveness_notes || '' %></textarea>
            </div>
          </div>
          
          <!-- Action Buttons -->
          <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button type="button" class="btn btn-secondary" onclick="window.location.href='capa-list.html'">
              ❌ İptal
            </button>
            <button type="submit" class="btn btn-primary">
              💾 Kaydet
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('capaForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());
      data.effectiveness_verified = formData.get('effectiveness_verified') === 'on';
      
      // Check if status changed to completed
      const statusChanged = data.status === 'completed' && '<%= capa.status %>' !== 'completed';
      
      try {
        const urlParams = new URLSearchParams(window.location.search);
        const studyId = urlParams.get('study');
        const capaId = urlParams.get('id');
        console.log('🔄 Sending CAPA update, id:', capaId);
        console.log('📦 Request data:', data);

        // POST /msa/:studyId/capa/:capaId/update portu (msaRoutes.js:3751) — supabase-js
        const {
          root_cause,
          root_cause_date,
          corrective_action,
          preventive_action,
          responsible_email,
          responsible_name,
          due_date,
          status,
          effectiveness_verified,
          effectiveness_notes
        } = data;

        // Build update object
        const updateData = {
          updated_at: MSA.nowIso()
        };

        if (root_cause !== undefined) updateData.root_cause = root_cause;
        if (root_cause_date) updateData.root_cause_date = root_cause_date;
        if (corrective_action !== undefined) updateData.corrective_action = corrective_action;
        if (preventive_action !== undefined) updateData.preventive_action = preventive_action;
        if (responsible_email) updateData.responsible_email = responsible_email;
        if (responsible_name) updateData.responsible_name = responsible_name;
        if (due_date) updateData.due_date = due_date;
        if (status) updateData.status = status;
        if (effectiveness_verified !== undefined) updateData.effectiveness_verified = effectiveness_verified;
        if (effectiveness_notes !== undefined) updateData.effectiveness_notes = effectiveness_notes;

        // Update CAPA
        const upd = await MSA.db.from(MSA.T.capa).update(updateData).eq('id', capaId);
        const result = upd.error
          ? { success: false, error: 'CAPA güncellenirken hata oluştu: ' + upd.error.message }
          : { success: true, message: 'CAPA başarıyla güncellendi' };

        if (result.success) {
          if (statusChanged) {
            // Status completed'a değişti, MSA planlama sayfasına yönlendir
            if (confirm('✅ DÖF tamamlandı!\n\nYeni bir kontrol MSA çalışması planlamak ister misiniz?')) {
              window.location.href = 'schedule-next.html?study=' + studyId + '&capa=' + capaId;
            } else {
              window.location.href = 'capa-list.html';
            }
          } else {
            alert('✅ DÖF başarıyla güncellendi!');
            window.location.reload();
          }
        } else {
          alert('❌ Hata: ' + result.error);
        }
      } catch (error) {
        console.error('Update error:', error);
        alert('❌ Güncelleme sırasında bir hata oluştu');
      }
    });
  </script>
</body>
</html>
