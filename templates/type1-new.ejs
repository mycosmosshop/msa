<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Type 1 Study - <%= branding?.company_name || 'GageAI' %></title>
  
  <!-- Theme Script -->
  <script>
    (function() {
      const theme = localStorage.getItem('theme_mode') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="css/dark-mode.css">
  <link rel="stylesheet" href="css/responsive.css">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: var(--bg-secondary);
      min-height: 100vh;
    }
    .navbar {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 20px rgba(0,0,0,0.1);
    }
    .navbar h1 {
      font-size: 24px;
      display: flex;
      align-items: center;
      gap: 15px;
    }
    .container {
      max-width: 900px;
      margin: 30px auto;
      padding: 0 20px;
    }
    .card {
      background: var(--card-bg);
      border-radius: 16px;
      box-shadow: var(--shadow);
      padding: 40px;
      margin-bottom: 20px;
    }
    h2 {
      color: var(--text-primary);
      margin-bottom: 10px;
      font-size: 28px;
    }
    .subtitle {
      color: var(--text-secondary);
      margin-bottom: 30px;
      font-size: 15px;
      line-height: 1.6;
    }
    .form-group {
      margin-bottom: 24px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    input[type="text"],
    input[type="number"],
    textarea {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid var(--border-color);
      border-radius: 10px;
      font-size: 14px;
      transition: all 0.3s ease;
      background: var(--input-bg);
      color: var(--text-primary);
      font-family: inherit;
    }
    input:focus, textarea:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }
    textarea {
      resize: vertical;
      min-height: 80px;
    }
    .form-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .info-box {
      background: var(--bg-tertiary);
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 24px;
      border-left: 4px solid #667eea;
    }
    .info-box p {
      color: var(--text-secondary);
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 8px;
    }
    .measurements-container {
      background: var(--bg-tertiary);
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 24px;
    }
    .measurement-input {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .measurement-input input {
      flex: 1;
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 14px 32px;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      padding: 14px 32px;
      border: 2px solid var(--border-color);
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s;
    }
    .btn-add {
      background: #10b981;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 600;
    }
    .btn-remove {
      background: #ef4444;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }
    .button-group {
      display: flex;
      gap: 12px;
      margin-top: 30px;
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <div class="navbar">
    <h1>
      <% if (branding?.logo_url) { %>
        <img src="<%= branding.logo_url %>" alt="Logo" style="height: 40px; width: auto;">
      <% } %>
      <%= branding?.company_name || 'GageAI' %>
    </h1>
    <div>
      <a href="index.html" style="color: white; text-decoration: none; margin-right: 20px;">← Dashboard</a>
      <a href="index.html" style="color: white; text-decoration: none;">Çıkış</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h2>📏 New Type 1 - Instrument Capability Study</h2>
      <p class="subtitle">
        Type 1 study evaluates instrument bias and capability using repeated measurements of a single reference standard.
        This analysis determines if your measurement instrument is accurate and precise enough for production use.
      </p>

      <div class="info-box">
        <p><strong>Requirements:</strong></p>
        <p>• A known reference value (master/standard part)</p>
        <p>• Minimum 5 measurements (25-50 recommended)</p>
        <p>• Tolerance specification for the characteristic</p>
        <p>• One operator, one instrument, one part</p>
      </div>

      <form id="type1Form">
        <!-- Study Info -->
        <div class="form-group">
          <label for="study_name">Study Name *</label>
          <input type="text" id="study_name" name="study_name" required 
                 placeholder="e.g., Caliper Bias Study - January 2025">
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description" 
                    placeholder="Optional notes about this study..."></textarea>
        </div>

        <!-- Instrument Info -->
        <div class="form-row">
          <div class="form-group">
            <label for="gauge_name">Gauge Name</label>
            <input type="text" id="gauge_name" name="gauge_name" 
                   placeholder="e.g., Digital Caliper">
          </div>
          <div class="form-group">
            <label for="gauge_number">Gauge Number</label>
            <input type="text" id="gauge_number" name="gauge_number" 
                   placeholder="e.g., CAL-001">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" 
                   placeholder="e.g., Quality Lab">
          </div>
          <div class="form-group">
            <label for="part_name">Part Name</label>
            <input type="text" id="part_name" name="part_name" 
                   placeholder="e.g., Reference Block">
          </div>
        </div>

        <div class="form-group">
          <label for="characteristic">Characteristic</label>
          <input type="text" id="characteristic" name="characteristic" 
                 placeholder="e.g., Length, Diameter, Thickness">
        </div>

        <!-- Reference & Tolerance -->
        <div class="form-row">
          <div class="form-group">
            <label for="reference_value">Reference Value (Master) *</label>
            <input type="number" id="reference_value" name="reference_value" 
                   step="any" required placeholder="e.g., 25.000">
          </div>
          <div class="form-group">
            <label for="tolerance">Tolerance (Total) *</label>
            <input type="number" id="tolerance" name="tolerance" 
                   step="any" required placeholder="e.g., 0.100">
          </div>
        </div>

        <!-- Measurements -->
        <div class="form-group">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <label>Measurements * (minimum 5)</label>
            <div style="display: flex; align-items: center; gap: 10px;">
              <label style="margin: 0; font-size: 13px;">Number of rows:</label>
              <input type="number" id="rowCountInput" min="5" max="100" value="20" 
                     style="width: 80px; padding: 8px; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-secondary);">
              <button type="button" class="btn-add" onclick="generateRows()" style="padding: 8px 16px;">Generate</button>
            </div>
          </div>
          <div class="measurements-container" id="measurementsContainer">
            <!-- Rows will be generated by JavaScript -->
          </div>
        </div>

        <!-- Analysis Options -->
        <div class="form-group" style="border-top: 2px solid var(--border-color); padding-top: 30px; margin-top: 30px;">
          <h3 style="color: var(--text-primary); margin-bottom: 20px; font-size: 20px;">📊 Analysis Options</h3>
          
          <!-- Bias Study Options -->
          <div style="background: var(--bg-tertiary); padding: 20px; border-radius: 10px; margin-bottom: 20px;">
            <h4 style="color: var(--text-primary); margin-bottom: 15px; font-size: 16px;">Bias Study Options</h4>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_bias_table" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Bias and instrument capability table</span>
              </label>
            </div>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_t_test" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">One sample t-test</span>
              </label>
            </div>
            
            <div class="form-row" style="margin-top: 15px;">
              <div class="form-group" style="margin-bottom: 0;">
                <label for="confidence_interval">Confidence Interval for Bias (%)</label>
                <input type="number" id="confidence_interval" name="confidence_interval" 
                       value="95" min="90" max="99" step="1" placeholder="95">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <label for="percent_tolerance_cg">Percent of Tolerance for Cg (%)</label>
                <input type="number" id="percent_tolerance_cg" name="percent_tolerance_cg" 
                       value="20" min="5" max="50" step="5" placeholder="20">
              </div>
            </div>
          </div>
          
          <!-- Plots Options -->
          <div style="background: var(--bg-tertiary); padding: 20px; border-radius: 10px;">
            <h4 style="color: var(--text-primary); margin-bottom: 15px; font-size: 16px;">Plots</h4>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_run_chart" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Run chart</span>
              </label>
              <div style="margin-left: 28px; margin-top: 8px;">
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                  <input type="checkbox" name="run_chart_individual" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display individual measurements</span>
                </label>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="run_chart_boundaries" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display boundaries of the reference interval</span>
                </label>
              </div>
            </div>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_histogram" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Histogram</span>
              </label>
              <div style="margin-left: 28px; margin-top: 8px;">
                <div class="form-row" style="gap: 15px;">
                  <div class="form-group" style="margin-bottom: 8px;">
                    <label for="histogram_bin_type" style="font-size: 12px;">Bin Width Type</label>
                    <select id="histogram_bin_type" name="histogram_bin_type" 
                            style="width: 100%; padding: 10px; border: 2px solid var(--border-color); border-radius: 8px; background: var(--input-bg); color: var(--text-primary);">
                      <option value="sturges" selected>Sturges</option>
                      <option value="fixed">Fixed Number</option>
                    </select>
                  </div>
                  <div class="form-group" style="margin-bottom: 8px;">
                    <label for="num_bins" style="font-size: 12px;">Number of Bins</label>
                    <input type="number" id="num_bins" name="num_bins" value="30" min="5" max="100" 
                           style="padding: 10px;">
                  </div>
                </div>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="histogram_show_mean" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display mean</span>
                </label>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="histogram_show_ci" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Confidence interval for mean (95%)</span>
                </label>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="histogram_show_reference" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display reference value</span>
                </label>
              </div>
            </div>
          </div>
        </div>

        <div class="button-group">
          <a href="index.html" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Calculate & Save Study</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let measurementCount = 20;

    // Generate rows on page load
    window.addEventListener('DOMContentLoaded', function() {
      generateRows();
    });

    function generateRows() {
      const rowCount = parseInt(document.getElementById('rowCountInput').value) || 20;
      if (rowCount < 5) {
        alert('Minimum 5 measurements required');
        document.getElementById('rowCountInput').value = 5;
        return;
      }
      if (rowCount > 100) {
        alert('Maximum 100 measurements allowed');
        document.getElementById('rowCountInput').value = 100;
        return;
      }

      const container = document.getElementById('measurementsContainer');
      container.innerHTML = ''; // Clear existing rows
      
      for (let i = 1; i <= rowCount; i++) {
        const div = document.createElement('div');
        div.className = 'measurement-input';
        div.innerHTML = `
          <span style="width: 40px; font-weight: 600;">#${i}</span>
          <input type="number" step="any" class="measurement-value" placeholder="Enter measurement value">
        `;
        container.appendChild(div);
      }
      
      measurementCount = rowCount;
    }

    function addMeasurement() {
      measurementCount++;
      const container = document.getElementById('measurementsContainer');
      const div = document.createElement('div');
      div.className = 'measurement-input';
      div.innerHTML = `
        <span style="width: 40px; font-weight: 600;">#${measurementCount}</span>
        <input type="number" step="any" required class="measurement-value" placeholder="Enter measurement value">
        <button type="button" class="btn-remove" onclick="removeMeasurement(this)">×</button>
      `;
      container.appendChild(div);
    }

    function removeMeasurement(btn) {
      if (document.querySelectorAll('.measurement-input').length > 5) {
        btn.parentElement.remove();
        renumberMeasurements();
      } else {
        alert('Minimum 5 measurements required');
      }
    }

    function renumberMeasurements() {
      const inputs = document.querySelectorAll('.measurement-input');
      inputs.forEach((input, index) => {
        input.querySelector('span').textContent = `#${index + 1}`;
      });
      measurementCount = inputs.length;
    }

    document.getElementById('type1Form').addEventListener('submit', async (e) => {
      e.preventDefault();

      const measurements = Array.from(document.querySelectorAll('.measurement-value'))
        .map(input => parseFloat(input.value))
        .filter(v => !isNaN(v));

      if (measurements.length < 5) {
        alert('Please enter at least 5 measurements');
        return;
      }

      // Collect analysis options
      const analysisOptions = {
        show_bias_table: document.querySelector('[name="show_bias_table"]').checked,
        show_t_test: document.querySelector('[name="show_t_test"]').checked,
        confidence_interval: parseInt(document.getElementById('confidence_interval').value) || 95,
        percent_tolerance_cg: parseInt(document.getElementById('percent_tolerance_cg').value) || 20,
        show_run_chart: document.querySelector('[name="show_run_chart"]').checked,
        run_chart_individual: document.querySelector('[name="run_chart_individual"]').checked,
        run_chart_boundaries: document.querySelector('[name="run_chart_boundaries"]').checked,
        show_histogram: document.querySelector('[name="show_histogram"]').checked,
        histogram_bin_type: document.getElementById('histogram_bin_type').value,
        num_bins: parseInt(document.getElementById('num_bins').value) || 30,
        histogram_show_mean: document.querySelector('[name="histogram_show_mean"]').checked,
        histogram_show_ci: document.querySelector('[name="histogram_show_ci"]').checked,
        histogram_show_reference: document.querySelector('[name="histogram_show_reference"]').checked
      };

      const formData = {
        study_name: document.getElementById('study_name').value,
        description: document.getElementById('description').value,
        gauge_name: document.getElementById('gauge_name').value,
        gauge_number: document.getElementById('gauge_number').value,
        location: document.getElementById('location').value,
        part_name: document.getElementById('part_name').value,
        characteristic: document.getElementById('characteristic').value,
        reference_value: document.getElementById('reference_value').value,
        tolerance: document.getElementById('tolerance').value,
        measurements: measurements,
        analysis_options: analysisOptions
      };

      try {
        const result = await window.msaType1Create(formData);

        if (result.success) {
          window.location.href = `type1-results.html?id=${result.studyId}`;
        } else {
          alert('Error: ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to create study');
      }
    });
  </script>

  <!-- Theme Switcher -->
  <script src="js/theme-switcher.js"></script>
</body>
</html>
