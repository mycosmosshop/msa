            <span>Operatör/Parça/Tekrar:</span>
            <strong><%= study.num_operators %>/<%= study.num_parts %>/<%= study.num_trials %></strong>
          </div>
          <% } %>

          <div class="study-info-item">
            <span>Tarih:</span>
            <strong><% if (study.created_at) { %><%= new Date(study.created_at).toLocaleDateString('tr-TR') %><% } else { %><span style="color: var(--text-secondary); font-style: italic;">-</span><% } %></strong>
          </div>
        </div>

        <div class="study-actions" onclick="event.stopPropagation()">
          <a href="results.html?id=<%= study.id %>" class="study-btn study-btn-view">
            <i class="bi bi-eye"></i> Sonuçlar
          </a>
          <a href="edit-study.html?id=<%= study.id %>" class="study-btn study-btn-edit">
            <i class="bi bi-gear"></i> Ayarlar
          </a>
          <button onclick="deleteStudy(<%= study.id %>, 'type3', '<%= study.study_name.replace(/'/g, "\\'") %>')" class="study-btn study-btn-delete">
            <i class="bi bi-trash"></i> Sil
          </button>
        </div>
      </div>
    <% }); %>
  </div>
</div>
<% } %>

<!-- Empty State -->
<% if ((!type1Studies || type1Studies.length === 0) &&
       (!type2Studies || type2Studies.length === 0) &&
       (!type3Studies || type3Studies.length === 0) &&
       (!draftStudies || draftStudies.length === 0) &&
       (!sharedStudies || sharedStudies.length === 0)) { %>
<div class="empty-state">
  <i class="bi bi-folder-x"></i>
  <h2 style="color: var(--text-primary); margin-bottom: 10px;">Henüz çalışma yok</h2>
  <p>Yeni bir MSA çalışması oluşturmak için yukarıdaki "Yeni Çalışma" butonuna tıklayın.</p>
</div>
<% } %>
    </div>

    <!-- KPI View -->
    <div id="kpi-view" style="display: <%= view === 'kpi' ? 'block' : 'none' %>">
<!-- KPI Dashboard -->
<% if (kpiData) { %>

<!-- Summary Cards -->
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 30px;">
  <!-- Total Studies -->
  <div class="section" style="text-align: center;">
    <i class="bi bi-clipboard-data" style="font-size: 48px; color: #667eea; margin-bottom: 10px;"></i>
    <div style="font-size: 36px; font-weight: bold; color: var(--text-primary); margin-bottom: 5px;">
      <%= kpiData.totalStudies %>
    </div>
    <div style="color: var(--text-secondary); font-size: 14px;">Toplam Çalışma</div>
  </div>

  <!-- Acceptable Rate -->
  <div class="section" style="text-align: center;">
    <i class="bi bi-check-circle" style="font-size: 48px; color: #10b981; margin-bottom: 10px;"></i>
    <div style="font-size: 36px; font-weight: bold; color: #10b981; margin-bottom: 5px;">
      <%= kpiData.acceptableRate.toFixed(1) %>%
    </div>
    <div style="color: var(--text-secondary); font-size: 14px;">Kabul Oranı</div>
  </div>

  <!-- Average GRR -->
  <div class="section" style="text-align: center;">
    <i class="bi bi-graph-up" style="font-size: 48px; color: #f59e0b; margin-bottom: 10px;"></i>
    <div style="font-size: 36px; font-weight: bold; color: var(--text-primary); margin-bottom: 5px;">
      <%= kpiData.avgGRR && typeof kpiData.avgGRR === 'number' ? kpiData.avgGRR.toFixed(1) + '%' : 'N/A' %>
    </div>
    <div style="color: var(--text-secondary); font-size: 14px;">Ortalama %GRR</div>
  </div>

  <!-- Active Gauges -->
  <div class="section" style="text-align: center;">
    <i class="bi bi-tools" style="font-size: 48px; color: #8b5cf6; margin-bottom: 10px;"></i>
    <div style="font-size: 36px; font-weight: bold; color: var(--text-primary); margin-bottom: 5px;">
      <%= kpiData.activeGauges || 0 %>
    </div>
    <div style="color: var(--text-secondary); font-size: 14px;">Aktif Gauge</div>
  </div>
</div>

<!-- Study Type Distribution -->
<div class="section">
  <h2 class="section-title">
    <i class="bi bi-pie-chart"></i>
    Çalışma Tipi Dağılımı
  </h2>
  <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin-top: 20px;">
    <div style="background: var(--bg-secondary); padding: 15px; border-radius: 8px; text-align: center;">
      <div style="font-size: 24px; font-weight: bold; color: #667eea;">
        <%= kpiData.type1Count || 0 %>
      </div>
      <div style="color: var(--text-secondary); font-size: 13px; margin-top: 5px;">Type 1</div>
    </div>
    <div style="background: var(--bg-secondary); padding: 15px; border-radius: 8px; text-align: center;">
      <div style="font-size: 24px; font-weight: bold; color: #f59e0b;">
        <%= kpiData.type2Count || 0 %>
      </div>
      <div style="color: var(--text-secondary); font-size: 13px; margin-top: 5px;">Type 2</div>
    </div>
    <div style="background: var(--bg-secondary); padding: 15px; border-radius: 8px; text-align: center;">
      <div style="font-size: 24px; font-weight: bold; color: #10b981;">
        <%= kpiData.type3Count || 0 %>
      </div>
      <div style="color: var(--text-secondary); font-size: 13px; margin-top: 5px;">Type 3</div>
    </div>
  </div>
</div>

<!-- Recent Activity -->
<% if (kpiData.recentStudies && kpiData.recentStudies.length > 0) { %>
<div class="section">
  <h2 class="section-title">
    <i class="bi bi-clock-history"></i>
    Son Çalışmalar
  </h2>
  <div style="margin-top: 20px;">
    <% kpiData.recentStudies.forEach(study => { %>
    <div style="background: var(--bg-secondary); padding: 15px; border-radius: 8px; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center;">
      <div style="flex: 1;">
        <div style="font-weight: 600; color: var(--text-primary); margin-bottom: 5px;">
          <%= study.study_name %>
        </div>
        <div style="font-size: 13px; color: var(--text-secondary);">
          <%= new Date(study.created_at).toLocaleDateString('tr-TR') %>
        </div>
      </div>
      <div>
        <% if (study.status === 'calculated') { %>
          <% if (study.is_acceptable === 'acceptable' || study.is_acceptable === true) { %>
            <span class="status-badge status-acceptable">✓ Acceptable</span>
          <% } else if (study.is_acceptable === 'marginal') { %>
            <span class="status-badge status-marginal">⚠ Marginal</span>
          <% } else { %>
            <span class="status-badge status-unacceptable">✗ Unacceptable</span>
          <% } %>
        <% } else { %>
          <span class="status-badge status-draft">Taslak</span>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>
</div>
<% } %>

<% } else { %>
<!-- No KPI Data -->
<div class="empty-state">
  <i class="bi bi-graph-up"></i>
  <h2 style="color: var(--text-primary); margin-bottom: 10px;">KPI Verisi Yok</h2>
  <p>KPI dashboard'u görmek için en az bir çalışma oluşturun.</p>
</div>
<% } %>
    </div>
  </div>

  <!-- Scripts -->
  <script>
    function toggleDropdown() {
      const dropdown = document.getElementById('newStudyDropdown');
      dropdown.classList.toggle('active');
      // Close tools dropdown if open
      document.getElementById('toolsDropdown')?.classList.remove('active');
    }

    function toggleToolsDropdown() {
      const dropdown = document.getElementById('toolsDropdown');
      dropdown.classList.toggle('active');
      // Close new study dropdown if open
      document.getElementById('newStudyDropdown')?.classList.remove('active');
    }

    // Close dropdown when clicking outside
    window.addEventListener('click', function(e) {
      if (!e.target.closest('.dropdown')) {
        document.getElementById('newStudyDropdown').classList.remove('active');
        document.getElementById('toolsDropdown')?.classList.remove('active');
      }
    });

    function switchView(view) {
      // Statik portta iki görünüm ayrı sayfa yüklemeleridir (KPI = index.html?view=kpi)
      window.location.href = view === 'kpi' ? 'index.html?view=kpi' : 'index.html';
    }

    // Delete study function
    // Orijinal DELETE /msa/type1/:id, /msa/type2/:id ve /msa/:id rotalarının supabase-js portu.
    // FK'ler ON DELETE CASCADE olduğundan ölçüm/operatör/parça/sonuç/CAPA kayıtları otomatik silinir.
    async function deleteStudy(studyId, studyType, studyName) {
      if (!confirm(`"${studyName}" çalışmasını silmek istediğinize emin misiniz?\n\nBu işlem geri alınamaz!`)) {
        return;
      }

      try {
        let query = MSA.db.from(MSA.T.studies).select('id, study_name').eq('id', studyId);
        if (studyType === 'type1') {
          query = query.eq('study_type', 'type1');
        } else if (studyType === 'type2') {
          query = query.eq('study_type', 'type2');
        }
        const { data: study, error: selErr } = await query.maybeSingle();

        let result;
        if (selErr) {
          result = { success: false, message: 'Failed to delete study: ' + selErr.message };
        } else if (!study) {
          result = { success: false, message: 'Study not found or access denied' };
        } else {
          const del = await MSA.db.from(MSA.T.studies).delete().eq('id', studyId);
          result = del.error
            ? { success: false, message: 'Failed to delete study: ' + del.error.message }
            : { success: true, message: 'Study deleted successfully' };
        }

        if (result.success) {
          alert('✅ Çalışma başarıyla silindi');
          window.location.reload();
        } else {
          alert('❌ Hata: ' + (result.message || 'Çalışma silinemedi'));
        }
      } catch (error) {
        console.error('Delete error:', error);
        alert('❌ Çalışma silinirken bir hata oluştu');
      }
    }

    // Create study from schedule
    function createStudyFromSchedule(scheduleId, studyType) {
      if (!confirm('Bu plandan yeni bir MSA çalışması başlatmak istiyor musunuz?')) {
        return;
      }

      const normalizedType = (studyType || 'type2').toLowerCase();
      if (normalizedType === 'type1') {
        window.location.href = `type1-new.html?schedule_id=${scheduleId}`;
        return;
      }
      if (normalizedType === 'type2') {
        window.location.href = `new-study.html?schedule_id=${scheduleId}`;
        return;
      }
      window.location.href = `new-study.html?schedule_id=${scheduleId}`;
    }
  </script>

  <!-- Theme Switcher -->
  <script src="js/theme-switcher.js"></script>
</body>
</html>
