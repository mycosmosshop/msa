<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DÖF Yönetimi - <%= branding.company_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  <style>
    :root {
      --primary-color: <%= branding.primary_color %>;
      --secondary-color: <%= branding.secondary_color %>;
    }
    
    body {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      min-height: 100vh;
      padding: 30px 0;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }
    
    .container {
      max-width: 1400px;
    }
    
    .header-card {
      background: white;
      border-radius: 15px;
      padding: 30px;
      margin-bottom: 30px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }
    
    .stat-card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
      text-align: center;
      transition: transform 0.2s;
    }
    
    .stat-card:hover {
      transform: translateY(-5px);
    }
    
    .stat-icon {
      font-size: 32px;
      margin-bottom: 10px;
    }
    
    .stat-value {
      font-size: 36px;
      font-weight: bold;
      margin-bottom: 5px;
    }
    
    .stat-label {
      color: #666;
      font-size: 14px;
    }
    
    .filters-card {
      background: white;
      border-radius: 12px;
      padding: 20px;
      margin-bottom: 20px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }
    
    .capa-table {
      background: white;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }
    
    .status-badge {
      padding: 6px 12px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 600;
      display: inline-block;
    }
    
    .status-open { background: #fee; color: #c33; }
    .status-in_progress { background: #ffc; color: #993; }
    .status-completed { background: #cfc; color: #393; }
    .status-closed { background: #ddd; color: #666; }
    .status-overdue { background: #f33; color: white; }
    
    .table-hover tbody tr:hover {
      background-color: #f8f9fa;
      cursor: pointer;
    }
    
    .btn-primary {
      background: var(--primary-color);
      border: none;
    }
    
    .btn-primary:hover {
      background: var(--secondary-color);
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <div class="header-card">
      <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
          <h1 style="margin: 0; color: var(--primary-color);">
            📋 DÖF (CAPA) Yönetimi
          </h1>
          <p style="margin: 5px 0 0 0; color: #666;">
            Düzeltici ve Önleyici Faaliyet Takibi
          </p>
        </div>
        <a href="index.html?view=studies" class="btn btn-primary">
          ← Çalışmalarıma Dön
        </a>
      </div>
    </div>
    
    <!-- Statistics -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon">📊</div>
        <div class="stat-value"><%= stats.total %></div>
        <div class="stat-label">Toplam DÖF</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">🔴</div>
        <div class="stat-value"><%= stats.open %></div>
        <div class="stat-label">Açık</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">🟡</div>
        <div class="stat-value"><%= stats.in_progress %></div>
        <div class="stat-label">Devam Ediyor</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">🟢</div>
        <div class="stat-value"><%= stats.completed %></div>
        <div class="stat-label">Tamamlandı</div>
      </div>
      
      <div class="stat-card">
        <div class="stat-icon">⚠️</div>
        <div class="stat-value" style="color: #f33;"><%= stats.overdue %></div>
        <div class="stat-label">Gecikmiş</div>
      </div>
    </div>
    
    <!-- Filters -->
    <div class="filters-card">
      <form method="GET" action="capa-list.html" class="row g-3">
        <div class="col-md-3">
          <label class="form-label">Durum</label>
          <select name="status" class="form-select">
            <option value="">Tümü</option>
            <option value="open" <%= filters.status === 'open' ? 'selected' : '' %>>Açık</option>
            <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>Devam Ediyor</option>
            <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Tamamlandı</option>
            <option value="closed" <%= filters.status === 'closed' ? 'selected' : '' %>>Kapatıldı</option>
            <option value="overdue" <%= filters.status === 'overdue' ? 'selected' : '' %>>Gecikmiş</option>
          </select>
        </div>
        
        <div class="col-md-3">
          <label class="form-label">Sorumlu</label>
          <select name="responsible" class="form-select">
            <option value="">Tümü</option>
            <% users.forEach(u => { %>
              <option value="<%= u.id %>" <%= filters.responsible == u.id ? 'selected' : '' %>>
                <%= u.name || u.email %>
              </option>
            <% }); %>
          </select>
        </div>
        
        <div class="col-md-4">
          <label class="form-label">Arama</label>
          <input type="text" name="search" class="form-control" 
                 placeholder="DÖF numarası, açıklama veya çalışma adı..." 
                 value="<%= filters.search || '' %>">
        </div>
        
        <div class="col-md-2" style="display: flex; align-items: flex-end;">
          <button type="submit" class="btn btn-primary w-100">
            <i class="bi bi-search"></i> Filtrele
          </button>
        </div>
      </form>
    </div>
    
    <!-- CAPA Table -->
    <div class="capa-table">
      <% if (capas.length === 0) { %>
        <div style="text-align: center; padding: 60px 20px; color: #999;">
          <div style="font-size: 64px; margin-bottom: 20px;">📭</div>
          <h3>Henüz DÖF kaydı yok</h3>
          <p>MSA sonuçları kabul edilemez seviyede olduğunda otomatik DÖF oluşturulacak.</p>
        </div>
      <% } else { %>
        <div style="overflow-x: auto;">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>DÖF No</th>
                <th>Çalışma</th>
                <th>Sorun Tipi</th>
                <th>Cg</th>
                <th>Cgk</th>
                <th>Bias %</th>
                <th>GRR %</th>
                <th>NDC</th>
                <th>Durum</th>
                <th>Sorumlu</th>
                <th>Termin</th>
                <th>Oluşturma</th>
              </tr>
            </thead>
            <tbody>
              <% capas.forEach(capa => { %>
                <tr onclick="window.location.href='capa-detail.html?study=<%= capa.study_id %>&id=<%= capa.id %>'">
                  <td>
                    <strong style="color: var(--primary-color);"><%= capa.capa_number %></strong>
                  </td>
                  <td><%= capa.study_name %></td>
                  <td>
                    <% if (capa.issue_type === 'grr_unacceptable') { %>
                      <span class="badge bg-danger">GRR Kabul Edilemez</span>
                    <% } else if (capa.issue_type === 'grr_marginal') { %>
                      <span class="badge bg-warning text-dark">GRR Marjinal</span>
                    <% } else if (capa.issue_type === 'ndc_low') { %>
                      <span class="badge bg-danger">NDC Düşük</span>
                    <% } else if (capa.issue_type === 'cg_unacceptable') { %>
                      <span class="badge bg-danger">Cg Kabul Edilemez</span>
                    <% } else if (capa.issue_type === 'cgk_unacceptable') { %>
                      <span class="badge bg-danger">Cgk Kabul Edilemez</span>
                    <% } else if (capa.issue_type === 'bias_unacceptable') { %>
                      <span class="badge bg-danger">Bias Yüksek</span>
                    <% } else { %>
                      <span class="badge bg-secondary"><%= capa.issue_type %></span>
                    <% } %>
                  </td>
                  
                  <!-- Type 1 Columns: Cg, Cgk, Bias -->
                  <td>
                    <% if (capa.study_type === 'type1' && capa.cg !== null && capa.cg !== undefined) { %>
                      <% 
                        const cgColor = capa.cg >= 1.33 ? '#10b981' : capa.cg >= 1.0 ? '#f59e0b' : '#ef4444';
                      %>
                      <span style="font-weight: 600; color: <%= cgColor %>;">
                        <%= capa.cg.toFixed(2) %>
                      </span>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (capa.study_type === 'type1' && capa.cgk !== null && capa.cgk !== undefined) { %>
                      <% 
                        const cgkColor = capa.cgk >= 1.33 ? '#10b981' : capa.cgk >= 1.0 ? '#f59e0b' : '#ef4444';
                      %>
                      <span style="font-weight: 600; color: <%= cgkColor %>;">
                        <%= capa.cgk.toFixed(2) %>
                      </span>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (capa.study_type === 'type1' && capa.bias !== null && capa.bias !== undefined) { %>
                      <% 
                        const biasColor = Math.abs(capa.bias) > 10 ? '#ef4444' : '#10b981';
                      %>
                      <span style="font-weight: 600; color: <%= biasColor %>;">
                        <%= capa.bias.toFixed(2) %>%
                      </span>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  
                  <!-- Type 3 Columns: GRR %, NDC -->
                  <td>
                    <% if (capa.study_type !== 'type1') { %>
                      <% 
                        const grrVal = capa.grr_percent || capa.grr_value;
                        const grrColor = grrVal > 30 ? '#ef4444' : grrVal > 10 ? '#f59e0b' : '#10b981';
                      %>
                      <% if (grrVal !== null && grrVal !== undefined && !isNaN(grrVal)) { %>
                        <span style="font-weight: 600; color: <%= grrColor %>;">
                          <%= parseFloat(grrVal).toFixed(2) %>%
                        </span>
                      <% } else { %>
                        -
                      <% } %>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% if (capa.study_type !== 'type1') { %>
                      <% 
                        const ndcVal = capa.ndc || capa.ndc_value;
                        const ndcColor = ndcVal !== null && ndcVal < 5 ? '#ef4444' : '#10b981';
                      %>
                      <% if (ndcVal !== null && ndcVal !== undefined && !isNaN(ndcVal)) { %>
                        <span style="font-weight: 600; color: <%= ndcColor %>;">
                          <%= parseFloat(ndcVal).toFixed(2) %>
                        </span>
                      <% } else { %>
                        -
                      <% } %>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <% 
                      let statusClass = 'status-' + capa.status;
                      let statusText = '';
                      if (capa.status === 'open') statusText = '🔴 Açık';
                      else if (capa.status === 'in_progress') statusText = '🟡 Devam Ediyor';
                      else if (capa.status === 'completed') statusText = '🟢 Tamamlandı';
                      else if (capa.status === 'closed') statusText = '⚫ Kapatıldı';
                      else if (capa.status === 'overdue') statusText = '⚠️ Gecikmiş';
                    %>
                    <span class="status-badge <%= statusClass %>"><%= statusText %></span>
                  </td>
                  <td>
                    <%= capa.responsible_name || capa.responsible_email || '-' %>
                  </td>
                  <td>
                    <% if (capa.due_date) { %>
                      <%= new Date(capa.due_date).toLocaleDateString('tr-TR') %>
                    <% } else { %>
                      -
                    <% } %>
                  </td>
                  <td>
                    <%= new Date(capa.created_at).toLocaleDateString('tr-TR') %>
                    <br>
                    <small style="color: #999;"><%= capa.creator_name %></small>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
