                    <div class="tooltip-description">
                      Tekrarlanabilirliğin toleransa oranı.
                    </div>
                  </div>
                <% } %>
              </td>
            <% } %>
          </tr>
          <tr>
            <td>Reproducibility</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.reproducibility.stdDev.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
