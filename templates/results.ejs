        // Define options for fit line and origin line
        const showFitLine = <%= analysisOptions.plots?.fit_line ? 'true' : 'false' %>;
        const showOriginLine = <%= analysisOptions.plots?.origin_line ? 'true' : 'false' %>;
        
        // Create scatter plots for each cell in the matrix
        for (let row = 1; row <= study.num_operators; row++) {
          for (let col = 1; col <= study.num_operators; col++) {
            // Skip diagonal cells (operator vs itself)
            if (row === col) {
              continue;
            }
            
            const canvasId = `matrixChart_${row}_${col}`;
            const canvas = document.getElementById(canvasId);
            
            if (!canvas) {
              console.warn(`Canvas not found: ${canvasId}`);
              continue;
            }
            
            const xData = operatorData[col] || [];
            const yData = operatorData[row] || [];
            const minLength = Math.min(xData.length, yData.length);
            
            // Create scatter points
            const scatterData = [];
            for (let i = 0; i < minLength; i++) {
              scatterData.push({ x: xData[i], y: yData[i] });
            }
            
            // Calculate min and max for axis ranges
            const allValues = [...xData, ...yData];
            const minVal = Math.min(...allValues);
            const maxVal = Math.max(...allValues);
            const padding = (maxVal - minVal) * 0.1;
            
            const datasets = [{
              data: scatterData,
              backgroundColor: 'rgba(66, 165, 245, 0.8)',
              borderColor: 'rgba(66, 165, 245, 1)',
              pointRadius: 5,
              pointHoverRadius: 7,
              showLine: false
            }];
            
            // Add fit line if enabled
            if (showFitLine && scatterData.length > 1) {
              // Calculate linear regression
              const n = scatterData.length;
              const sumX = scatterData.reduce((sum, point) => sum + point.x, 0);
              const sumY = scatterData.reduce((sum, point) => sum + point.y, 0);
              const sumXY = scatterData.reduce((sum, point) => sum + point.x * point.y, 0);
              const sumX2 = scatterData.reduce((sum, point) => sum + point.x * point.x, 0);
              
              const slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);
              const intercept = (sumY - slope * sumX) / n;
              
              // Create line data
              const lineData = [
                { x: minVal - padding, y: slope * (minVal - padding) + intercept },
                { x: maxVal + padding, y: slope * (maxVal + padding) + intercept }
              ];
              
              datasets.push({
                data: lineData,
                borderColor: 'rgba(255, 99, 132, 0.8)',
                backgroundColor: 'transparent',
                pointRadius: 0,
                showLine: true,
                borderWidth: 2,
                borderDash: [5, 5]
              });
            }
            
            // Add origin line (45-degree line) if enabled
            if (showOriginLine) {
              const originLineData = [
                { x: minVal - padding, y: minVal - padding },
                { x: maxVal + padding, y: maxVal + padding }
              ];
              
              datasets.push({
                data: originLineData,
                borderColor: 'rgba(128, 128, 128, 0.5)',
                backgroundColor: 'transparent',
                pointRadius: 0,
                showLine: true,
                borderWidth: 1,
                borderDash: [3, 3]
              });
            }
            
            // Create chart
            new Chart(canvas, {
              type: 'scatter',
              data: {
                datasets: datasets
              },
              options: {
                responsive: true,
                maintainAspectRatio: true,
                aspectRatio: 1,
                plugins: {
                  legend: {
                    display: false
                  },
                  tooltip: {
                    enabled: true,
                    callbacks: {
                      label: function(context) {
                        return `(${context.parsed.x.toFixed(2)}, ${context.parsed.y.toFixed(2)})`;
                      }
                    }
                  }
                },
                scales: {
                  x: {
                    min: minVal - padding,
                    max: maxVal + padding,
                    ticks: {
                      font: {
                        size: 10
                      },
                      maxTicksLimit: 6
                    },
                    grid: {
                      display: true,
                      color: 'rgba(0, 0, 0, 0.1)',
                      drawBorder: true,
                      lineWidth: 1
                    },
                    border: {
                      display: true,
                      width: 2,
                      color: 'rgba(0, 0, 0, 0.8)'
                    }
                  },
                  y: {
                    min: minVal - padding,
                    max: maxVal + padding,
                    ticks: {
                      font: {
                        size: 10
                      },
                      maxTicksLimit: 6
                    },
                    grid: {
