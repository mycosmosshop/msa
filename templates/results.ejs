          const xScale = chart.scales.x;
          
          // Draw vertical dividers
          ctx.save();
          ctx.strokeStyle = 'rgba(0, 0, 0, 0.3)';
          ctx.lineWidth = 1.5;
          ctx.setLineDash([5, 5]);
          
          operatorBoundaries.forEach(boundary => {
            const x = xScale.getPixelForValue(boundary);
            ctx.beginPath();
            ctx.moveTo(x, chartArea.top);
            ctx.lineTo(x, chartArea.bottom);
            ctx.stroke();
          });
          
          ctx.restore();
          
          // Draw operator names below the chart
          ctx.save();
          ctx.textAlign = 'center';
          ctx.textBaseline = 'top';
          ctx.font = 'bold 14px Arial';
          ctx.fillStyle = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim() || '#333';
          
          const yPosition = chartArea.bottom + 65; // Position below the part labels
          
          operators.forEach((operator, opIdx) => {
