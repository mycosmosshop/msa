                    border: {
                      display: true,
                      width: 2,
                      color: 'rgba(0, 0, 0, 0.8)'
                    }
                  }
                }
              }
            });
          }
        }
        
        console.log('✅ Matrix Plot created successfully');
        
      } catch (error) {
        console.error('❌ Matrix Plot Error:', error);
        console.error('Error details:', error.message, error.stack);
      }
    })();
    <% } %>

