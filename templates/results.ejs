              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Operator Std. Dev.</div>
                  <div class="tooltip-formula">σ(Op) = √Var(Operator)</div>
                  <div class="tooltip-description">
                    Operatör standart sapması. Sadece operatörden kaynaklanan değişkenlik.
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= (results.varianceComponents.reproducibility.operator > 0 ? (Math.sqrt(results.varianceComponents.reproducibility.operator) * 6).toFixed(3) : '0.000') %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Operator Study Variation</div>
                  <div class="tooltip-formula">SV(Op) = 6 × σ(Op)</div>
                  <div class="tooltip-description">
                    Operatör çalışma varyasyonu.
                  </div>
