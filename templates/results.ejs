            const operatorData = controlCharts.xbarChart.data.find(d => d.operator === operator);
            const operatorName = operatorData?.operator_name || getOperatorName(operator);
            
            ctx.fillText(operatorName, centerX, yPosition);
          });
          
          ctx.restore();
