                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.totalGaugeRR.studyVar.toFixed(3) %>
