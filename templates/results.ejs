    <!-- Variance Components -->
    <div class="section">
      <h2 class="section-title">🔬 Varyans Bileşenleri</h2>
      
      <!-- Table 1: Variance components -->
      <h3 style="margin-top: 20px; margin-bottom: 10px; font-size: 16px; color: #666;">Variance components</h3>
      <table>
        <thead>
          <tr>
            <th>Source</th>
            <th>Variance</th>
            <th>% Contribution</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Total gauge r&R</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.varianceComponents.totalGaugeRR.variance.toExponential(4) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Total Gauge R&R Variance</div>
                  <div class="tooltip-formula">Var(GRR) = Var(Repeatability) + Var(Reproducibility)</div>
                  <div class="tooltip-description">
                    Ölçüm sisteminin toplam varyansı. Tekrarlanabilirlik (EV) ve yeniden üretilebilirlik (AV) varyanslarının toplamıdır.
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.totalGaugeRR.pctContribution.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">% Contribution</div>
                  <div class="tooltip-formula">% = (Var(GRR) / Var(Total)) × 100</div>
                  <div class="tooltip-description">
                    Ölçüm sisteminin toplam varyansa katkısı. Düşük değer (%10 altı) idealdir.
                  </div>
                </div>
              <% } %>
            </td>
          </tr>
          <tr>
            <td>Repeatability</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.varianceComponents.repeatability.variance.toExponential(4) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Repeatability Variance (EV)</div>
                  <div class="tooltip-formula">Var(EV) = MS(Repeatability)</div>
                  <div class="tooltip-description">
                    Ekipman varyansı. Aynı operatörün aynı parçayı tekrar ölçtüğündeki farklılık. Cihazın hassasiyetini gösterir.
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.repeatability.pctContribution.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">% Contribution</div>
                  <div class="tooltip-formula">% = (Var(EV) / Var(Total)) × 100</div>
                  <div class="tooltip-description">
                    Tekrarlanabilirliğin toplam varyansa katkısı.
                  </div>
                </div>
              <% } %>
            </td>
          </tr>
          <tr>
            <td>Reproducibility</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.varianceComponents.reproducibility.variance.toExponential(4) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Reproducibility Variance (AV)</div>
                  <% if (results.varianceComponents.useInteractionModel) { %>
                    <div class="tooltip-formula">Var(AV) = Var(Operator) + Var(Interaction)</div>
                  <% } else { %>
                    <div class="tooltip-formula">Var(AV) = Var(Operator) (Interaction pooled)</div>
                  <% } %>
                  <div class="tooltip-description">
                    Operatör varyansı. Farklı operatörlerin aynı parçayı ölçtüğündeki farklılık. 
                    <% if (results.varianceComponents.useInteractionModel) { %>
                      Operatör ve etkileşim bileşenlerinin toplamı.
                    <% } else { %>
                      Etkileşim önemsiz olduğu için sadece operatör varyansı (Reproducibility = Operator).
                    <% } %>
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.reproducibility.pctContribution.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">% Contribution</div>
                  <div class="tooltip-formula">% = (Var(AV) / Var(Total)) × 100</div>
                  <div class="tooltip-description">
                    Yeniden üretilebilirliğin toplam varyansa katkısı.
                  </div>
                </div>
              <% } %>
            </td>
          </tr>
          <tr>
            <td style="padding-left: 30px;">Operator</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= (results.varianceComponents.reproducibility.operator > 0 ? results.varianceComponents.reproducibility.operator.toExponential(4) : '0.0000') %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Operator Variance</div>
                  <div class="tooltip-formula">Var(Op) = (MS(Op) - MS(Int or Error)) / (n × b)</div>
                  <div class="tooltip-description">
                    Sadece operatörden kaynaklanan varyans. 0 olması operatörler arası sistematik fark olmadığını gösterir (iyi durum).
                  </div>
                </div>
              <% } %>
            </td>
            <td>-</td>
          </tr>
          <% if (results.varianceComponents.useInteractionModel) { %>
          <tr>
            <td style="padding-left: 30px;">Interaction (Part × Operator)</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= (results.varianceComponents.reproducibility.interaction > 0 ? results.varianceComponents.reproducibility.interaction.toExponential(4) : '0.0000') %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Interaction Variance</div>
                  <div class="tooltip-formula">Var(Int) = (MS(Int) - MS(Error)) / n</div>
                  <div class="tooltip-description">
                    Part × Operator etkileşimi. Operatörlerin farklı parçalarda farklı davranması. 0 ise etkileşim yok demektir.
                  </div>
                </div>
              <% } %>
            </td>
            <td>-</td>
          </tr>
          <% } else { %>
          <tr style="background-color: var(--card-bg); font-style: italic; color: #666;">
            <td style="padding-left: 30px;">Interaction (Part × Operator)</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              Pooled
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Interaction Pooled</div>
                  <div class="tooltip-description">
                    Etkileşim önemsiz bulundu (F-ratio < 1.5) ve Repeatability ile birleştirildi (pooled). 
                    Bu durumda Reproducibility = Operator olur.
                  </div>
                </div>
              <% } %>
            </td>
            <td>-</td>
          </tr>
          <% } %>
          <tr>
            <td>Part-to-part</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.varianceComponents.partToPart.variance.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Part-to-Part Variance (PV)</div>
                  <div class="tooltip-formula">Var(PV) = (MS(Part) - MS(Int)) / (n × a)</div>
                  <div class="tooltip-description">
                    Parçalar arası gerçek değişkenlik. Yüksek olması istenir (ölçüm sisteminin parça farklarını ayırt edebildiğini gösterir).
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.partToPart.pctContribution.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">% Contribution</div>
                  <div class="tooltip-formula">% = (Var(PV) / Var(Total)) × 100</div>
                  <div class="tooltip-description">
                    Parça varyansının toplam varyansa katkısı. Yüksek olması arzu edilir (%90 üzeri mükemmel).
                  </div>
                </div>
              <% } %>
            </td>
          </tr>
          <tr style="font-weight: 700; background: #f8f9fa;">
            <td>Total variation</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.varianceComponents.totalVariation.variance.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Total Variation</div>
                  <div class="tooltip-formula">Var(Total) = Var(GRR) + Var(PV)</div>
                  <div class="tooltip-description">
                    Tüm ölçümlerdeki toplam değişkenlik. Ölçüm sistemi ve parça varyanslarının toplamı.
                  </div>
                </div>
              <% } %>
            </td>
            <td>100</td>
          </tr>
        </tbody>
      </table>
      
      <!-- Table 2: Gauge evaluation -->
      <h3 style="margin-top: 30px; margin-bottom: 10px; font-size: 16px; color: #666;">Gauge evaluation</h3>
      <table>
        <thead>
          <tr>
            <th>Source</th>
            <th>Std. dev.</th>
            <th>Study variation</th>
            <th>% Study variation</th>
