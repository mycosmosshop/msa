              <% } %>
            </td>
            <td>-</td>
            <% if (results.gaugeEvaluation.toleranceWidth) { %>
              <td>-</td>
            <% } %>
          </tr>
          <tr>
            <td>Part-to-part</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.partToPart.stdDev.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Part-to-Part Std. Dev.</div>
                  <div class="tooltip-formula">σ(PV) = √Var(Part-to-Part)</div>
                  <div class="tooltip-description">
                    Parçalar arası standart sapma. Parça varyansının karekökü.
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.partToPart.studyVar.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Part-to-Part Study Variation</div>
                  <div class="tooltip-formula">SV(PV) = 6 × σ(PV)</div>
                  <div class="tooltip-description">
                    Parçalar arası çalışma varyasyonu.
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.partToPart.pctStudyVar.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Part-to-Part % Study Var</div>
                  <div class="tooltip-formula">% = (SV(PV) / SV(Total)) × 100</div>
                  <div class="tooltip-description">
                    Parça varyansının toplam varyasyona yüzdesi. Yüksek olması istenir (>90% ideal).
                  </div>
                </div>
              <% } %>
            </td>
            <% if (results.gaugeEvaluation.toleranceWidth && results.gaugeEvaluation.partToPart.pctTolerance !== null) { %>
              <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
                <%= results.gaugeEvaluation.partToPart.pctTolerance.toFixed(2) %>
                <% if (analysisOptions.show_tooltips !== false) { %>
                  <div class="tooltip">
                    <div class="tooltip-title">Part-to-Part % Tolerance</div>
                    <div class="tooltip-formula">% = (SV(PV) / Tolerance) × 100</div>
                    <div class="tooltip-description">
                      Parça varyansının toleransa oranı.
                    </div>
                  </div>
                <% } %>
              </td>
            <% } %>
          </tr>
          <tr style="font-weight: 700; background: #f8f9fa;">
            <td>Total variation</td>
            <td><%= results.gaugeEvaluation.totalVariation.stdDev.toFixed(3) %></td>
            <td><%= results.gaugeEvaluation.totalVariation.studyVar.toFixed(3) %></td>
            <td>100.00</td>
            <% if (results.gaugeEvaluation.toleranceWidth) { %>
              <td>-</td>
            <% } %>
          </tr>
        </tbody>
      </table>
      
      <% if (results.gaugeEvaluation.toleranceWidth) { %>
        <p style="margin-top: 15px; color: #666; font-size: 14px;">
          <strong>📏 Tolerance Width:</strong> <%= results.gaugeEvaluation.toleranceWidth %>
          <br>
          <small>%Tolerance = (6 × σ / Tolerance Width) × 100</small>
        </p>
      <% } %>
      
      <p style="margin-top: 15px; color: #666; font-size: 13px; font-style: italic;">
        <strong>Method:</strong> <%= results.varianceComponents.useInteractionModel ? 'ANOVA with Interaction' : 'ANOVA without Interaction (pooled)' %>
        <br>
        Note: Number of distinct categories = <%= results.interpretation.ndc %>
        <br>
        Note: Study variation is calculated as std. dev. × 6
        <% if (!results.varianceComponents.useInteractionModel) { %>
          <br>
          Note: Interaction pooled with repeatability (F-ratio < 1.5)
        <% } %>
      </p>
    </div>

    <!-- Charts -->
    <% const isType3 = study.study_type === 'type3'; %>
    <% const showComponents = analysisOptions.plots?.components !== false; %>
    <% const showRangeCharts = !isType3 && analysisOptions.plots?.range_charts !== false; %>
    <% const showAverageChart = !isType3 && analysisOptions.plots?.average_chart !== false; %>
    <% const showInteraction = !isType3 && analysisOptions.plots?.interaction !== false; %>
    <% const showScatter = !isType3 && analysisOptions.plots?.scatter !== false; %>
    <% const showMeasurementsByPart = analysisOptions.plots?.measurements_part !== false || analysisOptions.plots?.measurements_by_part !== false; %>
    <% const showMeasurementsByOp = !isType3 && (analysisOptions.plots?.measurements_op !== false || analysisOptions.plots?.measurements_by_op !== false); %>

    <div class="chart-grid">
      <!-- Components of Variation -->
      <% if (showComponents) { %>
      <div class="chart-container">
        <h3 class="chart-title">📊 Components of Variation</h3>
        <div class="chart-wrapper">
          <canvas id="componentsChart"></canvas>
        </div>
        <div class="chart-description">
          <strong>Grafik Açıklaması:</strong> Bu grafik, toplam varyasyonun kaynaklarını gösterir. 
          <% if (results.gaugeEvaluation.totalGaugeRR.pctStudyVar < 10) { %>
            ✅ GRR &lt;10% - mükemmel ölçüm sistemi. Varyasyonun çoğu parçalardan geliyor (istenen durum).
          <% } else if (results.gaugeEvaluation.totalGaugeRR.pctStudyVar < 30) { %>
            ⚠️ GRR 10-30% arası - marjinal. Ölçüm sistemi iyileştirilebilir.
          <% } else { %>
            ❌ GRR &gt;30% - kabul edilemez. Ölçüm sistemi varyasyonun büyük kısmını oluşturuyor.
          <% } %>
        </div>
      </div>
      <% } %>

      <!-- R-Chart -->
      <% if (showRangeCharts) { %>
      <div class="chart-container">
        <h3 class="chart-title">📉 R Chart (Range by Operator)</h3>
        <div class="chart-wrapper">
          <canvas id="rChart"></canvas>
        </div>
        <div class="chart-description">
          <strong>Grafik Açıklaması:</strong> Her operatörün her parça için ölçüm aralığını (range) gösterir. 
          Tüm noktalar kontrol limitleri içinde kalmalı. Limitler dışına çıkan nokta varsa, o operatörün o parçada tutarsız ölçüm yaptığını gösterir (tekrarlanabilirlik problemi).
        </div>
        
        <div class="chart-description" id="rChartInterpretation" style="margin-top: 10px;"></div>
        
        <!-- Test Results for R Chart -->
        <div style="margin-top: 20px; padding: 15px; background: var(--card-bg, #f8f9fa); border-radius: 8px; border-left: 4px solid #eb5545;">
          <h4 style="margin-top: 0; color: #eb5545;">Test results for R chart</h4>
          <div id="rChartTestResults"></div>
        </div>
      </div>
      <% } %>

      <!-- X̄-Chart -->
      <% if (showAverageChart) { %>
      <div class="chart-container">
        <h3 class="chart-title">📈 X̄ Chart (Average by Operator)</h3>
        <div class="chart-wrapper">
          <canvas id="xbarChart"></canvas>
        </div>
        <div class="chart-description">
          <strong>Grafik Açıklaması:</strong> Operatörler arası ortalama karşılaştırması. 
          Tüm operatörlerin ortalamaları benzer ve kontrol limitleri içinde kalmalı. Bir operatör sistematik olarak yüksek veya düşük ölçüm yapıyorsa, eğitim veya kalibrasyon gerekir.
        </div>
        
        <div class="chart-description" id="xbarChartInterpretation" style="margin-top: 10px;"></div>
        
        <!-- Test Results for X̄ Chart -->
        <div style="margin-top: 20px; padding: 15px; background: var(--card-bg, #f8f9fa); border-radius: 8px; border-left: 4px solid #667eea;">
          <h4 style="margin-top: 0; color: #667eea;">Test results for x̄-bar chart</h4>
          <div id="xbarTestResults"></div>
        </div>
      </div>
      <% } %>

      <!-- Interaction Plot -->
      <% if (showInteraction) { %>
      <div class="chart-container">
        <h3 class="chart-title">🔀 Part × Operator Interaction Plot</h3>
        <div class="chart-wrapper">
          <canvas id="interactionChart"></canvas>
        </div>
        <div class="chart-description">
          <strong>Grafik Açıklaması:</strong> Operatörlerin farklı parçalarda tutarlılığını gösterir. 
          Çizgiler paralel olmalı (etkileşim yok). Çizgiler kesişiyorsa veya farklı eğimlerdeyse, operatörler farklı parçalarda farklı davranıyor demektir (etkileşim var - reproducibility problemi).
        </div>
        <div class="chart-description" id="interactionChartInterpretation" style="margin-top: 10px;"></div>
      </div>
      <% } %>

      <!-- Matrix Plot for Operators -->
      <% if (showScatter) { %>
      <div class="chart-container" style="grid-column: 1 / -1;">
        <h3 class="chart-title">📊 Matrix plot for operators</h3>
        <% 
          // Debug: Check if operators array exists
          const operatorsArray = typeof operators !== 'undefined' && operators ? operators : [];
          console.log('Operators array:', operatorsArray);
        %>
        <div class="matrix-plot-wrapper">
          <div class="matrix-plot-grid" style="--matrix-cols: <%= study.num_operators %>;">
            <% for (let opRow = 1; opRow <= study.num_operators; opRow++) { %>
              <% const rowOperator = operatorsArray.find(op => op.operator_number === opRow); %>
              <% for (let opCol = 1; opCol <= study.num_operators; opCol++) { %>
                <% const colOperator = operatorsArray.find(op => op.operator_number === opCol); %>
                <% if (opRow !== opCol) { %>
                <div class="matrix-plot-cell">
                <% if (opRow === 1) { %>
                  <div style="position: absolute; top: -30px; left: 0; right: 0; text-align: center; font-weight: bold; font-size: 16px; color: var(--text-primary); z-index: 10;"><%= colOperator?.operator_name || `Operatör ${opCol}` %></div>
                <% } %>
                <% if (opCol === 1) { %>
                  <div style="position: absolute; left: -80px; top: 50%; transform: translateY(-50%) rotate(-90deg); font-weight: bold; white-space: nowrap; font-size: 16px; color: var(--text-primary); z-index: 10;"><%= rowOperator?.operator_name || `Operatör ${opRow}` %></div>
                <% } %>
                <canvas id="matrixChart_<%= opRow %>_<%= opCol %>"></canvas>
              </div>
              <% } else { %>
              <div class="matrix-empty-cell matrix-plot-cell" style="display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-color);">
                <% if (opRow === 1) { %>
                  <div style="position: absolute; top: -30px; left: 0; right: 0; text-align: center; font-weight: bold; font-size: 16px; color: var(--text-primary); z-index: 10;"><%= colOperator?.operator_name || `Operatör ${opCol}` %></div>
                <% } %>
                <% if (opCol === 1) { %>
                  <div style="position: absolute; left: -80px; top: 50%; transform: translateY(-50%) rotate(-90deg); font-weight: bold; white-space: nowrap; font-size: 16px; color: var(--text-primary); z-index: 10;"><%= rowOperator?.operator_name || `Operatör ${opRow}` %></div>
                <% } %>
                <span style="color: var(--text-tertiary); font-style: italic; font-size: 12px;">—</span>
              </div>
              <% } %>
            <% } %>
          <% } %>
          </div>
        </div>
        <div class="chart-description">
          <strong>Grafik Açıklaması:</strong> Operatörler arası ölçüm karşılaştırmalarını gösterir. Her grafik, yatay ve dikey eksendeki iki operatörün aynı parçalar üzerindeki ölçüm ilişkisini gösterir. Noktalar 45° çizgiye yakınsa operatörler benzer ölçümler yapıyor demektir.
        </div>
        <div class="chart-description" id="matrixPlotInterpretation" style="margin-top: 10px;"></div>
      </div>
      <% } %>

      <!-- Measurements by Part -->
      <% if (showMeasurementsByPart) { %>
      <div class="chart-container" style="grid-column: 1 / -1;">
        <h3 class="chart-title">📏 Measurements by part</h3>
        <div class="chart-wrapper">
          <canvas id="measurementsByPartChart"></canvas>
        </div>
        <div class="chart-description">
          <strong>Grafik Açıklaması:</strong> Her parça için tüm ölçümlerin dağılımını gösterir. Her nokta bir ölçüm temsil eder. Parçalar arası fark (Part-to-Part varyasyon) burada görülebilir.
        </div>
        <div class="chart-description" id="measurementsByPartInterpretation" style="margin-top: 10px;"></div>
      </div>
      <% } %>

      <!-- Measurements by Operator -->
      <% if (showMeasurementsByOp) { %>
      <div class="chart-container" style="grid-column: 1 / -1;">
        <h3 class="chart-title">👥 Measurements by operator</h3>
        <div class="chart-wrapper">
          <canvas id="measurementsByOperatorChart"></canvas>
        </div>
        <div class="chart-description" id="operatorChartDescription">
          <strong>Grafik Açıklaması:</strong> Her operatör için ölçüm dağılımını box plot olarak gösterir. Kutu (box) ölçümlerin %50'sini içerir (Q1-Q3 arası), ortadaki çizgi medyan değerdir. Bıyıklar min/max değerleri gösterir.
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <script>
    const results = <%- JSON.stringify(results) %>;
    const controlCharts = <%- JSON.stringify(controlCharts) %>;
    const study = <%- JSON.stringify(study) %>;
    const measurements = <%- JSON.stringify(measurements) %>;
    const analysisOptions = <%- JSON.stringify(analysisOptions) %>;
    
    // Operator names helper - create a mapping from operator number to name
    const operators = <%- JSON.stringify(typeof operators !== 'undefined' && operators ? operators : []) %>;
    const operatorNames = {};
    operators.forEach(op => {
      // Use operator_name exactly as it comes from Excel, or fallback to numbered format
      operatorNames[op.operator_number] = op.operator_name || `Operatör ${op.operator_number}`;
    });
    
    // Helper function to get operator name - returns the exact name from Excel
    function getOperatorName(operatorNumber) {
      // Return the exact name from mapping (as it appears in Excel)
      return operatorNames[operatorNumber] || `Operatör ${operatorNumber}`;
    }

    // Chart.js plugin to set canvas background color based on theme
    const chartBackgroundPlugin = {
      id: 'customCanvasBackgroundColor',
      beforeDraw: (chart) => {
        const ctx = chart.canvas.getContext('2d');
        ctx.save();
        ctx.globalCompositeOperation = 'destination-over';
        // Get the background color from CSS variable
        const bgColor = getComputedStyle(document.documentElement).getPropertyValue('--card-bg').trim() || '#ffffff';
        ctx.fillStyle = bgColor;
        ctx.fillRect(0, 0, chart.width, chart.height);
        ctx.restore();
      }
    };
    
    // Register the plugin globally for all charts
    Chart.register(chartBackgroundPlugin);
    
    // Configure Chart.js defaults for dark mode
    const updateChartDefaults = () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      const textColor = getComputedStyle(document.documentElement).getPropertyValue('--text-primary').trim();
      const borderColor = getComputedStyle(document.documentElement).getPropertyValue('--border-color').trim();
      
      Chart.defaults.color = textColor;
      Chart.defaults.borderColor = borderColor;
      Chart.defaults.scale.grid.color = borderColor;
    };
    
    // Update on page load
    updateChartDefaults();
    
    // Listen for theme changes
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'data-theme') {
          updateChartDefaults();
          // Redraw all charts
          Object.values(Chart.instances).forEach(chart => chart.update());
          
          // Redraw box plot (custom plugin needs full recreation)
          if (typeof createMeasurementsByOperatorChart === 'function') {
            createMeasurementsByOperatorChart();
          }
          
          // Redraw measurements by part
          if (typeof createMeasurementsByPartChart === 'function') {
            createMeasurementsByPartChart();
          }
          
          // Update test results tables
          if (typeof renderRTestResults === 'function') {
            renderRTestResults();
          }
          if (typeof renderXbarTestResults === 'function') {
            renderXbarTestResults();
          }
          
          // Update chart interpretations
          if (typeof generateRChartInterpretation === 'function') {
            generateRChartInterpretation();
          }
          if (typeof generateXbarChartInterpretation === 'function') {
            generateXbarChartInterpretation();
          }
        }
      });
    });
    
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme']
    });

    // Wait for all DOM elements (including canvases) to be fully loaded
    window.addEventListener('load', function() {
      console.log('🚀 Page fully loaded, initializing all charts...');
      
      // Debug: Check plot options
      console.log('🔍 Analysis Options - Plot Settings:');
      console.log('  Full object:', analysisOptions.plots);
      console.log('  measurements_part:', analysisOptions.plots?.measurements_part);
      console.log('  measurements_by_part:', analysisOptions.plots?.measurements_by_part);
      console.log('  measurements_op:', analysisOptions.plots?.measurements_op);
      console.log('  measurements_by_op:', analysisOptions.plots?.measurements_by_op);
      console.log('  scatter:', analysisOptions.plots?.scatter);

    // Components of Variation Chart
    <% if (showComponents) { %>
    new Chart(document.getElementById('componentsChart'), {
      type: 'bar',
      data: {
        labels: ['Repeatability', 'Reproducibility', 'Gage R&R', 'Part-to-Part'],
        datasets: [
          {
            label: '% Contribution',
            data: [
              results.gaugeEvaluation.repeatability.pctContribution,
              results.gaugeEvaluation.reproducibility.pctContribution,
              results.gaugeEvaluation.totalGaugeRR.pctContribution,
              results.gaugeEvaluation.partToPart.pctContribution
            ],
            backgroundColor: 'rgba(102, 126, 234, 0.8)',
            borderColor: 'rgba(102, 126, 234, 1)',
            borderWidth: 2
          },
          {
            label: '% Study Var',
            data: [
              results.gaugeEvaluation.repeatability.pctStudyVar,
              results.gaugeEvaluation.reproducibility.pctStudyVar,
              results.gaugeEvaluation.totalGaugeRR.pctStudyVar,
              results.gaugeEvaluation.partToPart.pctStudyVar
            ],
            backgroundColor: 'rgba(118, 75, 162, 0.8)',
            borderColor: 'rgba(118, 75, 162, 1)',
            borderWidth: 2
          }<% if (results.gaugeEvaluation.toleranceWidth && results.gaugeEvaluation.totalGaugeRR.pctTolerance !== null) { %>,
          {
            label: '% Tolerance',
            data: [
              results.gaugeEvaluation.repeatability.pctTolerance,
              results.gaugeEvaluation.reproducibility.pctTolerance,
              results.gaugeEvaluation.totalGaugeRR.pctTolerance,
              results.gaugeEvaluation.partToPart.pctTolerance
            ],
            backgroundColor: 'rgba(240, 152, 25, 0.8)',
            borderColor: 'rgba(240, 152, 25, 1)',
            borderWidth: 2
          }<% } %>
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'top'
          }
        },
        scales: {
          y: {
            beginAtZero: true,
            max: 100,
            title: {
              display: true,
              text: 'Percentage (%)'
            }
          }
        }
      }
    });
    <% } %>

    // R-Chart (Range by Operator)
    <% if (showRangeCharts) { %>
    (() => {
      // Group data by operator
      const operators = [...new Set(controlCharts.rChart.data.map(d => d.operator))].sort();
      const parts = [...new Set(controlCharts.rChart.data.map(d => d.part))].sort();
      
      // Build x-axis labels with operator sections
      const xLabels = [];
      const rangeData = [];
      const operatorBoundaries = []; // Track where each operator section ends
      
      operators.forEach((operator, opIdx) => {
        const operatorData = controlCharts.rChart.data
          .filter(d => d.operator === operator)
          .sort((a, b) => a.part - b.part);
        
        operatorData.forEach((d, partIdx) => {
          // Show part labels for all parts, operator name will be shown below via callback
          const partLabel = d.part_name || (typeof d.part === 'number' ? `Parça ${d.part}` : d.part);
          xLabels.push(partLabel);
          rangeData.push(parseFloat(d.range));
        });
        
        // Mark boundary after each operator except the last
        if (opIdx < operators.length - 1) {
          operatorBoundaries.push(xLabels.length - 0.5);
        }
      });
      
      // Create datasets - each operator as separate segment to avoid connecting lines between operators
      const datasets = [];
      
      operators.forEach((operator, opIdx) => {
        const operatorRangeData = [];
        
        // Fill with null for previous operators
        for (let i = 0; i < opIdx * parts.length; i++) {
          operatorRangeData.push(null);
        }
        
        // Add this operator's data
        for (let i = 0; i < parts.length; i++) {
          const dataIdx = opIdx * parts.length + i;
          operatorRangeData.push(rangeData[dataIdx]);
        }
        
        // Fill with null for next operators
        for (let i = (opIdx + 1) * parts.length; i < rangeData.length; i++) {
          operatorRangeData.push(null);
        }
        
        datasets.push({
          label: opIdx === 0 ? 'Range' : '', // Only show label once
          data: operatorRangeData,
          borderColor: 'rgba(54, 162, 235, 1)',
          backgroundColor: 'rgba(54, 162, 235, 0.2)',
          borderWidth: 2,
          pointRadius: 6,
          pointHoverRadius: 8,
          fill: false,
          spanGaps: false // Don't connect across null values
        });
      });
      
      // Add control limits
      datasets.push(
        {
          label: 'UCL',
          data: Array(rangeData.length).fill(parseFloat(controlCharts.rChart.ucl)),
          borderColor: 'rgba(235, 51, 73, 1)',
          borderWidth: 2,
          borderDash: [5, 5],
          pointRadius: 0,
          fill: false
        },
        {
          label: 'CL (R̄)',
          data: Array(rangeData.length).fill(parseFloat(controlCharts.rChart.centerLine)),
          borderColor: 'rgba(17, 153, 142, 1)',
          borderWidth: 2,
          pointRadius: 0,
          fill: false
        },
        {
          label: 'LCL',
          data: Array(rangeData.length).fill(parseFloat(controlCharts.rChart.lcl)),
          borderColor: 'rgba(235, 51, 73, 1)',
          borderWidth: 2,
          borderDash: [5, 5],
          pointRadius: 0,
          fill: false
        }
      );
      
      // UCL, CL, LCL values for R chart
      const ucl_r = parseFloat(controlCharts.rChart.ucl);
      const cl_r = parseFloat(controlCharts.rChart.centerLine);
      const lcl_r = parseFloat(controlCharts.rChart.lcl);
      const stdDev_r = (ucl_r - cl_r) / 3;
      
      // Control Chart Tests for R Chart
      const rTestResults = {
        test1: [], test2: [], test3: [], test4: [],
        test5: [], test6: [], test7: [], test8: []
      };
      
      // Test 1: One point outside control limits
      rangeData.forEach((val, idx) => {
        if (val > ucl_r || val < lcl_r) {
          const opIdx = Math.floor(idx / parts.length);
          const partIdx = idx % parts.length;
          rTestResults.test1.push({ operator: operators[opIdx], part: parts[partIdx], point: idx + 1 });
        }
      });
      
      // Test 2: 7 points on same side
      for (let i = 0; i <= rangeData.length - 7; i++) {
        const segment = rangeData.slice(i, i + 7);
        if (segment.every(v => v > cl_r) || segment.every(v => v < cl_r)) {
          const opIdx = Math.floor(i / parts.length);
          rTestResults.test2.push({ operator: operators[opIdx], startPoint: i + 1 });
          break;
        }
      }
      
      // Test 3: 7 points increasing or decreasing
      for (let i = 0; i <= rangeData.length - 7; i++) {
        const segment = rangeData.slice(i, i + 7);
        const increasing = segment.every((v, j) => j === 0 || v > segment[j - 1]);
        const decreasing = segment.every((v, j) => j === 0 || v < segment[j - 1]);
        if (increasing || decreasing) {
          const opIdx = Math.floor(i / parts.length);
          rTestResults.test3.push({ operator: operators[opIdx], startPoint: i + 1 });
          break;
        }
      }
      
      // Test 4: 2 out of 3 > 2σ
      for (let i = 0; i <= rangeData.length - 3; i++) {
        const segment = rangeData.slice(i, i + 3);
        const count = segment.filter(v => Math.abs(v - cl_r) > 2 * stdDev_r).length;
        if (count >= 2) {
          const opIdx = Math.floor(i / parts.length);
          rTestResults.test4.push({ operator: operators[opIdx], startPoint: i + 1 });
        }
      }
      
      // Test 5: 15 points < 1σ
      for (let i = 0; i <= rangeData.length - 15; i++) {
        const segment = rangeData.slice(i, i + 15);
        if (segment.every(v => Math.abs(v - cl_r) < stdDev_r)) {
          const opIdx = Math.floor(i / parts.length);
          rTestResults.test5.push({ operator: operators[opIdx], startPoint: i + 1 });
          break;
        }
      }
      
      // Test 6: 8 points > 1σ
      for (let i = 0; i <= rangeData.length - 8; i++) {
        const segment = rangeData.slice(i, i + 8);
        if (segment.every(v => Math.abs(v - cl_r) > stdDev_r)) {
          const opIdx = Math.floor(i / parts.length);
          rTestResults.test6.push({ operator: operators[opIdx], startPoint: i + 1 });
          break;
        }
      }
      
      // Test 7: 4 out of 5 > 1σ (same side)
      for (let i = 0; i <= rangeData.length - 5; i++) {
        const segment = rangeData.slice(i, i + 5);
        const aboveCount = segment.filter(v => v > cl_r + stdDev_r).length;
        const belowCount = segment.filter(v => v < cl_r - stdDev_r).length;
        if (aboveCount >= 4 || belowCount >= 4) {
          const opIdx = Math.floor(i / parts.length);
          rTestResults.test7.push({ operator: operators[opIdx], startPoint: i + 1 });
        }
      }
      
      // Test 8: 14 points alternating
      if (rangeData.length >= 14) {
        for (let i = 0; i <= rangeData.length - 14; i++) {
          let alternating = true;
          for (let j = i + 1; j < i + 13; j++) {
            const curr = rangeData[j];
            const prev = rangeData[j - 1];
            const next = rangeData[j + 1];
            if ((curr > prev && curr > next) || (curr < prev && curr < next)) {
              continue;
            } else {
              alternating = false;
              break;
            }
          }
          if (alternating) {
            const opIdx = Math.floor(i / parts.length);
            rTestResults.test8.push({ operator: operators[opIdx], startPoint: i + 1 });
            break;
          }
        }
      }
      
