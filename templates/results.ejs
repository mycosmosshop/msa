      // Calculate standard deviation for tests
      const stdDev = (ucl - cl) / 3; // Approximate std dev from control limits
      
      // Control Chart Tests (8 tests as per Western Electric Rules)
      const testResults = {
        test1: [], // One point beyond 3σ
        test2: [], // 7 points in a row on same side
        test3: [], // 7 points in a row increasing/decreasing
        test4: [], // 2 out of 3 points > 2σ (same side)
        test5: [], // 15 points in a row < 1σ
        test6: [], // 8 points in a row > 1σ (both sides)
        test7: [], // 4 out of 5 points > 1σ (same side)
        test8: []  // 14 points alternating up/down
      };
      
      // Test 1: One point outside control limits (>3σ)
      avgData.forEach((val, idx) => {
        if (val > ucl || val < lcl) {
          const opIdx = Math.floor(idx / parts.length);
          const partIdx = idx % parts.length;
          testResults.test1.push({ operator: operators[opIdx], part: parts[partIdx], point: idx + 1 });
        }
      });
      
      // Test 2: 7 points in a row on same side of center line
      for (let i = 0; i <= avgData.length - 7; i++) {
        const segment = avgData.slice(i, i + 7);
        const allAbove = segment.every(v => v > cl);
        const allBelow = segment.every(v => v < cl);
        if (allAbove || allBelow) {
          const opIdx = Math.floor(i / parts.length);
          testResults.test2.push({ operator: operators[opIdx], startPoint: i + 1 });
          break; // Only report first occurrence
        }
