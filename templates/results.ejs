    function createMeasurementsByOperatorChart() {
      try {
        console.log('🔄 Creating Measurements by Operator chart...');
        
        // Destroy existing chart if it exists
        if (measurementsByOperatorChartInstance) {
          measurementsByOperatorChartInstance.destroy();
        }
        
        // Organize measurements by operator
        const operatorData = {};
        for (let op = 1; op <= study.num_operators; op++) {
          operatorData[op] = [];
        }
        
        measurements.forEach((m) => {
          let opKey = m.operator_id || m.operator || m.op_id || m.operatorId;
          const value = parseFloat(m.measurement);
          
          // If operator is string like "Operator 1", extract number
          if (typeof opKey === 'string') {
            const match = opKey.match(/(\d+)/);
            opKey = match ? parseInt(match[1]) : opKey;
          }
          
          if (!operatorData[opKey]) {
            operatorData[opKey] = [];
          }
          
          if (!isNaN(value)) {
            operatorData[opKey].push(value);
          }
        });
        
        console.log('Operator data organized:', operatorData);
        
        // Calculate quartiles for each operator
        function calculateQuartiles(data) {
          const sorted = [...data].sort((a, b) => a - b);
          const n = sorted.length;
          
          return {
            min: sorted[0],
            q1: sorted[Math.floor(n * 0.25)],
            median: sorted[Math.floor(n * 0.5)],
            q3: sorted[Math.floor(n * 0.75)],
            max: sorted[n - 1],
            mean: sorted.reduce((a, b) => a + b, 0) / n
          };
        }
        
        // Prepare box plot data
        const boxData = [];
        const operatorLabels = [];
        let overallMin = Infinity;
        let overallMax = -Infinity;
        
        for (let op = 1; op <= study.num_operators; op++) {
          const values = operatorData[op] || [];
          if (values.length > 0) {
            const stats = calculateQuartiles(values);
            boxData.push(stats);
            operatorLabels.push(getOperatorName(op));
            overallMin = Math.min(overallMin, stats.min);
            overallMax = Math.max(overallMax, stats.max);
          }
        }
        
        // Create datasets for box plot elements
        const datasets = [];
        
        // Box (Q1 to Q3) - using error bars
        const boxDataset = {
          label: 'IQR (Q1-Q3)',
          data: boxData.map((stats, i) => ({
            x: i,
            y: stats.median,
            yMin: stats.q1,
            yMax: stats.q3
          })),
          backgroundColor: 'rgba(200, 200, 200, 0.5)',
          borderColor: 'rgba(0, 0, 0, 0.8)',
          borderWidth: 2,
          pointRadius: 0
        };
        
        // Whiskers (min to max)
        const whiskerDataset = {
          label: 'Range',
          data: boxData.map((stats, i) => ({
            x: i,
            y: stats.median,
            yMin: stats.min,
            yMax: stats.max
          })),
          borderColor: 'rgba(0, 0, 0, 0.5)',
          borderWidth: 1,
          pointRadius: 0
        };
        
        // Median line
        const medianDataset = {
          label: 'Median',
          data: boxData.map((stats, i) => ({ x: i, y: stats.median })),
          backgroundColor: 'rgba(0, 0, 0, 0.9)',
          borderColor: 'rgba(0, 0, 0, 0.9)',
          borderWidth: 3,
          pointRadius: 0,
          pointStyle: 'line',
          type: 'line',
          showLine: false
        };
        
        // Custom plugin to draw box plots
        const boxPlotPlugin = {
          id: 'boxPlot',
          afterDatasetsDraw(chart) {
            const ctx = chart.ctx;
            const meta = chart.getDatasetMeta(0);
            
            boxData.forEach((stats, i) => {
              const x = meta.data[i].x;
              const boxWidth = 60; // Wider box for better visibility
              
              // Get y coordinates
              const yScale = chart.scales.y;
              const yMin = yScale.getPixelForValue(stats.min);
              const yQ1 = yScale.getPixelForValue(stats.q1);
              const yMedian = yScale.getPixelForValue(stats.median);
              const yQ3 = yScale.getPixelForValue(stats.q3);
              const yMax = yScale.getPixelForValue(stats.max);
              
              // Get theme-aware colors
              const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
              const strokeColor = isDark ? 'rgba(255, 255, 255, 0.9)' : 'rgba(0, 0, 0, 0.8)';
              const fillColor = isDark ? 'rgba(80, 80, 80, 0.6)' : 'rgba(240, 240, 240, 0.9)';
              const medianColor = isDark ? 'rgba(255, 255, 255, 1)' : 'rgba(0, 0, 0, 1)';
              
              // Draw whisker lines (vertical center line)
              ctx.strokeStyle = strokeColor;
              ctx.lineWidth = 1.5;
              
              // Bottom whisker (from min to Q1)
              ctx.beginPath();
              ctx.moveTo(x, yMin);
              ctx.lineTo(x, yQ1);
              ctx.stroke();
              
              // Top whisker (from Q3 to max)
              ctx.beginPath();
              ctx.moveTo(x, yQ3);
              ctx.lineTo(x, yMax);
              ctx.stroke();
              
              // Min/Max horizontal caps
              ctx.lineWidth = 1.5;
              ctx.beginPath();
              ctx.moveTo(x - boxWidth/3, yMin);
              ctx.lineTo(x + boxWidth/3, yMin);
              ctx.moveTo(x - boxWidth/3, yMax);
              ctx.lineTo(x + boxWidth/3, yMax);
              ctx.stroke();
              
              // Draw box (Q1 to Q3)
              ctx.fillStyle = fillColor;
              ctx.strokeStyle = strokeColor;
              ctx.lineWidth = 1.5;
              const boxHeight = yQ1 - yQ3;
              ctx.fillRect(x - boxWidth/2, yQ3, boxWidth, boxHeight);
              ctx.strokeRect(x - boxWidth/2, yQ3, boxWidth, boxHeight);
              
              // Draw median line (thicker and darker)
              ctx.strokeStyle = medianColor;
              ctx.lineWidth = 2.5;
              ctx.beginPath();
              ctx.moveTo(x - boxWidth/2, yMedian);
              ctx.lineTo(x + boxWidth/2, yMedian);
              ctx.stroke();
            });
          }
        };
        
        // Get theme-aware colors
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const textColor = isDark ? '#e8e8e8' : '#000000';  // Changed to pure black for light mode
        const gridColor = isDark ? 'rgba(255, 255, 255, 0.1)' : 'rgba(0, 0, 0, 0.1)';
        const borderColor = isDark ? 'rgba(255, 255, 255, 0.3)' : 'rgba(0, 0, 0, 0.8)';
        
        measurementsByOperatorChartInstance = new Chart(document.getElementById('measurementsByOperatorChart'), {
          type: 'scatter',
          data: {
            labels: operatorLabels,
            datasets: [{
              data: boxData.map((stats, i) => ({ x: i, y: stats.median })),
              pointRadius: 0
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
              legend: {
                display: false
              },
              tooltip: {
                enabled: false
              }
            },
            scales: {
              x: {
                type: 'category',
                labels: operatorLabels,
                offset: true,
                ticks: {
                  color: textColor,
                  font: {
                    size: 12
                  }
                },
                title: {
                  display: true,
                  text: 'Operator',
                  color: textColor,
                  font: {
                    size: 13,
                    weight: 'bold'
                  }
                },
                grid: {
                  display: false,
                  offset: true
                }
              },
              y: {
                beginAtZero: false,
                min: overallMin - (overallMax - overallMin) * 0.1,
                max: overallMax + (overallMax - overallMin) * 0.1,
                title: {
                  display: true,
                  text: 'Measurement',
                  color: textColor,
                  font: {
                    size: 13,
                    weight: 'bold'
                  }
                },
                ticks: {
                  color: textColor,
                  font: {
                    size: 11
                  },
                  precision: 1
                },
                grid: {
                  display: true,
                  color: gridColor,
                  lineWidth: 1
                },
                border: {
                  display: true,
                  width: 2,
                  color: borderColor
                }
              }
            }
          },
          plugins: [chartBackgroundPlugin, boxPlotPlugin]
        });
        
        // Generate interpretation text
        let interpretation = '<div style="margin-top: 10px; padding: 10px; background-color: #f8f9fa; border-left: 4px solid #007bff; border-radius: 4px;">';
        interpretation += '<strong>📊 Grafik Yorumu:</strong><br>';
        
        // Check operator consistency
        const ranges = boxData.map(stats => stats.max - stats.min);
        const avgRange = ranges.reduce((a, b) => a + b, 0) / ranges.length;
        const maxRange = Math.max(...ranges);
        const minRange = Math.min(...ranges);
        
        if (maxRange / minRange > 2) {
          interpretation += '⚠️ <strong>Operatörler arası tutarsızlık:</strong> Bazı operatörlerin ölçüm aralığı diğerlerinden önemli ölçüde farklı. ';
        } else {
          interpretation += '✅ <strong>Operatörler tutarlı:</strong> Tüm operatörlerin ölçüm aralıkları benzer. ';
        }
        
        // Check median differences
        const medians = boxData.map(stats => stats.median);
        const medianRange = Math.max(...medians) - Math.min(...medians);
        const overallRange = overallMax - overallMin;
        
        if (medianRange / overallRange > 0.3) {
          interpretation += '<br>⚠️ <strong>Operatör bias (yanlılık) var:</strong> Operatörlerin medyan değerleri birbirinden farklı, bu reproducibility sorununa işaret ediyor.';
        } else {
          interpretation += '<br>✅ <strong>Operatör bias düşük:</strong> Tüm operatörlerin medyan değerleri benzer.';
        }
        
        // Box width interpretation
        const iqrs = boxData.map(stats => stats.q3 - stats.q1);
        const avgIQR = iqrs.reduce((a, b) => a + b, 0) / iqrs.length;
        
        interpretation += `<br>📏 <strong>Ortalama IQR (Interquartile Range):</strong> ${avgIQR.toFixed(3)} - Operatör içi varyasyon (repeatability) göstergesi.`;
        
        interpretation += '</div>';
        
        // Replace content to avoid duplication (use = instead of +=)
        const descElement = document.getElementById('operatorChartDescription');
        const staticDesc = '<strong>Grafik Açıklaması:</strong> Her operatör için ölçüm dağılımını box plot olarak gösterir. Kutu (box) ölçümlerin %50\'sini içerir (Q1-Q3 arası), ortadaki çizgi medyan değerdir. Bıyıklar min/max değerleri gösterir.';
        descElement.innerHTML = staticDesc + interpretation;
        
        console.log('✅ Measurements by Operator chart created successfully');
        
      } catch (error) {
        console.error('❌ Measurements by Operator Error:', error);
        console.error('Error details:', error.message, error.stack);
      }
    }
    
    // Create chart initially
    createMeasurementsByOperatorChart();
    <% } else { %>
    console.warn('❌ showMeasurementsByOp is FALSE - Chart skipped!');
    console.warn('   analysisOptions.plots.measurements_op:', analysisOptions.plots?.measurements_op);
    console.warn('   analysisOptions.plots.measurements_by_op:', analysisOptions.plots?.measurements_by_op);
    <% } %>

    // Generate Interpretations for All Charts
    (function() {
      try {
        // Components of Variation Interpretation
        <% if (showComponents) { %>
        const componentsInterpretation = document.getElementById('componentsInterpretation');
        if (!componentsInterpretation) {
          const componentsDesc = document.querySelector('#componentsChart').closest('.chart-container').querySelector('.chart-description');
          if (componentsDesc) {
            let compText = '<div style="margin-top: 10px; padding: 10px; background-color: #f8f9fa; border-left: 4px solid #007bff; border-radius: 4px;">';
            compText += '<strong>📊 Grafik Yorumu:</strong><br>';
            
            const grr = <%= results.gaugeEvaluation.totalGaugeRR.pctStudyVar %>;
            const repeatability = <%= results.gaugeEvaluation.repeatability.pctStudyVar %>;
            const reproducibility = <%= results.gaugeEvaluation.reproducibility.pctStudyVar %>;
            const partToPart = <%= results.gaugeEvaluation.partToPart.pctStudyVar %>;
            
            // Genel GRR Değerlendirme
            if (grr < 10) {
              compText += '✅ <strong>Mükemmel ölçüm sistemi (GRR=' + grr.toFixed(1) + '%):</strong> Varyasyonun çoğu parçalardan geliyor. Ölçüm sistemi güvenilir ve kabul edilebilir.';
            } else if (grr < 30) {
              compText += '⚠️ <strong>Marjinal ölçüm sistemi (GRR=' + grr.toFixed(1) + '%):</strong> Kabul edilebilir ama iyileştirilebilir.';
            } else {
              compText += '❌ <strong>Kabul edilemez ölçüm sistemi (GRR=' + grr.toFixed(1) + '%):</strong> Varyasyonun büyük kısmı ölçüm sisteminden kaynaklanıyor.';
            }
            
            compText += '<br><br><strong>📊 Bileşen Analizi:</strong>';
            
            // Repeatability Analizi
            compText += '<br>🔄 <strong>Repeatability (' + repeatability.toFixed(1) + '%):</strong> ';
            if (repeatability < 10) {
              compText += '✅ Mükemmel - Aynı operatör tutarlı ölçümler yapıyor.';
            } else if (repeatability < 20) {
              compText += '⚠️ İyileştirilebilir - Cihaz kalibrasyonu ve bakımı önerilir.';
            } else {
              compText += '❌ Yüksek - Ölçüm cihazını kontrol edin, kalibrasyon yapın veya metodoloji değişikliği düşünün.';
            }
            
            // Reproducibility Analizi
            compText += '<br>👥 <strong>Reproducibility (' + reproducibility.toFixed(1) + '%):</strong> ';
            if (reproducibility < 10) {
              compText += '✅ Mükemmel - Operatörler arası yüksek uyum var.';
            } else if (reproducibility < 20) {
              compText += '⚠️ İyileştirilebilir - Operatör eğitimi ve prosedür standardizasyonu önerilir.';
            } else {
              compText += '❌ Yüksek - Operatör eğitimi verin, ölçüm prosedürünü netleştirin, görsel yardımcılar kullanın.';
            }
            
            // Gage R&R Genel Yorum
            compText += '<br>📏 <strong>Gage R&R (' + grr.toFixed(1) + '%):</strong> ';
            if (grr < 10) {
              compText += '✅ Ölçüm sistemi varyasyonun küçük bir kısmını oluşturuyor - sistem güvenilir.';
            } else if (grr < 30) {
              compText += '⚠️ Ölçüm sistemi varyasyonun önemli bir kısmını oluşturuyor - iyileştirme önerilir.';
              if (repeatability > reproducibility) {
                compText += ' Öncelik: Cihaz kalibrasyonu ve bakımı.';
              } else {
                compText += ' Öncelik: Operatör eğitimi.';
              }
            } else {
              compText += '❌ Ölçüm sistemi varyasyonun büyük kısmını oluşturuyor - acil iyileştirme gerekli.';
            }
            
            // Part-to-Part Analizi
            compText += '<br>� <strong>Part-to-Part (' + partToPart.toFixed(1) + '%):</strong> ';
            if (partToPart > 50) {
              compText += '✅ Parçalar arası varyasyon yüksek - bu iyi bir işaret, ölçüm sistemi parçalar arasındaki farkları ayırt edebiliyor.';
            } else if (partToPart > 30) {
              compText += '⚠️ Parçalar arası varyasyon orta düzeyde - ölçüm sistemi bazı parça farklarını ayırt edebiliyor.';
            } else {
              compText += '❌ Parçalar arası varyasyon düşük - ölçüm sistemi parçalar arasındaki farkları yeterince ayırt edemiyor veya parçalar gerçekten çok benzer.';
            }
            
            compText += '</div>';
            componentsDesc.insertAdjacentHTML('afterend', compText);
          }
        }
        <% } %>

        // R Chart Interpretation
        <% if (showRangeCharts && controlCharts && controlCharts.r) { %>
        const rInterpretation = document.getElementById('rChartInterpretation');
        if (rInterpretation) {
          let rText = '<div style="padding: 10px; background-color: #f8f9fa; border-left: 4px solid #eb5545; border-radius: 4px;">';
          rText += '<strong>📊 Grafik Yorumu:</strong><br>';
          
          const rOutliers = <%= JSON.stringify(controlCharts.r.outliers || []) %>;
          if (rOutliers.length === 0) {
            rText += '✅ <strong>Tüm noktalar kontrol limitleri içinde:</strong> Operatör içi tutarlılık iyi (repeatability kabul edilebilir).';
          } else {
            rText += `⚠️ <strong>${rOutliers.length} nokta kontrol limitlerinin dışında:</strong> Bazı operatörler bazı parçalarda tutarsız ölçüm yapıyor. `;
            rText += 'Bu operatörler eğitim gerektirebilir veya ölçüm cihazı kalibre edilmeli.';
          }
          
          rText += '</div>';
          rInterpretation.innerHTML = rText;
        }
        <% } %>

        // X̄ Chart Interpretation
        <% if (showAverageChart && controlCharts && controlCharts.xbar) { %>
        const xbarInterpretation = document.getElementById('xbarChartInterpretation');
        if (xbarInterpretation) {
          let xbarText = '<div style="padding: 10px; background-color: #f8f9fa; border-left: 4px solid #667eea; border-radius: 4px;">';
          xbarText += '<strong>📊 Grafik Yorumu:</strong><br>';
          
          const xbarOutliers = <%= JSON.stringify(controlCharts.xbar.outliers || []) %>;
          if (xbarOutliers.length === 0) {
            xbarText += '✅ <strong>Tüm operatör ortalamaları kontrol limitleri içinde:</strong> Operatör bias (yanlılık) kabul edilebilir düzeyde.';
          } else {
            xbarText += `⚠️ <strong>${xbarOutliers.length} operatör ortalaması kontrol limitlerinin dışında:</strong> Bazı operatörler sistematik olarak yüksek veya düşük ölçüm yapıyor. `;
            xbarText += 'Bu reproducibility sorununa işaret ediyor - operatör eğitimi veya standart prosedür gerekli.';
          }
          
          xbarText += '</div>';
          xbarInterpretation.innerHTML = xbarText;
        }
        <% } %>

        // Interaction Plot Interpretation
        <% if (showInteraction) { %>
        const interactionInterpretation = document.getElementById('interactionChartInterpretation');
        if (interactionInterpretation) {
          let intText = '<div style="padding: 10px; background-color: #f8f9fa; border-left: 4px solid #007bff; border-radius: 4px;">';
          intText += '<strong>📊 Grafik Yorumu:</strong><br>';
          
          const repeatability = <%= results.gaugeEvaluation.repeatability.pctStudyVar %>;
          const reproducibility = <%= results.gaugeEvaluation.reproducibility.pctStudyVar %>;
          
          if (reproducibility < 10) {
            intText += '✅ <strong>Çizgiler paralel:</strong> Operatörler tüm parçalarda tutarlı davranıyor, etkileşim yok.';
          } else if (reproducibility < 20) {
            intText += '⚠️ <strong>Hafif etkileşim var:</strong> Bazı operatörler farklı parçalarda farklı davranıyor olabilir.';
          } else {
            intText += '❌ <strong>Belirgin etkileşim:</strong> Operatörler farklı parçalarda farklı davranıyor, reproducibility sorunu ciddi.';
          }
          
          intText += '</div>';
          interactionInterpretation.innerHTML = intText;
        }
        <% } %>

        // Measurements by Part Interpretation
        <% if (showMeasurementsByPart) { %>
        const partInterpretation = document.getElementById('measurementsByPartInterpretation');
        if (partInterpretation) {
          let partText = '<div style="padding: 10px; background-color: #f8f9fa; border-left: 4px solid #28a745; border-radius: 4px;">';
          partText += '<strong>📊 Grafik Yorumu:</strong><br>';
          
          const partToPart = <%= results.gaugeEvaluation.partToPart.pctStudyVar %>;
          
          if (partToPart > 70) {
            partText += '✅ <strong>Part-to-Part varyasyon yüksek (>' + partToPart.toFixed(1) + '%):</strong> İyi! Ölçüm sistemi parçalar arasındaki farkları ayırt edebiliyor.';
          } else if (partToPart > 50) {
            partText += '⚠️ <strong>Part-to-Part varyasyon orta (' + partToPart.toFixed(1) + '%):</strong> Kabul edilebilir ama ölçüm sistemi geliştirilebilir.';
          } else {
            partText += '❌ <strong>Part-to-Part varyasyon düşük (' + partToPart.toFixed(1) + '%):</strong> Ölçüm sistemi parçalar arasındaki farkları yeterince ayırt edemiyor.';
          }
          
          partText += '</div>';
          partInterpretation.innerHTML = partText;
        }
        <% } %>
        
        // Matrix Plot Interpretation
        <% if (showScatter) { %>
        const matrixInterpretation = document.getElementById('matrixPlotInterpretation');
        if (matrixInterpretation) {
          let matrixText = '<div style="padding: 10px; background-color: #f8f9fa; border-left: 4px solid #17a2b8; border-radius: 4px;">';
          matrixText += '<strong>📊 Grafik Yorumu:</strong><br>';
          
          const reproducibility = <%= results.gaugeEvaluation.reproducibility.pctStudyVar %>;
          const showFitLine = <%= analysisOptions.plots?.fit_line ? 'true' : 'false' %>;
          const showOriginLine = <%= analysisOptions.plots?.origin_line ? 'true' : 'false' %>;
          
          if (reproducibility < 10) {
            matrixText += '✅ <strong>Operatörler arası yüksek uyum:</strong> ';
            if (showOriginLine) {
              matrixText += 'Noktalar 45° çizgisine yakın, operatörler aynı ölçümleri yapıyor. ';
            }
            matrixText += 'Reproducibility mükemmel (' + reproducibility.toFixed(1) + '%).';
          } else if (reproducibility < 20) {
            matrixText += '⚠️ <strong>Operatörler arası orta düzey uyum:</strong> ';
            if (showOriginLine) {
              matrixText += 'Bazı noktalar 45° çizgisinden sapıyor. ';
            }
            matrixText += 'Operatör eğitimi reproducibility\'yi iyileştirebilir (' + reproducibility.toFixed(1) + '%).';
          } else {
            matrixText += '❌ <strong>Operatörler arası düşük uyum:</strong> ';
            if (showOriginLine) {
              matrixText += 'Noktalar 45° çizgisinden önemli ölçüde sapıyor. ';
            }
            matrixText += 'Ciddi reproducibility sorunu (' + reproducibility.toFixed(1) + '%). Standardizasyon ve eğitim şart.';
          }
          
          if (showFitLine) {
            matrixText += '<br>📏 <strong>Fit line (regresyon çizgisi):</strong> Operatörler arası sistematik farkı gösterir.';
          }
          
          matrixText += '</div>';
          matrixInterpretation.innerHTML = matrixText;
        }
        <% } %>
        
        console.log('✅ Chart interpretations generated');
        
      } catch (error) {
        console.error('❌ Interpretation generation error:', error);
      }
    })();

    console.log('✅ All charts initialized successfully');
    }); // End of window.addEventListener('load')
  </script>
  
  <!-- Theme Switcher Script -->
  <script src="js/theme-switcher.js"></script>
</body>
</html>




