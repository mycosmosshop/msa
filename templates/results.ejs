<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analiz Sonuçları - <%= study.study_name %></title>
  
  <!-- Prevent theme flashing - load theme before any rendering -->
  <script>
    (function() {
      const theme = localStorage.getItem('theme_mode') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  
  <!-- Bootstrap Icons for theme toggle -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <!-- Dark Mode CSS -->
  <link rel="stylesheet" href="css/dark-mode.css">
  
  <!-- Responsive CSS -->
  <link rel="stylesheet" href="css/responsive.css">
  
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <style>
    /* Zoom stability rules */
    html {
      font-size: 16px;                     /* Base font size for rem calculations */
      overflow-x: hidden;
      width: 100%;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      max-width: 100%;                     /* Prevent elements from exceeding container */
    }
    
    img, canvas, svg {
      max-width: 100%;
      height: auto;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 1.25rem;                    /* 20px → rem units for zoom stability */
      overflow-x: hidden;                   /* Prevent horizontal scroll */
    }

    .container {
      max-width: 100rem;                   /* 1600px → rem units */
      width: 100%;
      margin: 0 auto;
      background: var(--card-bg);
      color: var(--text-primary);
      border-radius: 1.25rem;              /* 20px → rem */
      padding: 1.875rem;                   /* 30px → rem */
      box-shadow: 0 1.25rem 3.75rem rgba(0,0,0,0.3);
      overflow-x: hidden;                   /* Prevent inner overflow */
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;                     /* Wrap on small zoom */
      margin-bottom: 1.875rem;             /* 30px → rem */
      padding-bottom: 1.25rem;             /* 20px → rem */
      border-bottom: 0.125rem solid var(--border-color);
      gap: 1rem;                           /* Add gap for wrapped items */
      width: 100%;
    }

    .header h1 {
      color: var(--text-primary);
      font-size: 1.75rem;                  /* 28px → rem */
      display: flex;
      align-items: center;
      gap: 0.9375rem;                      /* 15px → rem */
      flex: 1;
      min-width: 0;                        /* Allow text truncation */
    }

    .status-badge {
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 13px;
      font-weight: 700;
      display: inline-block;
      text-align: center;
      border: 2px solid transparent;
      white-space: nowrap;
      text-transform: none;
    }

    .status-acceptable {
      background: #c8e6c9;
      color: #1b5e20;
      border-color: #4caf50;
    }

    .status-marginal {
      background: #ffe0b2;
      color: #e65100;
      border-color: #ff9800;
      font-weight: 800;
    }

    .status-unacceptable {
      background: #ffcdd2;
      color: #b71c1c;
      border-color: #f44336;
    }

    .status-draft {
      background: #f5f5f5;
      color: #616161;
      border-color: #9e9e9e;
    }

    /* Status Badge - Dark Mode Support */
    [data-theme="dark"] .status-acceptable {
      background: #1b5e20 !important;
      color: #a5d6a7 !important;
      border-color: #4caf50 !important;
    }

    [data-theme="dark"] .status-marginal {
      background: #e65100 !important;
      color: #ffcc80 !important;
      border-color: #ff9800 !important;
    }

    [data-theme="dark"] .status-unacceptable {
      background: #b71c1c !important;
      color: #ef9a9a !important;
      border-color: #f44336 !important;
    }

    [data-theme="dark"] .status-draft {
      background: #424242 !important;
      color: #bdbdbd !important;
      border-color: #757575 !important;
    }

    .btn-group {
      display: flex;
      gap: 10px;
    }

    .btn {
      padding: 12px 24px;
      border: none;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      text-decoration: none;
      display: inline-block;
    }

    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
    }

    .btn-secondary {
      background: #6c757d;
      color: white;
    }

    .btn-secondary:hover {
      background: #5a6268;
      transform: translateY(-2px);
    }
    
    .btn-print {
      background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
      color: white;
    }
    
    .btn-print:hover {
      transform: translateY(-2px);
      box-shadow: 0 5px 15px rgba(245, 87, 108, 0.4);
    }

    .study-info {
      background: var(--bg-tertiary);
      padding: 20px;
      border-radius: 10px;
      margin-bottom: 30px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
    }

    .info-item {
      display: flex;
      flex-direction: column;
    }

    .info-label {
      color: var(--text-secondary);
      font-size: 12px;
      margin-bottom: 5px;
    }

    .info-value {
      color: var(--text-primary);
      font-size: 16px;
      font-weight: 600;
    }

    .section {
      margin-bottom: 40px;
      overflow: visible;
      position: relative;
    }

    .section-title {
      font-size: 20px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 20px;
      padding-left: 15px;
      border-left: 4px solid #667eea;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      background: var(--card-bg);
      color: var(--text-primary);
      border-radius: 10px;
      overflow: visible;
      box-shadow: 0 2px 10px var(--shadow-color);
      position: relative;
    }

    thead {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    thead th {
      color: white;
      padding: 15px;
      text-align: center;
      font-weight: 600;
      font-size: 14px;
    }

    tbody tr {
      transition: background 0.2s;
    }

    tbody tr:hover {
      background: var(--bg-tertiary);
    }

    tbody tr:nth-child(even) {
      background: var(--bg-secondary);
    }

    tbody td {
      padding: 12px 15px;
      text-align: center;
      border-bottom: 1px solid var(--border-color);
    }

    tbody td:first-child {
      font-weight: 600;
      text-align: left;
      color: var(--text-primary);
    }
    
    /* Table total row */
    .table-total-row {
      font-weight: 700;
      background: var(--bg-tertiary) !important;
    }
    
    /* Info box for warnings/recommendations */
    .info-box {
      margin-top: 15px;
      padding: 12px;
      background: var(--bg-tertiary);
      border-radius: 6px;
    }
    
    .info-box.warning {
      background: rgba(240, 152, 25, 0.1);
      border-left: 4px solid #f09819;
    }
    
    .info-box.info {
      background: var(--bg-tertiary);
      border-left: 4px solid #667eea;
    }
    
    /* Matrix plot empty cells */
    .matrix-empty-cell {
      background-color: var(--bg-secondary);
    }
    
    /* Matrix plot grid - keep aspect ratio on zoom */
    .matrix-plot-grid {
      display: grid;
      grid-template-columns: repeat(var(--matrix-cols), 1fr);
      gap: 0.5rem;                         /* 8px → rem */
      margin-bottom: 1.25rem;              /* 20px → rem */
      max-width: 100%;
      width: 100%;
      justify-content: center;
    }
    
    .matrix-plot-cell {
      position: relative;
      aspect-ratio: 1 / 1;
      min-height: 11.25rem;                /* 180px → rem */
      max-height: 21.875rem;               /* 350px → rem */
      width: 100%;
      overflow: visible;                    /* Allow labels to overflow */
    }
    
    .matrix-plot-cell canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100% !important;
      height: 100% !important;
    }

    .chart-grid {
      display: grid;
      grid-template-columns: 1fr;          /* Default: single column */
      gap: 1.875rem;                       /* 30px → rem */
      margin-bottom: 1.875rem;
      width: 100%;
      max-width: 100%;
    }
    
    /* Responsive adjustments for chart grid - using rem-based breakpoints */
    @media (min-width: 87.5rem) {          /* 1400px */
      .chart-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    
    @media (min-width: 112.5rem) {         /* 1800px */
      .chart-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .chart-container {
      background: var(--card-bg);
      color: var(--text-primary);
      padding: 1.25rem;                    /* 20px → rem */
      border-radius: 0.625rem;             /* 10px → rem */
      box-shadow: 0 0.125rem 0.625rem var(--shadow-color);
      min-height: 25rem;                   /* 400px → rem */
      width: 100%;
      max-width: 100%;
      overflow: hidden;                     /* Prevent content overflow */
    }

    .chart-title {
      font-size: 1rem;                     /* 16px → rem */
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.9375rem;            /* 15px → rem */
      text-align: center;
    }

    .chart-wrapper {
      position: relative;
      height: 25rem;                       /* 400px → rem */
      min-height: 18.75rem;                /* 300px → rem */
      width: 100%;
      max-width: 100%;
    }
    
    /* Matrix plot specific styles */
    .matrix-plot-wrapper {
      position: relative;
      max-width: 90%;
      margin: 0 auto;
      padding: 3rem 5rem;                  /* Extra padding for labels */
      width: 100%;
    }
    
    .matrix-plot-wrapper canvas {
      position: absolute;
      top: 0;
      left: 0;
      width: 100% !important;
      height: 100% !important;
    }
    
    .chart-description {
      margin-top: 12px;
      padding: 10px 15px;
      background: var(--bg-tertiary);
      border-left: 3px solid #667eea;
      border-radius: 4px;
      font-size: 13px;
      line-height: 1.6;
      color: var(--text-secondary);
    }
    
    .chart-description strong {
      color: var(--text-primary);
      font-weight: 600;
    }

    .interpretation {
      background: var(--bg-tertiary);
      padding: 25px;
      border-radius: 15px;
      margin-bottom: 30px;
      border-left: 6px solid #667eea;
    }

    .interpretation h3 {
      color: var(--text-primary);
      margin-bottom: 15px;
      font-size: 18px;
    }

    .interpretation p {
      color: var(--text-secondary);
      line-height: 1.6;
      margin-bottom: 10px;
    }

    .metric-highlight {
      display: inline-block;
      padding: 4px 12px;
      background: #667eea;
      color: white;
      border-radius: 6px;
      font-weight: 600;
      margin: 0 5px;
    }

    .variance-row {
      display: flex;
      justify-content: space-between;
      padding: 15px;
      background: var(--card-bg);
      border-radius: 8px;
      margin-bottom: 10px;
      box-shadow: 0 2px 5px var(--shadow-color);
    }

    .variance-label {
      font-weight: 600;
      color: var(--text-secondary);
    }

    .variance-value {
      font-weight: 700;
      font-size: 18px;
      color: var(--text-primary);
    }

    .traffic-light-container {
      padding: 30px;
      background: var(--bg-tertiary);
      border-radius: 15px;
    }
    
    .traffic-light-row {
      margin-bottom: 60px;
      position: relative;
    }
    
    .traffic-light-row:last-child {
      margin-bottom: 0;
    }
    
    .traffic-light-label {
      font-size: 13px;
      color: var(--text-secondary);
      margin-bottom: 8px;
      font-weight: 600;
    }

    .traffic-light {
      width: 100%;
      height: 50px;
      border-radius: 8px;
      position: relative;
      overflow: visible;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      display: flex;
      margin-top: 30px;
      margin-bottom: 30px;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .traffic-section {
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 600;
      font-size: 11px;
      color: white;
      transition: all 0.3s;
      border-right: 1px solid rgba(255,255,255,0.2);
      clip-path: inherit;
    }
    
    .traffic-section:first-child {
      border-radius: 8px 0 0 8px;
    }
    
    .traffic-section:last-child {
      border-right: none;
      border-radius: 0 8px 8px 0;
    }

    .traffic-green {
      background: #15B79E;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .traffic-yellow {
      background: #F0B429;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    .traffic-red {
      background: #E5484D;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }
    
    .traffic-boundary {
      position: absolute;
      top: 0;
      height: 100%;
      width: 2px;
      background: var(--text-primary);
      z-index: 5;
      pointer-events: none;
    }
    
    .boundary-label {
      position: absolute;
      top: 100%;
      left: 50%;
      margin-top: 5px;
      font-size: 11px;
      font-weight: 600;
      color: var(--text-secondary);
      transform: translateX(-50%);
      white-space: nowrap;
    }

    .traffic-indicator {
      position: absolute;
      top: 0;
      height: 100%;
      width: 3px;
      background: var(--text-primary);
      box-shadow: 0 0 8px var(--shadow-color);
      transition: left 0.5s;
      z-index: 10;
      pointer-events: none;
    }
    
    .traffic-value {
      position: absolute;
      bottom: 100%;
      left: 50%;
      margin-bottom: 5px;
      font-size: 13px;
      font-weight: 700;
      color: var(--text-primary);
      transform: translateX(-50%);
      white-space: nowrap;
    }
    
    .traffic-scale {
      display: flex;
      justify-content: space-between;
      margin-top: 8px;
      font-size: 11px;
      color: var(--text-secondary);
      font-weight: 600;
    }
    
    /* Tooltip Styles */
    .tooltip-cell {
      position: relative;
      cursor: help;
    }
    
    tbody .tooltip-cell:hover {
      background-color: var(--bg-tertiary) !important;
    }
    
    thead .tooltip-cell:hover {
      background-color: rgba(255, 255, 255, 0.1) !important;
    }
    
    .tooltip {
      visibility: hidden;
      opacity: 0;
      position: absolute;
      z-index: 10000;
      background: var(--bg-secondary);
      color: var(--text-primary);
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 13px;
      line-height: 1.6;
      min-width: 250px;
      max-width: 400px;
      box-shadow: 0 4px 12px var(--shadow-color);
      pointer-events: none;
      transition: opacity 0.2s, visibility 0.2s;
      white-space: normal;
    }
    
    .tooltip-cell:hover .tooltip {
      visibility: visible;
      opacity: 1;
      left: 50%;
      top: -10px;
      transform: translate(-50%, -100%);
    }
    
    .tooltip::after {
      content: '';
      position: absolute;
      top: 100%;
      left: 50%;
      transform: translateX(-50%);
      border: 6px solid transparent;
      border-top-color: var(--bg-secondary);
    }
    
    /* Ensure table allows overflow for tooltips */
    table {
      position: relative;
    }
    
    tbody tr {
      position: relative;
    }
    
    .tooltip-title {
      font-weight: 700;
      margin-bottom: 6px;
      color: #667eea;
      font-size: 14px;
    }
    
    .tooltip-formula {
      font-family: 'Courier New', monospace;
      background: var(--bg-tertiary);
      padding: 4px 8px;
      border-radius: 4px;
      margin: 6px 0;
      font-size: 12px;
      color: var(--text-primary);
    }
    
    .tooltip-description {
      margin-top: 8px;
      font-size: 12px;
      color: var(--text-secondary);
    }
    
    /* Recommendation Box */
    .recommendation-box {
      margin-top: 20px;
      padding: 20px;
      border-radius: 12px;
      border-left: 5px solid;
      background: var(--bg-tertiary);
      color: var(--text-primary);
    }
    
    .recommendation-box.acceptable {
      border-color: #38ef7d;
    }
    
    .recommendation-box.marginal {
      border-color: #f09819;
    }
    
    .recommendation-box.unacceptable {
      border-color: #eb3349;
    }
    
    .recommendation-box h3 {
      margin-bottom: 12px;
      font-size: 18px;
      display: flex;
      align-items: center;
      gap: 10px;
      color: var(--text-primary);
    }
    
    .recommendation-box ul {
      margin-left: 20px;
      line-height: 1.8;
    }
    
    .recommendation-box li {
      margin-bottom: 8px;
    }
    
    .corrective-actions {
      margin-top: 15px;
      padding: 15px;
      background: var(--card-bg);
      border-radius: 8px;
    }
    
    .corrective-actions h4 {
      color: #e74c3c;
      margin-bottom: 10px;
      font-size: 16px;
    }
    
    /* Print/PDF Styles */
    .print-header {
      display: none;
    }
    
    @media print {
      body {
        background: white;
        padding: 0;
      }
      
      .container {
        max-width: 100%;
        box-shadow: none;
        padding: 20px;
        border-radius: 0;
      }
      
      .header,
      .btn-group,
      .btn,
      .no-print {
        display: none !important;
      }
      
      .print-header {
        display: block;
        margin-bottom: 30px;
        padding: 25px;
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border: 2px solid #667eea;
        border-radius: 12px;
        page-break-inside: avoid;
      }
      
      .print-header-title {
        text-align: center;
        font-size: 24px;
        font-weight: 700;
        color: #667eea;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
      }
      
      .print-study-info {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        padding: 15px;
        background: white;
        border-radius: 8px;
        margin-top: 15px;
      }
      
      .print-info-item {
        padding: 10px;
        border-left: 3px solid #667eea;
      }
      
      .print-info-label {
        font-size: 11px;
        color: #666;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        margin-bottom: 5px;
      }
      
      .print-info-value {
        font-size: 14px;
        color: #333;
        font-weight: 700;
      }
      
      .study-info {
        display: none;
      }
      
      .section {
        page-break-inside: avoid;
        margin-bottom: 30px;
      }
      
      .interpretation {
        page-break-inside: avoid;
        page-break-after: avoid;
        margin-bottom: 20px;
      }
      
      .chart-container {
        page-break-inside: avoid;
        margin-bottom: 20px;
      }
      
      table {
        page-break-inside: auto;
        font-size: 11px;
      }
      
      thead {
        display: table-header-group;
      }
      
      tr {
        page-break-inside: avoid;
        page-break-after: auto;
      }
      
      .section-title {
        page-break-after: avoid;
        font-size: 18px;
        margin-top: 20px;
      }
      
      /* Hide tooltips in print */
      .tooltip {
        display: none !important;
      }
      
      /* Ensure charts print correctly */
      canvas {
        max-width: 100% !important;
        height: auto !important;
      }
      
      .chart-grid {
        grid-template-columns: 1fr;
      }
      
      /* Status badge for print */
      .status-badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        border: 2px solid currentColor;
        background: white !important;
      }
      
      .status-acceptable {
        color: #1b5e20 !important;
        border-color: #4caf50 !important;
      }
      
      .status-marginal {
        color: #e65100 !important;
        border-color: #ff9800 !important;
        font-weight: 800;
      }
      
      .status-unacceptable {
        color: #b71c1c !important;
        border-color: #f44336 !important;
      }
    }
  </style>
</head>
<body>
  <%
    // Analysis options - global variable for the whole page
    const analysisOptions = study.analysis_options || { 
      plots: {}, 
      show_tooltips: true, 
      show_recommendations: true 
    };
    
    // Debug: Log to console
    console.log('📊 Analysis Options:', {
      show_tooltips: analysisOptions.show_tooltips,
      show_recommendations: analysisOptions.show_recommendations,
      full: analysisOptions
    });
  %>
  
  <div class="container">
    <div class="header">
      <div>
        <h1>
          📊 Gage R&R Analiz Sonuçları
          <% 
            let statusClass = 'status-unacceptable';
            let statusText = 'Kabul Edilemez';
            if (results.interpretation.acceptability === 'Acceptable') {
              statusClass = 'status-acceptable';
              statusText = '✓ Kabul Edilebilir';
            } else if (results.interpretation.acceptability === 'Marginal') {
              statusClass = 'status-marginal';
              statusText = '⚠ Marjinal';
            }
          %>
          <span class="status-badge <%= statusClass %>"><%= statusText %></span>
        </h1>
        <p style="color: #666; margin-top: 10px; font-size: 14px;">
          <%= study.study_name %>
          <% if (study.study_type === 'type3') { %>
            <span style="background: #667eea; color: white; padding: 2px 8px; border-radius: 4px; font-size: 12px; margin-left: 10px;">Type 3 study (automatic equipment)</span>
          <% } %>
        </p>
      </div>
      <div class="btn-group" style="display: flex; align-items: center; gap: 10px;">
        <!-- Theme Toggle Button -->
