                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>" style="font-weight: 700; color: <%= results.gaugeEvaluation.totalGaugeRR.pctStudyVar < 10 ? '#38ef7d' : results.gaugeEvaluation.totalGaugeRR.pctStudyVar < 30 ? '#f09819' : '#eb3349' %>">
              <%= results.gaugeEvaluation.totalGaugeRR.pctStudyVar.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">% Study Variation</div>
                  <div class="tooltip-formula">% = (SV(GRR) / SV(Total)) × 100</div>
                  <div class="tooltip-description">
                    <strong>Ana Kabul Kriteri:</strong><br>
                    < 10%: Kabul Edilebilir (Yeşil)<br>
                    10-30%: Marjinal (Turuncu)<br>
                    > 30%: Kabul Edilemez (Kırmızı)
                  </div>
                </div>
              <% } %>
            </td>
            <% if (results.gaugeEvaluation.toleranceWidth && results.gaugeEvaluation.totalGaugeRR.pctTolerance !== null) { %>
              <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>" style="font-weight: 700; color: <%= results.gaugeEvaluation.totalGaugeRR.pctTolerance < 10 ? '#38ef7d' : results.gaugeEvaluation.totalGaugeRR.pctTolerance < 30 ? '#f09819' : '#eb3349' %>">
                <%= results.gaugeEvaluation.totalGaugeRR.pctTolerance.toFixed(2) %>
                <% if (analysisOptions.show_tooltips !== false) { %>
                  <div class="tooltip">
                    <div class="tooltip-title">% Tolerance</div>
                    <div class="tooltip-formula">% = (SV(GRR) / Tolerance Width) × 100</div>
                    <div class="tooltip-description">
                      Ölçüm sisteminin tolerans genişliğine oranı.<br>
                      < 10%: Mükemmel<br>
                      10-30%: Kabul edilebilir<br>
                      > 30%: İyileştir
                    </div>
                  </div>
                <% } %>
              </td>
            <% } %>
          </tr>
          <tr>
            <td>Repeatability</td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.repeatability.stdDev.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Repeatability Std. Dev.</div>
                  <div class="tooltip-formula">σ(EV) = √Var(Repeatability)</div>
                  <div class="tooltip-description">
