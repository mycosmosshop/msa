      // Test 3: 7 points in a row all increasing or decreasing
      for (let i = 0; i <= avgData.length - 7; i++) {
        const segment = avgData.slice(i, i + 7);
        const increasing = segment.every((v, j) => j === 0 || v > segment[j - 1]);
        const decreasing = segment.every((v, j) => j === 0 || v < segment[j - 1]);
        if (increasing || decreasing) {
          const opIdx = Math.floor(i / parts.length);
          testResults.test3.push({ operator: operators[opIdx], startPoint: i + 1 });
          break;
        }
      }
      
      // Test 4: 2 out of 3 consecutive points > 2σ from center (same side)
      for (let i = 0; i <= avgData.length - 3; i++) {
