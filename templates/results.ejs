            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.reproducibility.studyVar.toFixed(3) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Reproducibility Study Variation</div>
                  <div class="tooltip-formula">SV(AV) = 6 × σ(AV)</div>
                  <div class="tooltip-description">
                    Yeniden üretilebilirlik çalışma varyasyonu.
                  </div>
                </div>
              <% } %>
            </td>
            <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
              <%= results.gaugeEvaluation.reproducibility.pctStudyVar.toFixed(2) %>
              <% if (analysisOptions.show_tooltips !== false) { %>
                <div class="tooltip">
                  <div class="tooltip-title">Reproducibility % Study Var</div>
                  <div class="tooltip-formula">% = (SV(AV) / SV(Total)) × 100</div>
                  <div class="tooltip-description">
                    Yeniden üretilebilirliğin toplam varyasyona yüzdesi.
                  </div>
                </div>
              <% } %>
            </td>
            <% if (results.gaugeEvaluation.toleranceWidth && results.gaugeEvaluation.reproducibility.pctTolerance !== null) { %>
              <td class="<%= analysisOptions.show_tooltips !== false ? 'tooltip-cell' : '' %>">
