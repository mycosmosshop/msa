            <h4>🚨 ACİL Düzeltici Faaliyetler:</h4>
            <ul>
              <% if (results.gaugeEvaluation.repeatability.pctContribution > 50) { %>
              <li><strong>KRİTİK: Repeatability çok yüksek (%<%= results.gaugeEvaluation.repeatability.pctContribution.toFixed(1) %>):</strong>
