<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>POD - <%= study.study_name %></title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
  :root{ --p:#667eea; --p2:#764ba2; --bg:#f5f7fb; --card:#fff; --ink:#232a35; --muted:#6b7280;
         --line:#e6e9f2; --good:#1e7e4a; --gbg:#eaf6ef; --shadow:0 2px 10px rgba(30,40,70,.07); }
  *{box-sizing:border-box} body{margin:0;background:var(--bg);color:var(--ink);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px}
  .wrap{max-width:960px;margin:0 auto;padding:18px}
  .hdr{background:linear-gradient(135deg,var(--p),var(--p2));color:#fff;border-radius:14px;padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;box-shadow:var(--shadow)}
  .hdr h1{margin:0;font-size:20px;font-weight:700} .hdr .sub{opacity:.9;font-size:12.5px;margin-top:3px}
  .badge{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:999px;font-weight:700;font-size:13px;background:var(--gbg);color:var(--good)}
  .acts{display:flex;gap:8px;flex-wrap:wrap;margin:14px 0}
  .btn{border:0;border-radius:9px;padding:9px 15px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:7px}
  .btn.primary{background:linear-gradient(135deg,var(--p),var(--p2));color:#fff} .btn.ghost{background:#eef1f8;color:#41506b}
  .card{background:var(--card);border-radius:13px;box-shadow:var(--shadow);padding:18px 20px;margin:14px 0}
  .card h2{margin:0 0 3px;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px} .card h2 .i{color:var(--p)}
  .exp{background:#f8f9fd;border-left:3px solid var(--p);border-radius:0 8px 8px 0;padding:10px 13px;font-size:12.8px;color:#4a5568;margin:10px 0 4px;line-height:1.55}
  table{width:100%;border-collapse:collapse;margin-top:8px;font-size:13px}
  th,td{padding:8px 10px;text-align:center;border-bottom:1px solid var(--line)}
  th{background:#f3f5fb;font-weight:600;color:#39415a;font-size:12px} td:first-child,th:first-child{text-align:left}
  .num{font-variant-numeric:tabular-nums}
  .info{grid-template-columns:repeat(auto-fit,minmax(130px,1fr));display:grid;gap:10px;margin-top:6px}
  .info .kv{background:#f8f9fd;border-radius:9px;padding:10px 12px}
  .info .kv b{display:block;color:var(--muted);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.3px}
  .info .kv span{font-size:16px;font-weight:700}
  .eq{background:#eef1f8;border-radius:9px;padding:10px 14px;font-size:14px;font-weight:700;text-align:center;color:#3a4a7a;margin-top:8px}
  .chartbox{position:relative;height:420px}
  .optlbl{display:inline-flex;align-items:center;gap:7px;font-size:13px;color:#41506b;font-weight:600;cursor:pointer}
  .optlbl input[type=checkbox],.optlbl input[type=radio]{width:16px;height:16px;cursor:pointer}
  .foot{color:var(--muted);font-size:11.5px;text-align:center;margin:18px 0 8px}
  @media print{.acts{display:none}body{background:#fff}.card{box-shadow:none;border:1px solid var(--line)}}
</style>
</head>
<body>
<div class="wrap">
  <% var si=results.studyInfo; var P=results.parameters; var F=results.fit; var pod=results.pod;
     function fn(x,d){ return x==null?'—':Number(x).toFixed(d==null?3:d); }
     function fp(p){ return p==null?'—':(p<0.001?'< .001':p.toFixed(3)); } %>
  <div class="hdr">
    <div><h1><i class="bi bi-search"></i> Tespit Olasılığı (POD)</h1>
      <div class="sub"><%= study.study_name %><%= study.gauge_name ? ' · '+study.gauge_name : '' %></div></div>
    <span class="badge"><i class="bi bi-bullseye"></i> a₉₀ = <%= fn(pod.a90,2) %></span>
  </div>

  <div class="acts">
    <a class="btn primary" href="#" onclick="window.print();return false"><i class="bi bi-printer"></i> PDF / Yazdır</a>
    <a class="btn ghost" href="pod-data-entry.html?id=<%= study.id %>"><i class="bi bi-pencil"></i> Veriyi Düzenle</a>
    <a class="btn ghost" href="index.html"><i class="bi bi-arrow-left"></i> Panoya Dön</a>
  </div>

  <div class="card">
    <h2><i class="bi bi-sliders i"></i> Analiz Seçenekleri</h2>
    <div class="exp">JASP <i>Analysis options</i> karşılığı. Bağ fonksiyonu / dönüşüm seçince model yeniden kurulur (<b>Uygula</b>). Grafik öğelerini aç/kapatın.</div>
    <% var inp = results._inputs || {link:'logit',logcov:false,ci:95}; %>
    <div style="display:flex;gap:18px;flex-wrap:wrap;align-items:center;margin:8px 0 4px">
      <span style="font-size:12.5px;font-weight:700;color:#39415a">Bağ (link):</span>
      <label class="optlbl"><input type="radio" name="link" value="logit" <%= inp.link!=='probit'?'checked':'' %>> Logit</label>
      <label class="optlbl"><input type="radio" name="link" value="probit" <%= inp.link==='probit'?'checked':'' %>> Probit</label>
      <label class="optlbl" style="margin-left:10px"><input type="checkbox" id="inLog" <%= inp.logcov?'checked':'' %>> Kovaryatı log-dönüştür</label>
      <label class="optlbl">Güven %<input type="number" id="inCi" value="<%= inp.ci %>" min="50" max="99.9" step="1" style="width:64px;padding:5px 7px;border:1px solid var(--line);border-radius:7px"></label>
      <button class="btn primary" onclick="applyInputs()"><i class="bi bi-arrow-repeat"></i> Uygula</button>
    </div>
    <div style="border-top:1px solid var(--line);margin-top:12px;padding-top:12px;display:flex;flex-wrap:wrap;gap:12px 20px">
      <label class="optlbl"><input type="checkbox" checked onchange="tgl('secFit',this)"> Model uyum tablosu</label>
      <label class="optlbl"><input id="cbDens" type="checkbox" checked onchange="toggleDensity(this)"> Yoğunluk göster (hit/miss)</label>
      <label class="optlbl"><input id="cbBand" type="checkbox" onchange="toggleBand(this)"> Güven aralığı (%<%= inp.ci %>)</label>
      <label class="optlbl"><input id="cbRug" type="checkbox" checked onchange="toggleRug(this)"> Veriyi göster (rug)</label>
      <label class="optlbl"><input id="cbObs" type="checkbox" checked onchange="toggleObs(this)"> Gözlenen oranlar</label>
      <label class="optlbl"><input id="cbLogX" type="checkbox" onchange="toggleLogX(this)"> Logaritmik x-ekseni</label>
    </div>
  </div>

  <div class="card">
    <h2><i class="bi bi-info-circle i"></i> Özet</h2>
    <div class="info">
      <div class="kv"><b>a₅₀ (%50 POD)</b><span><%= fn(pod.a50,2) %></span></div>
      <div class="kv"><b>a₉₀ (%90 POD)</b><span><%= fn(pod.a90,2) %></span></div>
      <div class="kv"><b>a₉₅ (%95 POD)</b><span><%= fn(pod.a95,2) %></span></div>
      <div class="kv"><b>AIC</b><span><%= fn(F.AIC,2) %></span></div>
      <div class="kv"><b>Gözlem</b><span><%= si.n %></span></div>
    </div>
    <div class="exp"><b>Tespit Olasılığı (POD)</b>, bir kusurun/özelliğin <b>boyutu büyüdükçe</b> tespit edilme olasılığının nasıl arttığını lojistik regresyonla modeller.
      <b>a₉₀</b>, %90 tespit olasılığına karşılık gelen boyuttur — muayene sisteminin güvenilir biçimde yakalayabildiği en küçük kusur boyutu olarak yorumlanır. Küçük a₉₀ = daha hassas tespit.</div>
  </div>

  <div class="card">
    <h2><i class="bi bi-sliders i"></i> Model Parametreleri (Lojistik)</h2>
    <table>
      <thead><tr><th>Terim</th><th>Tahmin</th><th>Std. Hata</th><th>z</th><th>p</th></tr></thead>
      <tbody>
        <tr><td>Sabit (Intercept)</td><td class="num"><%= fn(P.intercept.estimate) %></td><td class="num"><%= fn(P.intercept.se) %></td><td class="num"><%= fn(P.intercept.z,2) %></td><td class="num"><%= fp(P.intercept.p) %></td></tr>
        <tr><td>Boyut (Size)</td><td class="num"><%= fn(P.slope.estimate) %></td><td class="num"><%= fn(P.slope.se) %></td><td class="num"><%= fn(P.slope.z,2) %></td><td class="num"><%= fp(P.slope.p) %></td></tr>
      </tbody>
    </table>
    <div class="eq"><%= results.equation %></div>
  </div>

  <div class="card" id="secFit">
    <h2><i class="bi bi-clipboard-data i"></i> Model Uyumu</h2>
    <table>
      <thead><tr><th>AIC</th><th>BIC</th><th>Sapma (Deviance)</th><th>Log-olabilirlik</th></tr></thead>
      <tbody><tr><td class="num"><%= fn(F.AIC,2) %></td><td class="num"><%= fn(F.BIC,2) %></td><td class="num"><%= fn(F.deviance,2) %></td><td class="num"><%= fn(F.logLik,3) %></td></tr></tbody>
    </table>
  </div>

  <div class="card">
    <h2><i class="bi bi-graph-up-arrow i"></i> Tespit Grafiği (Detection Plot)</h2>
    <div class="exp">Siyah eğri = POD modeli (1 tespit etme olasılığı). <b>Üstteki/alttaki gri eğriler = yoğunluk</b>: üstte tespit edilen (hit), altta kaçırılan (miss) gözlemlerin boyut dağılımı — hit'ler büyük boyutta, miss'ler küçük boyutta yoğunlaşır. Üst/alt kısa çizgiler (rug) = ham gözlemler. Kesikli çizgiler a₅₀/a₉₀ boyutları. (İsterseniz seçeneklerden <b>%<%= (results.studyInfo.ciLevel*100).toFixed(0) %> güven aralığı</b> bandını açabilirsiniz.)</div>
    <div class="chartbox"><canvas id="chartPod"></canvas></div>
  </div>

  <div class="foot">GageAI · Tespit Olasılığı (POD) — <%= results.studyInfo.link==='probit'?'probit':'lojistik' %> regresyon / JASP metodolojisi ile doğrulanmıştır.</div>
</div>

<script>
var POD_CH=null;
function tgl(id,cb){ var el=document.getElementById(id); if(el) el.style.display=cb.checked?'':'none'; }
function setDs(label,hidden){ if(!POD_CH)return; var d=POD_CH.data.datasets.find(function(x){return x._role===label;}); if(d){ d.hidden=hidden; POD_CH.update(); } }
function toggleBand(cb){ if(!POD_CH)return; POD_CH.data.datasets.forEach(function(d){ if(d._role==='bandLo'||d._role==='bandHi') d.hidden=!cb.checked; }); POD_CH.update(); }
function toggleDensity(cb){ if(!POD_CH)return; POD_CH.data.datasets.forEach(function(d){ if(d._role==='densHit'||d._role==='densMiss') d.hidden=!cb.checked; }); POD_CH.update(); }
function toggleRug(cb){ if(window.__setRug) window.__setRug(cb.checked); }
function toggleObs(cb){ setDs('obs',!cb.checked); }
function toggleLogX(cb){ if(!POD_CH)return; POD_CH.options.scales.x.type = cb.checked?'logarithmic':'linear'; POD_CH.update(); }
function applyInputs(){
  var link=(document.querySelector('input[name="link"]:checked')||{}).value||'logit';
  var log=document.getElementById('inLog').checked, ci=document.getElementById('inCi').value;
  var u=new URL(location.href); u.searchParams.set('id','<%= study.id %>');
  u.searchParams.set('link',link); if(log) u.searchParams.set('logcov','1'); else u.searchParams.delete('logcov');
  if(ci!=='') u.searchParams.set('ci',ci); else u.searchParams.delete('ci');
  location.href=u.toString();
}
(function(){
  var R = <%- JSON.stringify(results) %>;
  var g=R.graph; var pod=R.pod;
  var el=document.getElementById('chartPod'); if(!el) return;
  var showRug=true;
  var refPlugin={ id:'refs', afterDatasetsDraw:function(c){ try{ var ctx=c.ctx, x=c.scales.x, y=c.scales.y; if(!x||!y)return;
    // a50/a90 dikey referanslar
    function vline(val,col,lbl){ if(val==null||!isFinite(val))return; var px=x.getPixelForValue(val); if(px<x.left||px>x.right)return;
      ctx.save(); ctx.strokeStyle=col; ctx.setLineDash([5,4]); ctx.lineWidth=1.1; ctx.globalAlpha=0.75; ctx.beginPath(); ctx.moveTo(px,y.top); ctx.lineTo(px,y.bottom); ctx.stroke();
      ctx.setLineDash([]); ctx.globalAlpha=1; ctx.fillStyle=col; ctx.font='11px Segoe UI'; ctx.fillText(lbl,px+3,y.top+12); ctx.restore(); }
    vline(pod.a50,'#b7791f','a50'); vline(pod.a90,'#c0392b','a90');
    // Rug: hit → üst, miss → alt kısa çizgiler (JASP tarzı)
    if(showRug){ ctx.save(); ctx.strokeStyle='#555'; ctx.lineWidth=1; var yTop=y.getPixelForValue(1.0), yBot=y.getPixelForValue(0.0);
      g.rug.forEach(function(r){ var px=x.getPixelForValue(r.x); if(px<x.left||px>x.right)return; ctx.beginPath();
        if(r.y>=0.5){ ctx.moveTo(px,y.top); ctx.lineTo(px,y.top+9); } else { ctx.moveTo(px,y.bottom); ctx.lineTo(px,y.bottom-9); } ctx.stroke(); }); ctx.restore(); }
  }catch(e){} }};
  window.__setRug=function(v){ showRug=v; POD_CH.update(); };
  var xmin=g.curve[0].x, xmax=g.curve[g.curve.length-1].x;
  var AMP=0.12;
  POD_CH=new Chart(el,{
    data:{ datasets:[
      { type:'line', _role:'bandLo', label:'CI alt', hidden:true, data:g.curve.map(function(p){return {x:p.x,y:p.yLo};}), borderColor:'#9aa0ac', borderWidth:1, pointRadius:0, tension:0.3, fill:false },
      { type:'line', _role:'bandHi', label:'CI üst', hidden:true, data:g.curve.map(function(p){return {x:p.x,y:p.yHi};}), borderColor:'#9aa0ac', backgroundColor:'rgba(150,155,170,.10)', borderWidth:1, pointRadius:0, tension:0.3, fill:'-1' },
      { type:'line', _role:'densHit', label:'Yoğunluk (hit)', data:g.curve.map(function(p){return {x:p.x,y:1.0+AMP*(p.dHit||0)};}), borderColor:'#9aa0ac', borderWidth:1.2, pointRadius:0, tension:0.35, fill:false },
      { type:'line', _role:'densMiss', label:'Yoğunluk (miss)', data:g.curve.map(function(p){return {x:p.x,y:0.0-AMP*(p.dMiss||0)};}), borderColor:'#9aa0ac', borderWidth:1.2, pointRadius:0, tension:0.35, fill:false },
      { type:'line', _role:'curve', label:'POD eğrisi', data:g.curve.map(function(p){return {x:p.x,y:p.y};}), borderColor:'#111', borderWidth:2.2, pointRadius:0, tension:0.3, fill:false },
      { type:'scatter', _role:'obs', label:'Gözlenen oran', data:g.observed, backgroundColor:'rgba(90,90,90,.55)', pointRadius:4, pointHoverRadius:7 }
    ]},
    options:{ responsive:true, maintainAspectRatio:false,
      scales:{ x:{ type:'linear', min:xmin, max:xmax, title:{display:true,text:'Boyut'}, grid:{display:false} },
               y:{ min:-0.16, max:1.18, title:{display:true,text:'1 tespit etme olasılığı'}, grid:{color:'#f0f2f7'}, ticks:{stepSize:0.2} } },
      plugins:{ legend:{ labels:{usePointStyle:true, boxWidth:8, filter:function(it){ return ['POD eğrisi','Gözlenen oran'].indexOf(it.text)!==-1; } } },
        tooltip:{ callbacks:{ label:function(c){ return c.dataset._role==='obs' ? ('Boyut '+c.parsed.x+': '+(g.observed[c.dataIndex]?g.observed[c.dataIndex].hits+'/'+g.observed[c.dataIndex].n:'')+' (%'+(c.parsed.y*100).toFixed(0)+')') : (c.dataset.label+': %'+(c.parsed.y*100).toFixed(1)); } } } },
    },
    plugins:[refPlugin]
  });
  if(typeof requestAnimationFrame==='function') requestAnimationFrame(function(){ try{ POD_CH.resize(); }catch(e){} });
})();
</script>
</body>
</html>
