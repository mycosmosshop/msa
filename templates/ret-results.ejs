<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Test-Retest - <%= study.study_name %></title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
  :root{ --p:#667eea; --p2:#764ba2; --bg:#f5f7fb; --card:#fff; --ink:#232a35; --muted:#6b7280;
         --line:#e6e9f2; --good:#1e7e4a; --gbg:#eaf6ef; --mar:#b7791f; --mbg:#fdf6e6; --bad:#c0392b; --bbg:#fdecea; --shadow:0 2px 10px rgba(30,40,70,.07); }
  *{box-sizing:border-box} body{margin:0;background:var(--bg);color:var(--ink);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px}
  .wrap{max-width:960px;margin:0 auto;padding:18px}
  .hdr{background:linear-gradient(135deg,var(--p),var(--p2));color:#fff;border-radius:14px;padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;box-shadow:var(--shadow)}
  .hdr h1{margin:0;font-size:20px;font-weight:700} .hdr .sub{opacity:.9;font-size:12.5px;margin-top:3px}
  .badge{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:999px;font-weight:700;font-size:13px}
  .badge.good{background:var(--gbg);color:var(--good)} .badge.marginal{background:var(--mbg);color:var(--mar)} .badge.bad{background:var(--bbg);color:var(--bad)} .badge.neutral{background:#eef1f8;color:var(--muted)}
  .acts{display:flex;gap:8px;flex-wrap:wrap;margin:14px 0}
  .btn{border:0;border-radius:9px;padding:9px 15px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:7px}
  .btn.primary{background:linear-gradient(135deg,var(--p),var(--p2));color:#fff} .btn.ghost{background:#eef1f8;color:#41506b}
  .card{background:var(--card);border-radius:13px;box-shadow:var(--shadow);padding:18px 20px;margin:14px 0}
  .card h2{margin:0 0 3px;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px} .card h2 .i{color:var(--p)}
  .exp{background:#f8f9fd;border-left:3px solid var(--p);border-radius:0 8px 8px 0;padding:10px 13px;font-size:12.8px;color:#4a5568;margin:10px 0 4px;line-height:1.55}
  table{width:100%;border-collapse:collapse;margin-top:8px;font-size:13px}
  th,td{padding:8px 10px;text-align:center;border-bottom:1px solid var(--line)}
  th{background:#f3f5fb;font-weight:600;color:#39415a;font-size:12px;white-space:nowrap}
  .num{font-variant-numeric:tabular-nums}
  .info{grid-template-columns:repeat(auto-fit,minmax(130px,1fr));display:grid;gap:10px;margin-top:6px}
  .info .kv{background:#f8f9fd;border-radius:9px;padding:10px 12px}
  .info .kv b{display:block;color:var(--muted);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.3px}
  .info .kv span{font-size:16px;font-weight:700}
  .chartbox{position:relative;height:360px}
  .foot{color:var(--muted);font-size:11.5px;text-align:center;margin:18px 0 8px}
  @media print{.acts{display:none}body{background:#fff}.card{box-shadow:none;border:1px solid var(--line)}}
</style>
</head>
<body>
<div class="wrap">
  <% var it=results.interpretation; var s=results.shortGauge; %>
  <div class="hdr">
    <div><h1><i class="bi bi-arrow-left-right"></i> Test-Retest (Menzil Yöntemi)</h1>
      <div class="sub"><%= study.study_name %><%= study.gauge_name ? ' · '+study.gauge_name : '' %></div></div>
    <span class="badge <%= it.acceptabilityClass %>">
      <% if(it.decisivePct!=null){ %><i class="bi bi-<%= it.acceptabilityClass==='good'?'check-circle-fill':(it.acceptabilityClass==='marginal'?'exclamation-triangle-fill':'x-circle-fill') %>"></i> %GRR: <%= it.acceptability %>
      <% } else { %><i class="bi bi-info-circle-fill"></i> Ölçüm Hatası Tahmini<% } %>
    </span>
  </div>

  <div class="acts">
    <a class="btn primary" href="#" onclick="window.print();return false"><i class="bi bi-printer"></i> PDF / Yazdır</a>
    <a class="btn ghost" href="ret-data-entry.html?id=<%= study.id %>"><i class="bi bi-pencil"></i> Veriyi Düzenle</a>
    <a class="btn ghost" href="index.html"><i class="bi bi-arrow-left"></i> Panoya Dön</a>
  </div>

  <div class="card">
    <h2><i class="bi bi-speedometer i"></i> Kısa Mastar Çalışması (Short Gauge Study)</h2>
    <div class="exp">Bu hızlı yöntem, her parçanın <b>iki tekrarı arasındaki menzil</b>i kullanarak ölçüm cihazının <b>tekrarlanabilirlik hatasını (GRR)</b> tahmin eder.
      <b>GRR = R̄ / d₂*</b>, burada R̄ ortalama menzil, d₂* alt grup boyutu ve parça sayısına göre düzeltilmiş sabittir.</div>
    <table>
      <thead><tr><th>Örneklem (parça)</th><th>Ortalama Menzil (R̄)</th><th>d₂*</th><th>GRR (σ)</th><th>Çalışma Var. (6σ)</th><% if(s.pctTolerance!=null){ %><th>%GRR (Tolerans)</th><% } %><% if(s.pctProcess!=null){ %><th>%GRR (Proses)</th><% } %></tr></thead>
      <tbody>
        <tr><td class="num"><%= s.sampleSize %></td><td class="num"><%= s.rBar.toFixed(4) %></td><td class="num"><%= s.d2.toFixed(3) %></td>
          <td class="num" style="font-weight:700"><%= s.grr.toFixed(4) %></td><td class="num"><%= s.studyVar.toFixed(4) %></td>
          <% if(s.pctTolerance!=null){ %><td class="num"><%= s.pctTolerance.toFixed(2) %>%</td><% } %>
          <% if(s.pctProcess!=null){ %><td class="num"><%= s.pctProcess.toFixed(2) %>%</td><% } %></tr>
      </tbody>
    </table>
    <% if(it.decisivePct!=null){ %>
    <div class="exp" style="border-left-color:#9aa4bf">%GRR &lt; %10 kabul edilebilir, %10–30 marjinal, &gt;%30 kabul edilemez (AIAG). Bu çalışma: <b><%= it.acceptability %></b>.</div>
    <% } else { %>
    <div class="exp" style="border-left-color:#9aa4bf">Tolerans veya proses standart sapması girilmediği için yalnızca ölçüm hatası (GRR = <b><%= s.grr.toFixed(4) %></b>) tahmin edildi. %GRR için çalışma ayarlarına tolerans girin.</div>
    <% } %>
  </div>

  <div class="card">
    <h2><i class="bi bi-graph-up-arrow i"></i> 1. Ölçüm – 2. Ölçüm Grafiği</h2>
    <div class="exp">Her nokta bir parçanın iki ölçümünü gösterir. Noktalar <b>45° kesikli çizgiye</b> (kusursuz tekrar) ne kadar yakınsa cihaz o kadar tutarlıdır. Mavi çizgi gerçek eğilim (fit). Dağılım genişse tekrarlanabilirlik zayıftır.</div>
    <div class="chartbox"><canvas id="chartScatter"></canvas></div>
  </div>

  <div class="foot">GageAI · Test-Retest (Menzil Yöntemi) — AIAG MSA 4. Baskı / JASP metodolojisi ile doğrulanmıştır.</div>
</div>

<script>
(function(){
  var R = <%- JSON.stringify(results) %>;
  var g = R.graph;
  var el=document.getElementById('chartScatter');
  if(el){
    var ds=[
      { type:'line', label:'45° (kusursuz)', data:g.diag, borderColor:'#999', borderDash:[6,5], pointRadius:0, borderWidth:1.5, tension:0 },
      { type:'scatter', label:'Parçalar', data:g.scatter, backgroundColor:'#667eea', pointRadius:6, pointHoverRadius:8 }
    ];
    if(g.fit) ds.splice(1,0,{ type:'line', label:'Eğilim (fit)', data:g.fit, borderColor:'#2563eb', pointRadius:0, borderWidth:2.5, tension:0 });
    new Chart(el,{ data:{ datasets:ds },
      options:{ responsive:true, maintainAspectRatio:false,
        scales:{ x:{ title:{display:true,text:'1. Ölçüm'} }, y:{ title:{display:true,text:'2. Ölçüm'} } },
        plugins:{ legend:{ labels:{usePointStyle:true, boxWidth:8} },
          tooltip:{ callbacks:{ label:function(c){ return c.dataset.label==='Parçalar' ? ('Parça '+(g.scatter[c.dataIndex]?g.scatter[c.dataIndex].part:'')+': ('+c.parsed.x.toFixed(3)+', '+c.parsed.y.toFixed(3)+')') : (c.dataset.label); } } } }
      }
    });
  }
})();
</script>
</body>
</html>
