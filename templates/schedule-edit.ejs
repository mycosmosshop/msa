<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MSA Planı Düzenle - <%= branding.company_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  <style>
    :root {
      --primary-color: <%= branding.primary_color %>;
      --secondary-color: <%= branding.secondary_color %>;
    }

    body {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      min-height: 100vh;
      padding: 30px 0;
    }

    .card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }

    .card-header {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      color: white;
      border-radius: 15px 15px 0 0 !important;
      padding: 20px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .form-label {
      font-weight: 600;
      color: #555;
      margin-bottom: 8px;
    }

    .form-control, .form-select {
      border-radius: 8px;
      border: 2px solid #e0e0e0;
      padding: 10px 15px;
    }

    .form-control:focus, .form-select:focus {
      border-color: var(--primary-color);
      box-shadow: 0 0 0 0.2rem rgba(111, 66, 193, 0.25);
    }

    .btn-primary {
      background: var(--primary-color);
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-weight: 600;
    }

    .btn-primary:hover {
      background: var(--secondary-color);
    }

    .section-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
  </style>
</head>
<body>
  <div class="container" style="max-width: 900px;">
    <div class="card">
      <div class="card-header">
        <div>
          <h3 style="margin: 0;">
            <i class="bi bi-pencil-square"></i>
            MSA Planı Düzenle
          </h3>
          <p style="margin: 10px 0 0 0; opacity: 0.9;">
            Planlama bilgilerini güncelleyin
          </p>
        </div>
        <a href="index.html?view=studies" class="btn btn-secondary" style="margin-left: auto;">
          <i class="bi bi-arrow-left"></i> Çalışmalara Dön
        </a>
      </div>

      <div class="card-body">
        <form id="scheduleForm">
          <!-- Title -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-pencil"></i> Çalışma Başlığı *
            </label>
            <input type="text" class="form-control" name="title"
                   value="<%= schedule.title %>"
                   placeholder="Örn: Motor Yatağı İç Çap - 6 Aylık Kontrol MSA" required>
            <small class="text-muted">MSA çalışmasını tanımlayan açıklayıcı bir başlık girin</small>
          </div>

          <!-- Description -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-text-paragraph"></i> Açıklama
            </label>
            <textarea class="form-control" name="description" rows="3"
                      placeholder="Bu MSA çalışmasının amacını ve kapsamını açıklayın..."><%= schedule.description || '' %></textarea>
          </div>

          <!-- Dates -->
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-calendar-event"></i> Planlanan Tarih *
              </label>
              <input type="date" class="form-control" name="planned_date"
                     value="<%= schedule.planned_date ? new Date(schedule.planned_date).toISOString().split('T')[0] : '' %>" required>
              <small class="text-muted">MSA çalışmasının yapılacağı tarih</small>
            </div>
            <div class="col-md-3">
              <label class="form-label">
                <i class="bi bi-clock"></i> Hatırlatma Saati
              </label>
              <input type="time" class="form-control" name="reminder_time"
                     value="<%= schedule.reminder_time || '09:00' %>">
              <small class="text-muted">Saat (varsayılan: 09:00)</small>
            </div>
            <div class="col-md-3">
              <label class="form-label">
                <i class="bi bi-calendar-week"></i> Kaç Gün Önce
              </label>
              <input type="number" class="form-control" name="reminder_days_before"
                     value="<%= schedule.reminder_days_before || 7 %>" min="1" max="90">
              <small class="text-muted">Gün (varsayılan: 7)</small>
            </div>
          </div>

          <!-- Responsible -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-person-check"></i> Sorumlu Kişi
            </label>
            <select class="form-select" name="responsible_user_id">
              <option value="">Seçilmedi</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>" <%= schedule.responsible_email === u.id ? 'selected' : '' %>>
                  <%= u.name || u.email %>
                </option>
              <% }); %>
            </select>
            <small class="text-muted">MSA çalışmasını yapacak kişi</small>
          </div>

          <!-- Status -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-info-circle"></i> Durum
            </label>
            <select class="form-select" name="status">
              <option value="planned" <%= schedule.status === 'planned' ? 'selected' : '' %>>📅 Planlanan</option>
              <option value="in_progress" <%= schedule.status === 'in_progress' ? 'selected' : '' %>>⏳ Devam Ediyor</option>
              <option value="completed" <%= schedule.status === 'completed' ? 'selected' : '' %>>✅ Tamamlandı</option>
              <option value="cancelled" <%= schedule.status === 'cancelled' ? 'selected' : '' %>>❌ İptal</option>
            </select>
            <small class="text-muted">Planlamanın mevcut durumu</small>
          </div>

          <!-- MSA Details -->
          <div class="section-title">
            <i class="bi bi-clipboard-data"></i> MSA Detayları (Opsiyonel)
          </div>
          <p class="text-muted" style="margin-top: -10px; margin-bottom: 15px; font-size: 14px;">
            Bu bilgileri şimdi doldurabilir veya daha sonra MSA çalışması oluştururken girebilirsiniz.
          </p>

          <!-- Equipment Selection -->
          <% if (equipment && equipment.length > 0) { %>
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-tools"></i> Ölçüm Ekipmanı
            </label>
            <select class="form-select" id="equipment_select" onchange="fillEquipmentDetails()">
              <option value="">Manuel Gir</option>
              <% equipment.forEach(eq => { %>
                <option value="<%= eq.id %>"
                        data-name="<%= eq.name %>"
                        data-serial="<%= eq.serial_number %>"
                        data-device="<%= eq.device_number %>">
                  <%= eq.name %> (Seri: <%= eq.serial_number %>, Cihaz: <%= eq.device_number %>)
                </option>
              <% }); %>
            </select>
            <small class="text-muted">Listeden seçin veya manuel girin</small>
          </div>
          <% } %>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Ölçüm Cihazı Adı</label>
              <input type="text" class="form-control" id="gauge_name" name="gauge_name"
                     value="<%= schedule.gauge_name || '' %>"
                     placeholder="Örn: Dijital Mikrometre">
            </div>
            <div class="col-md-6">
              <label class="form-label">Cihaz Seri No</label>
              <input type="text" class="form-control" id="gauge_number" name="gauge_number"
                     value="<%= schedule.gauge_number || '' %>"
                     placeholder="Örn: MIT-2024-001">
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Parça Adı</label>
              <input type="text" class="form-control" name="part_name"
                     value="<%= schedule.part_name || '' %>"
                     placeholder="Örn: Motor Yatağı Burcu">
            </div>
            <div class="col-md-6">
              <label class="form-label">Ölçülen Özellik</label>
              <input type="text" class="form-control" name="characteristic"
                     value="<%= schedule.characteristic || '' %>"
                     placeholder="Örn: İç Çap">
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Tolerans</label>
              <input type="text" class="form-control" name="tolerance"
                     value="<%= schedule.tolerance || '' %>"
                     placeholder="Örn: ±0.05 veya 10.00 - 10.10">
            </div>
            <div class="col-md-6">
              <label class="form-label">Konum/Lokasyon</label>
              <input type="text" class="form-control" name="location"
                     value="<%= schedule.location || '' %>"
                     placeholder="Örn: Üretim Hattı 3">
            </div>
          </div>

          <!-- Notes -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-sticky"></i> Notlar
            </label>
            <textarea class="form-control" name="notes" rows="2"
                      placeholder="Ek notlar, özel talimatlar..."><%= schedule.notes || '' %></textarea>
          </div>

          <!-- Actions -->
          <div class="d-flex gap-2 justify-content-end">
            <a href="schedule-master.html" class="btn btn-secondary">
              <i class="bi bi-x-circle"></i> İptal
            </a>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-circle"></i> Güncelle
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Equipment selection auto-fill
    function fillEquipmentDetails() {
      const select = document.getElementById('equipment_select');
      const selectedOption = select.options[select.selectedIndex];

      if (selectedOption.value) {
        // Fill equipment details from selected option
        document.getElementById('gauge_name').value = selectedOption.dataset.name || '';
        document.getElementById('gauge_number').value = selectedOption.dataset.serial || '';
      } else {
        // Clear fields if "Manuel Gir" selected
        document.getElementById('gauge_name').value = '';
        document.getElementById('gauge_number').value = '';
      }
    }

    // Form submission
    document.getElementById('scheduleForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());

      try {
        const result = await MSA_SCHEDULE_API.update(<%= schedule.id %>, data);

        if (result.success) {
          alert('✅ Planlama başarıyla güncellendi!');
          window.location.href = 'schedule-master.html';
        } else {
          alert('❌ Hata: ' + result.error);
        }
      } catch (error) {
        alert('❌ Bağlantı hatası: ' + error.message);
      }
    });
  </script>
</body>
</html>
