<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tüm Döfler - <%= branding?.company_name || 'MSA System' %></title>
  
  <!-- Bootstrap Icons -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  
  <!-- Dark Mode CSS -->
  <link rel="stylesheet" href="css/dark-mode.css">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: var(--bg-secondary);
      min-height: 100vh;
    }

    .navbar {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 20px rgba(0,0,0,0.1);
    }

    .navbar h1 {
      font-size: 24px;
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .container {
      max-width: 1400px;
      margin: 30px auto;
      padding: 0 20px;
    }

    .section {
      background: var(--card-bg);
      border-radius: 16px;
      padding: 30px;
      box-shadow: var(--shadow);
    }

    .btn {
      padding: 10px 20px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 500;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.3s ease;
    }

    .btn-secondary {
      background: rgba(255,255,255,0.2);
      color: white;
    }

    .btn-secondary:hover {
      background: rgba(255,255,255,0.3);
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 20px;
    }

    th {
      background: var(--bg-hover);
      color: var(--text-primary);
      padding: 12px;
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid var(--border-color);
    }

    td {
      padding: 12px;
      border-bottom: 1px solid var(--border-color);
      color: var(--text-primary);
    }

    tr:hover {
      background: var(--bg-hover);
    }

    .status-badge {
      padding: 4px 12px;
      border-radius: 12px;
      font-size: 12px;
      font-weight: 600;
      display: inline-block;
    }

    .status-marginal {
      background: #fef3c7;
      color: #92400e;
    }

    .status-unacceptable {
      background: #fee2e2;
      color: #991b1b;
    }

    .type-badge {
      padding: 4px 8px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      display: inline-block;
    }

    .type-type1 {
      background: #dbeafe;
      color: #1e40af;
    }

    .type-type2 {
      background: #fef3c7;
      color: #92400e;
    }

    .type-type3 {
      background: #f3e8ff;
      color: #6b21a8;
    }

    .metric {
      font-family: 'Courier New', monospace;
      font-weight: 600;
    }

    .metric-good {
      color: #059669;
    }

    .metric-warning {
      color: #d97706;
    }

    .metric-bad {
      color: #dc2626;
    }

    .capa-badge {
      background: #e0e7ff;
      color: #3730a3;
      padding: 2px 8px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 600;
      margin-left: 5px;
    }

    .capa-chip-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .capa-chip {
      background: #e0e7ff;
      color: #22215b;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 600;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .capa-status-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: #6366f1;
      display: inline-block;
    }

    .view-btn {
      background: #667eea;
      color: white;
      padding: 6px 12px;
      border-radius: 6px;
      text-decoration: none;
      font-size: 12px;
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }

    .view-btn:hover {
      background: #5568d3;
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <h1>
      <% if (branding?.logo_url) { %>
        <img src="<%= branding.logo_url %>" alt="Logo" style="height: 40px;">
      <% } %>
      <i class="bi bi-exclamation-triangle"></i>
      Tüm Döfler
    </h1>
    <div>
      <a href="index.html" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i>
        Dashboard'a Dön
      </a>
    </div>
  </nav>

  <div class="container">
    <div class="section">
      <h2 style="margin-bottom: 20px; color: var(--text-primary);">
        <i class="bi bi-exclamation-triangle"></i>
        Kabul Edilemeyen MSA Çalışmaları (Döfler)
        <span style="font-size: 16px; color: var(--text-secondary); font-weight: normal;">
          (<%= studies.length %> döflü çalışma)
        </span>
      </h2>
      
      <% if (studies.length === 0) { %>
        <div style="text-align: center; padding: 40px; color: var(--text-secondary);">
          <i class="bi bi-check-circle" style="font-size: 48px; color: #10b981; margin-bottom: 15px;"></i>
          <h3 style="color: var(--text-primary);">Harika! Hiç Döf Yok</h3>
          <p>Hiç kabul edilemeyen MSA çalışmanız bulunmuyor.</p>
        </div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Çalışma Adı</th>
              <th>Tip</th>
              <th>Durum</th>
              <th>%GRR</th>
              <th>NDC</th>
              <th>Bias</th>
              <th>Cg / Cgk</th>
              <th>CAPA</th>
              <th>Sahip</th>
              <th>Tarih</th>
              <th>İşlem</th>
            </tr>
          </thead>
          <tbody>
            <% studies.forEach(study => { %>
              <tr>
                <!-- Study Name -->
                <td><strong><%= study.study_name %></strong></td>
                
                <!-- Type Badge -->
                <td>
                  <% 
                    let rawType = (study.normalized_type || study.study_type || 'type3').toString().toLowerCase();
                    let studyType = rawType.includes('type1') ? 'type1' : rawType.includes('type2') ? 'type2' : 'type3';
                    let typeLabel = studyType === 'type1' ? 'Type 1' : studyType === 'type2' ? 'Type 2' : 'Type 3';
                    let typeClass = `type-${studyType}`;
                  %>
                  <span class="type-badge <%= typeClass %>"><%= typeLabel %></span>
                </td>
                
                <!-- Status -->
                <td>
                  <span class="status-badge status-unacceptable">Kabul Edilemez</span>
                </td>
                
                <!-- %GRR -->
                <td>
                  <% 
                    const grrValue = study.grr_percent !== undefined && study.grr_percent !== null 
                      ? (typeof study.grr_percent === 'number' ? study.grr_percent : parseFloat(study.grr_percent))
                      : null;
                  %>
                  <% if (grrValue !== null && !isNaN(grrValue)) { %>
                    <% const grrClass = grrValue < 10 ? 'metric-good' : grrValue < 30 ? 'metric-warning' : 'metric-bad'; %>
                    <span class="metric <%= grrClass %>"><%= grrValue.toFixed(2) %>%</span>
                  <% } else { %>
                    <span style="color: var(--text-secondary);">-</span>
                  <% } %>
                </td>
                
                <!-- NDC -->
                <td>
                  <% 
                    const ndcValue = study.ndc !== undefined && study.ndc !== null 
                      ? (typeof study.ndc === 'number' ? study.ndc : parseFloat(study.ndc))
                      : null;
                  %>
                  <% if (ndcValue !== null && !isNaN(ndcValue)) { %>
                    <% const ndcClass = ndcValue >= 5 ? 'metric-good' : ndcValue >= 2 ? 'metric-warning' : 'metric-bad'; %>
                    <span class="metric <%= ndcClass %>"><%= Math.floor(ndcValue) %></span>
                  <% } else { %>
                    <span style="color: var(--text-secondary);">-</span>
                  <% } %>
                </td>
                
                <!-- Bias (Type 1 & 2) -->
                <td>
                  <% if ((studyType === 'type1' || studyType === 'type2') && study.percent_bias != null) { %>
                    <% 
                      let percentBias = typeof study.percent_bias === 'number' ? study.percent_bias : parseFloat(study.percent_bias);
                      let biasClass = Math.abs(percentBias) < 5 ? 'metric-good' : Math.abs(percentBias) < 10 ? 'metric-warning' : 'metric-bad';
                    %>
                    <span class="metric <%= biasClass %>"><%= percentBias.toFixed(2) %>%</span>
                  <% } else { %>
                    <span style="color: var(--text-secondary);">-</span>
                  <% } %>
                </td>
                
                <!-- Cg / Cgk (Type 1 only) -->
                <td>
                  <% if (studyType === 'type1' && study.cg != null && study.cgk != null) { %>
                    <% 
                      let cg = typeof study.cg === 'number' ? study.cg : parseFloat(study.cg);
                      let cgk = typeof study.cgk === 'number' ? study.cgk : parseFloat(study.cgk);
                      let cgClass = cg >= 1.33 ? 'metric-good' : cg >= 1.0 ? 'metric-warning' : 'metric-bad';
                      let cgkClass = cgk >= 1.33 ? 'metric-good' : cgk >= 1.0 ? 'metric-warning' : 'metric-bad';
                    %>
                    <span class="metric <%= cgClass %>"><%= cg.toFixed(2) %></span> / 
                    <span class="metric <%= cgkClass %>"><%= cgk.toFixed(2) %></span>
                  <% } else { %>
                    <span style="color: var(--text-secondary);">-</span>
                  <% } %>
                </td>
                
                <!-- CAPA -->
                <td>
                  <% 
                    let studyCapas = (capaMap && capaMap[study.id]) ? capaMap[study.id] : [];
                  %>
                  <% if (studyCapas.length > 0) { %>
                    <div class="capa-chip-grid">
                      <% studyCapas.forEach(capa => { 
                        const status = (capa.status || 'open').toLowerCase();
                        const label = capa.display_label || capa.capa_number || capa.title || `CAPA-${capa.id}`;
                        const statusColor = status === 'completed' ? '#10b981' : status === 'in_progress' ? '#f59e0b' : status === 'cancelled' ? '#6b7280' : '#ef4444';
                      %>
                        <span class="capa-chip" title="Durum: <%= status %>">
                          <span class="capa-status-dot" style="background: <%= statusColor %>;"></span>
                          <%= label %>
                        </span>
                      <% }); %>
                    </div>
                  <% } else { %>
                    <span style="color: var(--text-secondary);">-</span>
                  <% } %>
                </td>
                
                <!-- Owner -->
                <td><%= study.owner_name || 'Bilinmiyor' %></td>
                
                <!-- Date -->
                <td><%= new Date(study.created_at).toLocaleDateString('tr-TR') %></td>
                
                <!-- Actions -->
                <td>
                  <a href="study-detail.html?id=<%= study.id %>" class="view-btn">
                    <i class="bi bi-eye"></i>
                    Görüntüle
                  </a>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <!-- Theme Switcher -->
  <script src="js/theme-switcher.js"></script>
</body>
</html>
