<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Yeni MSA Planla - <%= branding.company_name %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.7.2/font/bootstrap-icons.css">
  <style>
    :root {
      --primary-color: <%= branding.primary_color %>;
      --secondary-color: <%= branding.secondary_color %>;
    }

    body {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      min-height: 100vh;
      padding: 30px 0;
    }

    .card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }

    .card-header {
      background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
      color: white;
      border-radius: 15px 15px 0 0 !important;
      padding: 20px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .form-label {
      font-weight: 600;
      color: #555;
      margin-bottom: 8px;
    }

    .form-control, .form-select {
      border-radius: 8px;
      border: 2px solid #e0e0e0;
      padding: 10px 15px;
    }

    .form-control:focus, .form-select:focus {
      border-color: var(--primary-color);
      box-shadow: 0 0 0 0.2rem rgba(111, 66, 193, 0.25);
    }

    .btn-primary {
      background: var(--primary-color);
      border: none;
      padding: 12px 30px;
      border-radius: 8px;
      font-weight: 600;
    }

    .btn-primary:hover {
      background: var(--secondary-color);
    }

    .info-box {
      background: #f8f9fa;
      padding: 20px;
      border-radius: 10px;
      margin-bottom: 20px;
      border-left: 4px solid var(--primary-color);
    }

    .section-title {
      font-size: 18px;
      font-weight: 600;
      color: var(--primary-color);
      margin-bottom: 15px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
  </style>
</head>
<body>
  <div class="container" style="max-width: 900px;">
    <div class="card">
      <div class="card-header">
        <div>
          <h3 style="margin: 0;">
            <i class="bi bi-calendar-plus"></i>
            Yeni MSA Planla
          </h3>
          <p style="margin: 10px 0 0 0; opacity: 0.9;">
            DÖF: <%= capa.capa_number %> tamamlandı - Kontrol MSA'sı planlayın
          </p>
        </div>
        <a href="index.html?view=studies" class="btn btn-secondary" style="margin-left: auto;">
          <i class="bi bi-arrow-left"></i> Çalışmalara Dön
        </a>
      </div>

      <div class="card-body">
        <!-- Info -->
        <div class="info-box">
          <strong><i class="bi bi-info-circle"></i> Bilgilendirme:</strong><br>
          DÖF tamamlandıktan sonra iyileştirmelerin etkinliğini doğrulamak için
          yeni bir MSA çalışması planlamanız önerilir. Aşağıdaki bilgileri
          önceki çalışmadan otomatik olarak doldurduk, gerekirse değiştirebilirsiniz.
        </div>

        <form id="scheduleForm">
          <!-- Hidden fields -->
          <input type="hidden" name="capa_id" value="<%= capa.id %>">
          <input type="hidden" name="previous_study_id" value="<%= study.id %>">

          <!-- Title -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-pencil"></i> Çalışma Başlığı *
            </label>
            <input type="text" class="form-control" name="title"
                   value="<%= study.study_name %> - Kontrol MSA" required>
            <small class="text-muted">Örn: Motor Yatağı İç Çap - 3 Aylık Kontrol</small>
          </div>

          <!-- Description -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-text-paragraph"></i> Açıklama
            </label>
            <textarea class="form-control" name="description" rows="3">DÖF <%= capa.capa_number %> kapsamında yapılan iyileştirmelerin etkinliğini doğrulamak için kontrol MSA çalışması.</textarea>
          </div>

          <!-- Dates -->
          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-calendar-event"></i> Planlanan Tarih *
              </label>
              <input type="date" class="form-control" name="planned_date"
                     value="<%= new Date(Date.now() + 90*24*60*60*1000).toISOString().split('T')[0] %>" required>
              <small class="text-muted">Önerilen: 3 ay sonra</small>
            </div>
            <div class="col-md-6">
              <label class="form-label">
                <i class="bi bi-bell"></i> Hatırlatma Tarihi
              </label>
              <input type="date" class="form-control" name="reminder_date"
                     value="<%= new Date(Date.now() + 83*24*60*60*1000).toISOString().split('T')[0] %>">
              <small class="text-muted">7 gün önce hatırlat</small>
            </div>
          </div>

          <!-- Responsible -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-person-check"></i> Sorumlu Kişi
            </label>
            <select class="form-select" name="responsible_user_id">
              <option value="">Seçilmedi</option>
              <% users.forEach(u => { %>
                <option value="<%= u.id %>" <%= study.owner_email === u.id ? 'selected' : '' %>>
                  <%= u.name || u.email %>
                </option>
              <% }); %>
            </select>
          </div>

          <!-- MSA Details -->
          <div class="section-title">
            <i class="bi bi-clipboard-data"></i> MSA Detayları
          </div>

          <!-- Equipment Selection (if available) -->
          <% if (equipment && equipment.length > 0) { %>
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-tools"></i> Ölçüm Ekipmanı
            </label>
            <select class="form-select" id="equipment_select" onchange="fillEquipmentDetails()">
              <option value="">Manuel Gir</option>
              <% equipment.forEach(eq => { %>
                <option value="<%= eq.id %>"
                        data-name="<%= eq.name %>"
                        data-serial="<%= eq.serial_number %>"
                        data-device="<%= eq.device_number %>">
                  <%= eq.name %> (Seri: <%= eq.serial_number %>, Cihaz: <%= eq.device_number %>)
                </option>
              <% }); %>
            </select>
            <small class="text-muted">Listeden seçebilir veya manuel girebilirsiniz</small>
          </div>
          <% } %>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Ölçüm Cihazı Adı</label>
              <input type="text" class="form-control" id="gauge_name" name="gauge_name"
                     value="<%= study.gauge_name || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Cihaz Seri No</label>
              <input type="text" class="form-control" id="gauge_number" name="gauge_number"
                     value="<%= study.gauge_number || '' %>">
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Parça Adı</label>
              <input type="text" class="form-control" name="part_name"
                     value="<%= study.part_name || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Ölçülen Özellik</label>
              <input type="text" class="form-control" name="characteristic"
                     value="<%= study.characteristic || '' %>">
            </div>
          </div>

          <div class="row mb-3">
            <div class="col-md-6">
              <label class="form-label">Tolerans</label>
              <input type="text" class="form-control" name="tolerance"
                     value="<%= study.tolerance || '' %>">
            </div>
            <div class="col-md-6">
              <label class="form-label">Konum/Lokasyon</label>
              <input type="text" class="form-control" name="location"
                     value="<%= study.location || '' %>">
            </div>
          </div>

          <!-- Notes -->
          <div class="mb-3">
            <label class="form-label">
              <i class="bi bi-sticky"></i> Notlar
            </label>
            <textarea class="form-control" name="notes" rows="2"></textarea>
          </div>

          <!-- Actions -->
          <div class="d-flex gap-2 justify-content-end">
            <a href="capa-detail.html?study=<%= study.id %>&id=<%= capa.id %>" class="btn btn-secondary">
              <i class="bi bi-x-circle"></i> İptal
            </a>
            <button type="button" class="btn btn-outline-primary" onclick="skipScheduling()">
              <i class="bi bi-skip-forward"></i> Şimdi Planlamayacağım
            </button>
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check-circle"></i> MSA Planla
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    document.getElementById('scheduleForm').addEventListener('submit', async function(e) {
      e.preventDefault();

      const formData = new FormData(this);
      const data = Object.fromEntries(formData.entries());

      try {
        const result = await MSA_SCHEDULE_API.create(data);

        if (result.success) {
          alert('✅ MSA başarıyla planlandı!\n\nPlanlanan Tarih: ' + data.planned_date);
          window.location.href = 'schedule-master.html';
        } else {
          alert('❌ Hata: ' + result.error);
        }
      } catch (error) {
        alert('❌ Bağlantı hatası: ' + error.message);
      }
    });

    function skipScheduling() {
      if (confirm('MSA planlamadan devam etmek istediğinizden emin misiniz?\n\nDaha sonra MSA Planlama sayfasından manuel olarak planlayabilirsiniz.')) {
        window.location.href = 'capa-detail.html?study=<%= study.id %>&id=<%= capa.id %>';
      }
    }

    function fillEquipmentDetails() {
      const select = document.getElementById('equipment_select');
      const selectedOption = select.options[select.selectedIndex];

      if (selectedOption.value) {
        // Seçilen ekipman bilgilerini formdaki alanlara doldur
        document.getElementById('gauge_name').value = selectedOption.dataset.name || '';
        document.getElementById('gauge_number').value = selectedOption.dataset.serial || '';
      } else {
        // "Manuel Gir" seçilirse alanları temizle
        document.getElementById('gauge_name').value = '';
        document.getElementById('gauge_number').value = '';
      }
    }
  </script>
</body>
</html>
