<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Proses Yeterliliği - <%= study.study_name %></title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
<style>
  :root{ --p:#667eea; --p2:#764ba2; --bg:#f5f7fb; --card:#fff; --ink:#232a35; --muted:#6b7280;
         --line:#e6e9f2; --good:#1e7e4a; --gbg:#eaf6ef; --mar:#b7791f; --mbg:#fdf6e6; --bad:#c0392b; --bbg:#fdecea; --shadow:0 2px 10px rgba(30,40,70,.07); }
  *{box-sizing:border-box} body{margin:0;background:var(--bg);color:var(--ink);font-family:'Segoe UI',system-ui,sans-serif;font-size:14px}
  .wrap{max-width:1040px;margin:0 auto;padding:18px}
  .hdr{background:linear-gradient(135deg,var(--p),var(--p2));color:#fff;border-radius:14px;padding:20px 22px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;box-shadow:var(--shadow)}
  .hdr h1{margin:0;font-size:20px;font-weight:700} .hdr .sub{opacity:.9;font-size:12.5px;margin-top:3px}
  .badge{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;border-radius:999px;font-weight:700;font-size:13px}
  .badge.good{background:var(--gbg);color:var(--good)} .badge.marginal{background:var(--mbg);color:var(--mar)} .badge.bad{background:var(--bbg);color:var(--bad)} .badge.neutral{background:#eef1f8;color:var(--muted)}
  .acts{display:flex;gap:8px;flex-wrap:wrap;margin:14px 0}
  .btn{border:0;border-radius:9px;padding:9px 15px;font-size:13px;font-weight:600;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:7px}
  .btn.primary{background:linear-gradient(135deg,var(--p),var(--p2));color:#fff} .btn.ghost{background:#eef1f8;color:#41506b}
  .card{background:var(--card);border-radius:13px;box-shadow:var(--shadow);padding:18px 20px;margin:14px 0}
  .card h2{margin:0 0 3px;font-size:16px;font-weight:700;display:flex;align-items:center;gap:8px} .card h2 .i{color:var(--p)}
  .exp{background:#f8f9fd;border-left:3px solid var(--p);border-radius:0 8px 8px 0;padding:10px 13px;font-size:12.8px;color:#4a5568;margin:10px 0 4px;line-height:1.55}
  table{width:100%;border-collapse:collapse;margin-top:8px;font-size:13px}
  th,td{padding:8px 10px;text-align:center;border-bottom:1px solid var(--line)}
  th{background:#f3f5fb;font-weight:600;color:#39415a;font-size:12px} td:first-child,th:first-child{text-align:left}
  .num{font-variant-numeric:tabular-nums}
  .pill{display:inline-block;padding:2px 9px;border-radius:999px;font-weight:700;font-size:12px}
  .pill.good{background:var(--gbg);color:var(--good)} .pill.marginal{background:var(--mbg);color:var(--mar)} .pill.bad{background:var(--bbg);color:var(--bad)}
  .info{grid-template-columns:repeat(auto-fit,minmax(120px,1fr));display:grid;gap:10px;margin-top:6px}
  .info .kv{background:#f8f9fd;border-radius:9px;padding:9px 12px}
  .info .kv b{display:block;color:var(--muted);font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.3px}
  .info .kv span{font-size:16px;font-weight:700}
  .grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px}@media(max-width:820px){.grid2{grid-template-columns:1fr}}
  .chartbox{position:relative;height:300px} .chartbox.tall{height:340px}
  .foot{color:var(--muted);font-size:11.5px;text-align:center;margin:18px 0 8px}
  .optgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px 16px}
  .optgrid label{display:flex;flex-direction:column;font-size:12px;font-weight:600;color:#4a5568;gap:5px}
  .optgrid select,.optgrid input[type=number]{padding:8px 10px;border:1px solid var(--line);border-radius:8px;font-size:13px;font-family:inherit;font-weight:500;color:var(--ink)}
  .optgrid label.chk{flex-direction:row;align-items:center;gap:8px;align-self:end}
  .optgrid label.chk input{width:16px;height:16px}
  .teststrip{margin-top:8px} .testcap{font-size:11px;font-weight:700;color:#39415a;text-transform:uppercase;letter-spacing:.3px;margin-bottom:4px}
  .testok{background:var(--gbg);color:var(--good);border-radius:8px;padding:7px 11px;font-size:12.5px;font-weight:600;display:flex;align-items:center;gap:6px}
  .testtbl{font-size:12px;margin-top:0} .testtbl th{background:#fdf0ee;color:#8c3a2e} .testtbl td{padding:5px 8px}
  @media print{.acts,.optgrid,#optApply{display:none}body{background:#fff}.card{box-shadow:none;border:1px solid var(--line)}}
</style>
</head>
<body>
<div class="wrap">
  <% var it=results.interpretation; var si=results.studyInfo; var W=results.within; var O=results.overall; var perf=results.performance; var nm=results.normality;
     var Wci=W.ci||{}, Oci=O.ci||{}; var op=results.options||{}; var tr=results.transform||{}; var ciPct=Math.round((op.ciLevel||0.90)*100);
     var nn=results.nonNormal; var isNN=!!(op.isNonNormal && nn && !nn.error);
     var mainIdx=isNN?nn.ppk:it.cpk; var mainLbl=isNN?'Ppk':'Cpk';
     var mainCls=mainIdx==null?'neutral':(mainIdx>=1.33?'good':(mainIdx>=1.0?'marginal':'bad'));
     var mainTxt=mainCls==='good'?'Yeterli':(mainCls==='marginal'?'Marjinal':(mainCls==='bad'?'Yetersiz':'—'));
     function fn(x,d){ return x==null?'—':Number(x).toFixed(d==null?3:d); }
     function cil(o){ return (o&&o.lo!=null&&isFinite(o.lo))?Number(o.lo).toFixed(3):'—'; }
     function cih(o){ return (o&&o.hi!=null&&isFinite(o.hi))?Number(o.hi).toFixed(3):'—'; }
     function idxPill(v){ if(v==null)return '—'; var c=v>=1.33?'good':(v>=1.0?'marginal':'bad'); return '<span class="pill '+c+'">'+v.toFixed(3)+'</span>'; }
     function sel(cur,val){ return String(cur)===String(val)?' selected':''; }
     var swLbl = si.method==='individual' ? 'MR̄/1.128' : (si.withinLabel||'s̄/c₄'); %>
  <div class="hdr">
    <div><h1><i class="bi bi-graph-up"></i> Proses Yeterliliği</h1>
      <div class="sub"><%= study.study_name %><%= study.gauge_name ? ' · '+study.gauge_name : '' %></div></div>
    <span class="badge <%= mainCls %>">
      <i class="bi bi-<%= mainCls==='good'?'check-circle-fill':(mainCls==='marginal'?'exclamation-triangle-fill':'x-circle-fill') %>"></i>
      <%= mainLbl %> = <%= fn(mainIdx) %> · <%= mainTxt %><%= isNN?' · '+nn.dist:'' %>
    </span>
  </div>

  <div class="acts">
    <a class="btn primary" href="#" onclick="window.print();return false"><i class="bi bi-printer"></i> PDF / Yazdır</a>
    <a class="btn ghost" href="cap-data-entry.html?id=<%= study.id %>"><i class="bi bi-pencil"></i> Veriyi Düzenle</a>
    <a class="btn ghost" href="capability.html"><i class="bi bi-arrow-left"></i> Panoya Dön</a>
  </div>

  <div class="card" style="border:1px solid var(--line)">
    <h2><i class="bi bi-sliders i"></i> Analiz Ayarları</h2>
    <div class="exp" style="margin-bottom:12px">JASP Process Capability seçenekleri. Değiştirdiğinizde analiz seçtiğiniz ayarlara göre yeniden hesaplanır.</div>
    <div class="optgrid">
      <label>Veri dağılımı
        <select id="optDist">
          <optgroup label="Normal">
            <option value="normal"<%= sel(op.distribution,'normal') %>>Normal dağılım</option>
            <option value="boxcox"<%= sel(op.distribution,'boxcox') %>>Box-Cox normalizasyon</option>
          </optgroup>
          <optgroup label="Normal olmayan (dağılım uydur)">
            <option value="lognormal"<%= sel(op.distribution,'lognormal') %>>Lognormal</option>
            <option value="lognormal3"<%= sel(op.distribution,'lognormal3') %>>3-parametreli Lognormal</option>
            <option value="weibull"<%= sel(op.distribution,'weibull') %>>Weibull</option>
            <option value="weibull3"<%= sel(op.distribution,'weibull3') %>>3-parametreli Weibull</option>
          </optgroup>
        </select></label>
      <label>Normal-olmayan yeterlilik yöntemi
        <select id="optNNMethod">
          <option value="percentile"<%= sel(op.nonNormalMethod,'percentile') %>>Percentile (yüzdelik)</option>
          <option value="nonconformance"<%= sel(op.nonNormalMethod,'nonconformance') %>>Non-conformance (uyumsuzluk)</option>
        </select></label>
      <label>Alt grup boyutu
        <input type="number" id="optSg" min="1" max="25" value="<%= op.subgroupSize!=null?op.subgroupSize:(si.subgroupSize||5) %>"></label>
      <label>Within σ yöntemi (alt grup&gt;1)
        <select id="optWithin">
          <option value="sbar"<%= sel(op.withinMethod,'sbar') %>>S-bar (s̄/c₄)</option>
          <option value="rbar"<%= sel(op.withinMethod,'rbar') %>>R-bar (R̄/d₂)</option>
          <option value="pooled"<%= sel(op.withinMethod,'pooled') %>>Pooled</option>
        </select></label>
      <label>Kontrol kartı
        <select id="optChart">
          <option value="auto"<%= sel(op.controlChart,'auto') %>>Otomatik</option>
          <option value="xbars"<%= sel(op.controlChart,'xbars') %>>X̄ &amp; S</option>
          <option value="xbarr"<%= sel(op.controlChart,'xbarr') %>>X̄ &amp; R</option>
          <option value="imr"<%= sel(op.controlChart,'imr') %>>I-MR (Bireysel)</option>
        </select></label>
      <label>Güven aralığı %
        <select id="optCi">
          <option value="90"<%= sel(ciPct,90) %>>90%</option>
          <option value="95"<%= sel(ciPct,95) %>>95%</option>
          <option value="99"<%= sel(ciPct,99) %>>99%</option>
        </select></label>
      <label>Histogram bin sayısı
        <input type="number" id="optBins" min="4" max="40" value="<%= op.bins||si.N&&Math.min(Math.max(Math.ceil(Math.sqrt(si.N)),8),20)||10 %>"></label>
      <label>Kontrol limiti σ katsayısı
        <input type="number" id="optSigma" min="1" max="6" step="0.5" value="<%= op.sigmaMult||3 %>"></label>
      <label class="chk"><input type="checkbox" id="optUnbias"<%= op.useUnbiasing!==false?' checked':'' %>> Sapmasızlık sabiti (c₄/d₂) kullan</label>
    </div>
    <div style="font-weight:700;font-size:12px;color:#39415a;text-transform:uppercase;letter-spacing:.3px;margin:16px 2px 8px">Ölçü Spesifikasyonu (girip Uygula deyince kaydedilir)</div>
    <div class="optgrid">
      <label>Alt spesifikasyon (LSL)
        <input type="number" id="optLsl" step="any" value="<%= si.origLsl!=null?si.origLsl:'' %>" placeholder="ör. 94">
        <span style="font-weight:500;font-size:11px;color:var(--muted)"><label class="chk" style="display:inline-flex;gap:5px;margin-top:3px"><input type="checkbox" id="optLslB"<%= op.lslBoundary?' checked':'' %>> Sınır (boundary — hesaba katma)</label></span></label>
      <label>Hedef (Target)
        <input type="number" id="optTarget" step="any" value="<%= si.origTarget!=null?si.origTarget:'' %>" placeholder="ör. 100"></label>
      <label>Üst spesifikasyon (USL)
        <input type="number" id="optUsl" step="any" value="<%= si.origUsl!=null?si.origUsl:'' %>" placeholder="ör. 106">
        <span style="font-weight:500;font-size:11px;color:var(--muted)"><label class="chk" style="display:inline-flex;gap:5px;margin-top:3px"><input type="checkbox" id="optUslB"<%= op.uslBoundary?' checked':'' %>> Sınır (boundary — hesaba katma)</label></span></label>
    </div>
    <div style="margin-top:12px;display:flex;gap:8px;flex-wrap:wrap">
      <button class="btn primary" onclick="capReload()"><i class="bi bi-arrow-repeat"></i> Uygula ve Yeniden Hesapla</button>
      <button class="btn ghost" onclick="location.href='cap-results.html?id=<%= study.id %>'"><i class="bi bi-x-circle"></i> Varsayılana Dön</button>
    </div>
    <% if(tr.applied){ %><div class="exp" style="border-left-color:#b7791f;margin-top:10px"><b>Box-Cox dönüşümü uygulandı</b> — optimal <b>λ = <%= fn(tr.lambda,3) %></b><% if(tr.ciLo!=null){ %> (%95 GA: <%= fn(tr.ciLo,2) %> … <%= fn(tr.ciHi,2) %>)<% } %>, yuvarlanmış λ = <b><%= fn(tr.lambdaRounded,1) %></b><%= tr.shift?(', kaydırma = '+fn(tr.shift,3)):'' %>.
      <%= tr.lambda===0?'(λ≈0 → doğal logaritma)':(Math.abs(tr.lambda-0.5)<0.06?'(λ≈0.5 → karekök)':'') %>
      Tüm indeksler, spesifikasyon sınırları ve grafikler <b>dönüştürülmüş ölçekte</b> hesaplanır.
      <% if(tr.includesOne){ %><br><b style="color:#8c3a2e">⚠ λ güven aralığı 1'i içeriyor → verinin istatistiksel olarak dönüşüme İHTİYACI YOK</b> (normal dağılım yeterli; dönüşümü kapatabilirsiniz).<% } %>
      <br><span style="color:var(--muted)">Not: Box-Cox yalnız pozitif veriyle çalışır; sıfır/negatif değer varsa Johnson dönüşümü gerekir (modülde otomatik +kaydırma uygulanır).</span></div><% } %>
  </div>

  <div class="card">
    <h2><i class="bi bi-info-circle i"></i> Özet</h2>
    <div class="info">
      <div class="kv"><b>Cp</b><span><%= fn(W.cp) %></span></div>
      <div class="kv"><b>Cpk</b><span><%= fn(W.cpk) %></span></div>
      <div class="kv"><b>Pp</b><span><%= fn(O.cp) %></span></div>
      <div class="kv"><b>Ppk</b><span><%= fn(O.cpk) %></span></div>
      <div class="kv"><b>Ortalama</b><span><%= fn(si.mean,3) %></span></div>
      <div class="kv"><b>σ (within)</b><span><%= fn(si.sigmaWithin,4) %></span></div>
      <div class="kv"><b>σ (overall)</b><span><%= fn(si.sigmaOverall,4) %></span></div>
      <div class="kv"><b>n / altgrup</b><span><%= si.N %> / <%= si.subgroupSize %></span></div>
    </div>
    <div class="exp"><b>Proses yeterliliği</b>, sürecin çıktısının spesifikasyon sınırlarına (LSL–USL) ne kadar sığdığını ölçer.
      <b>Cp/Cpk</b> kısa dönem (within, σ = <%= swLbl %>), <b>Pp/Ppk</b> uzun dönem (overall) yeteneği gösterir.
      Genel kabul: <b>Cpk ≥ 1.33 yeterli</b>, 1.00–1.33 marjinal, &lt; 1.00 yetersiz. Cp≈Cpk ise süreç ortalanmıştır.
      Spesifikasyon: LSL=<%= fn(si.lsl,2) %>, Hedef=<%= si.target!=null?fn(si.target,2):'—' %>, USL=<%= fn(si.usl,2) %>.</div>
  </div>

  <div class="card">
    <h2><i class="bi bi-bar-chart-line i"></i> Histogram & Yeterlilik Grafiği</h2>
    <div class="exp">Gri barlar = veri dağılımı. <b style="color:#1f2a44">Overall</b> (koyu dolgu) = uzun dönem σ ile normal eğri, <b style="color:#c0392b">Within</b> (kırmızı kesikli) = kısa dönem σ ile normal eğri (Minitab tarzı). Dikey kırmızı çizgiler = spesifikasyon sınırları (LSL/USL), yeşil = hedef. Barlar sınırların içinde ve iki eğri üst üste + ortalanmışsa süreç hem stabil hem yeterlidir.</div>
    <div class="chartbox tall"><canvas id="chartHist"></canvas></div>
  </div>

  <% if(isNN){ %>
  <div class="card">
    <h2><i class="bi bi-diagram-2 i"></i> Normal-Olmayan Yeterlilik — <%= nn.dist %> (<%= nn.method==='nonconformance'?'Non-conformance':'Percentile' %>)</h2>
    <div class="exp">Veri normal dağılıma uymadığında <b><%= nn.dist %></b> dağılımı uydurulur ve yeterlilik <b><%= nn.method==='nonconformance'?'uyumsuzluk oranından eşdeğer Z (Ppk=Φ⁻¹(1−p)/3)':'yüzdelik yöntemiyle (P0.135 / P50 / P99.865)' %></b> hesaplanır (JASP/Minitab kuralı). Normal-olmayan analizde güven aralığı ve within/overall ayrımı raporlanmaz.</div>
    <div class="grid2">
      <div>
        <div style="font-weight:600;font-size:13px">Yeterlilik İndeksleri</div>
        <table>
          <tbody>
            <tr><td>Pp</td><td><%- idxPill(nn.pp) %></td></tr>
            <tr><td>Ppk</td><td><%- idxPill(nn.ppk) %></td></tr>
            <tr><td>Ppl (alt)</td><td class="num"><%= fn(nn.ppl) %></td></tr>
            <tr><td>Ppu (üst)</td><td class="num"><%= fn(nn.ppu) %></td></tr>
            <% if(nn.cpm!=null){ %><tr><td>Cpm (hedefe göre)</td><td class="num"><%= fn(nn.cpm) %></td></tr><% } %>
          </tbody>
        </table>
      </div>
      <div>
        <div style="font-weight:600;font-size:13px">Uydurulan Dağılım</div>
        <table>
          <tbody>
            <% Object.keys(nn.params).forEach(function(k){ %><tr><td><%= k %></td><td class="num"><%= fn(nn.params[k],4) %></td></tr><% }); %>
            <tr><td>Anderson-Darling (fit)</td><td class="num"><%= fn(nn.ad,3) %></td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div style="overflow-x:auto;margin-top:10px">
    <table>
      <thead><tr><th>Yüzdelikler</th><th>P0.135</th><th>P50 (medyan)</th><th>P99.865</th></tr></thead>
      <tbody><tr><td><%= nn.dist %></td><td class="num"><%= fn(nn.P00135,3) %></td><td class="num"><%= fn(nn.P50,3) %></td><td class="num"><%= fn(nn.P99865,3) %></td></tr></tbody>
    </table>
    </div>
    <div class="exp" style="margin-top:10px"><b>Beklenen uyumsuzluk (fit):</b> ppm&lt;LSL = <%= fn(nn.expected.below,2) %> · ppm&gt;USL = <%= fn(nn.expected.above,2) %> · <b>toplam = <%= fn(nn.expected.total,2) %> ppm</b>. Gözlenen (veride): <%= fn(perf.observed.total,2) %> ppm.
      <% if(nn.boundary.lsl||nn.boundary.usl){ %><br><b>Sınır (boundary):</b> <%= nn.boundary.lsl?'LSL':'' %><%= nn.boundary.lsl&&nn.boundary.usl?' ve ':'' %><%= nn.boundary.usl?'USL':'' %> hesaba katılmadı (tek-yön analiz).<% } %></div>
  </div>
  <% } %>

  <% if(!isNN){ %>
  <div class="card">
    <h2><i class="bi bi-table i"></i> Proses Yeterliliği (within)</h2>
    <div class="exp">Kısa dönem (within) yeterlilik — σ<sub>within</sub> = <%= swLbl %> = <%= fn(si.sigmaWithin,4) %>. Yanında <b>%90 güven aralıkları</b> (Cp/Cpk için, df = <%= si.dfWithin %>).</div>
    <div style="overflow-x:auto">
    <table>
      <thead>
        <tr><th rowspan="2">Cp</th><th colspan="2">%90 GA (Cp)</th><th rowspan="2">CpL</th><th rowspan="2">CpU</th><th rowspan="2">Cpk</th><th colspan="2">%90 GA (Cpk)</th></tr>
        <tr><th>Alt</th><th>Üst</th><th>Alt</th><th>Üst</th></tr>
      </thead>
      <tbody><tr>
        <td><%- idxPill(W.cp) %></td>
        <td class="num"><%= cil(Wci.cp) %></td><td class="num"><%= cih(Wci.cp) %></td>
        <td class="num"><%= fn(W.cpl) %></td><td class="num"><%= fn(W.cpu) %></td>
        <td><%- idxPill(W.cpk) %></td>
        <td class="num"><%= cil(Wci.cpk) %></td><td class="num"><%= cih(Wci.cpk) %></td>
      </tr></tbody>
    </table>
    </div>
  </div>

  <div class="card">
    <h2><i class="bi bi-table i"></i> Proses Performansı (total)</h2>
    <div class="exp">Uzun dönem (overall) performans — σ<sub>overall</sub> = örneklem std sapması = <%= fn(si.sigmaOverall,4) %>. %90 güven aralıkları (df = <%= si.dfTotal %>).</div>
    <div style="overflow-x:auto">
    <table>
      <thead>
        <tr><th rowspan="2">Pp</th><th colspan="2">%90 GA (Pp)</th><th rowspan="2">PpL</th><th rowspan="2">PpU</th><th rowspan="2">Ppk</th><th colspan="2">%90 GA (Ppk)</th></tr>
        <tr><th>Alt</th><th>Üst</th><th>Alt</th><th>Üst</th></tr>
      </thead>
      <tbody><tr>
        <td><%- idxPill(O.cp) %></td>
        <td class="num"><%= cil(Oci.cp) %></td><td class="num"><%= cih(Oci.cp) %></td>
        <td class="num"><%= fn(O.cpl) %></td><td class="num"><%= fn(O.cpu) %></td>
        <td><%- idxPill(O.cpk) %></td>
        <td class="num"><%= cil(Oci.cpk) %></td><td class="num"><%= cih(Oci.cpk) %></td>
      </tr></tbody>
    </table>
    </div>
    <% if(results.cpm!=null){ %><div class="exp" style="border-left-color:#9aa4bf">Hedefe göre yeterlilik <b>Cpm = <%= fn(results.cpm) %></b> (hedef sapması dahil).</div><% } %>
  </div>

  <div class="card">
    <h2><i class="bi bi-percent i"></i> Uyumsuzluk İstatistikleri (PPM)</h2>
    <div class="exp"><b>Gözlenen</b> = veride spesifikasyon dışı kalan gerçek oran. <b>Beklenen (toplam)</b> = uzun dönem σ ile teorik oran. <b>Beklenen (within)</b> = kısa dönem σ ile potansiyel oran. Birim: milyonda kusurlu (ppm).</div>
    <table>
      <thead><tr><th></th><th>Gözlenen</th><th>Beklenen (toplam)</th><th>Beklenen (within)</th></tr></thead>
      <tbody>
        <tr><td>ppm &lt; LSL</td><td class="num"><%= fn(perf.observed.below,3) %></td><td class="num"><%= fn(perf.expectedOverall.below,3) %></td><td class="num"><%= fn(perf.expectedWithin.below,3) %></td></tr>
        <tr><td>ppm &gt; USL</td><td class="num"><%= fn(perf.observed.above,3) %></td><td class="num"><%= fn(perf.expectedOverall.above,3) %></td><td class="num"><%= fn(perf.expectedWithin.above,3) %></td></tr>
        <tr><td style="font-weight:600">ppm toplam</td><td class="num" style="font-weight:600"><%= fn(perf.observed.total,3) %></td><td class="num" style="font-weight:600"><%= fn(perf.expectedOverall.total,3) %></td><td class="num" style="font-weight:600"><%= fn(perf.expectedWithin.total,3) %></td></tr>
      </tbody>
    </table>
  </div>
  <% } %>

  <% var gl=results.graph.chartLabels; var xb=results.graph.xbarChart; var sc=results.graph.sChart;
     function testsHtml(tst){ if(!tst||!tst.length) return '<div class="testok"><i class="bi bi-check-circle-fill"></i> Test ihlali oluşmadı.</div>';
       return '<table class="testtbl"><thead><tr><th>Kural</th><th>Açıklama</th><th>Noktalar</th></tr></thead><tbody>'+
         tst.map(function(t){ return '<tr><td>'+t.rule+'</td><td style="text-align:left">'+t.desc+'</td><td>'+t.pts.join(', ')+'</td></tr>'; }).join('')+'</tbody></table>'; } %>
  <div class="card">
    <h2><i class="bi bi-activity i"></i> Kontrol Kartları (<%= gl.kind %>)</h2>
    <div class="exp">Süreç <b>kararlılığını</b> gösterir. Noktalar kontrol sınırları (UCL/LCL) içinde ve rastgele dağılmışsa süreç stabildir — yeterlilik analizi ancak stabil süreçte anlamlıdır. Kart tipi alt grup boyutuna göre otomatik seçilir (n=1 → I-MR, 2–8 → X̄-R, ≥9 → X̄-S) veya Ayarlar'dan elle seçilebilir.</div>
    <div class="grid2">
      <div><div style="font-weight:600;font-size:12.5px;text-align:center"><%= gl.top %></div><div class="chartbox"><canvas id="chartXbar"></canvas></div>
        <div class="teststrip"><div class="testcap"><%= gl.topAxis %> kartı testleri</div><%- testsHtml(xb.tests) %></div></div>
      <div><div style="font-weight:600;font-size:12.5px;text-align:center"><%= gl.bottom %></div><div class="chartbox"><canvas id="chartS"></canvas></div>
        <div class="teststrip"><div class="testcap"><%= gl.bottomAxis %> kartı testleri</div><%- testsHtml(sc.tests) %></div></div>
    </div>
  </div>

  <div class="card">
    <h2><i class="bi bi-graph-up-arrow i"></i> Normal Olasılık Grafiği (Q-Q)</h2>
    <div class="exp">Noktalar düz çizgiye (kırmızı kesikli %95 bandı) yakınsa veri normal dağılıma uyar. Sistematik sapma (S/eğri şekli) normal-olmamayı gösterir — bu durumda "Veri dağılımı" ayarından <b>Box-Cox normalizasyon</b> seçebilirsiniz.<%= tr.applied ? ' (Grafik dönüştürülmüş ölçektedir.)' : '' %></div>
    <div class="chartbox tall"><canvas id="chartQQ"></canvas></div>
  </div>

  <div class="card">
    <h2><i class="bi bi-clipboard-data i"></i> Normallik Testi (Anderson-Darling)</h2>
    <table>
      <thead><tr><th>N</th><th>Ortalama</th><th>Std. Sapma</th><th>AD</th><th>p-değeri</th><th>Sonuç</th></tr></thead>
      <tbody><tr><td class="num"><%= nm.N %></td><td class="num"><%= fn(nm.mean,3) %></td><td class="num"><%= fn(nm.sd,4) %></td><td class="num"><%= fn(nm.ad,3) %></td><td class="num"><%= nm.p<0.001?'< .001':fn(nm.p,3) %></td>
        <td><%- nm.p>=0.05 ? '<span class="pill good">Normal</span>' : '<span class="pill bad">Normal değil</span>' %></td></tr></tbody>
    </table>
    <div class="exp" style="border-left-color:#9aa4bf">p ≥ 0.05 ise veri normal dağılıma uyar ve Cp/Cpk yorumları geçerlidir. p &lt; 0.05 ise dönüşüm ya da normal-olmayan yeterlilik yöntemi gerekebilir.</div>
  </div>

  <div class="foot">GageAI · Proses Yeterliliği (Process Capability) — AIAG/ISO / JASP metodolojisi ile doğrulanmıştır.</div>
</div>

<script>
(function(){
  var R = <%- JSON.stringify(results) %>;
  var g=R.graph;
  // Histogram + within/overall normal eğrileri + spesifikasyon çizgileri (Minitab tarzı)
  var hEl=document.getElementById('chartHist');
  if(hEl){
    var xmin=g.hist[0].x0, xmax=g.hist[g.hist.length-1].x1;
    // Spesifikasyon çizgileri LİNEER eksene göre çizilir (böylece LSL/USL/Hedef her zaman görünür)
    var specPlugin={ id:'spec', afterDatasetsDraw:function(c){ var ctx=c.ctx, xl=c.scales.xLin, y=c.scales.y; if(!xl)return;
      function vline(val,col,lbl){ if(val==null||!isFinite(val))return; var px=xl.getPixelForValue(val); if(px<xl.left-1||px>xl.right+1)return;
        ctx.save(); ctx.strokeStyle=col; ctx.setLineDash([6,5]); ctx.lineWidth=2; ctx.beginPath(); ctx.moveTo(px,y.top); ctx.lineTo(px,y.bottom); ctx.stroke();
        ctx.setLineDash([]); ctx.fillStyle=col; ctx.font='bold 11px Segoe UI';
        var tw=ctx.measureText(lbl).width; var tx=Math.min(Math.max(px-tw/2,xl.left), xl.right-tw);
        ctx.fillStyle='#fff'; ctx.fillRect(tx-3,y.top-2,tw+6,15); ctx.fillStyle=col; ctx.fillText(lbl,tx,y.top+9); ctx.restore(); }
      vline(g.lsl,'#c0392b','LSL = '+Number(g.lsl).toFixed(2));
      vline(g.usl,'#c0392b','USL = '+Number(g.usl).toFixed(2));
      vline(g.target,'#1e7e4a','Hedef = '+Number(g.target).toFixed(2));
    }};
    var histDatasets=[
      { type:'bar', label:'Frekans', data:g.hist.map(function(b){return b.count;}), backgroundColor:'rgba(130,140,165,.35)', borderColor:'#8f9bb8', borderWidth:1, categoryPercentage:1.0, barPercentage:1.0, order:3 }
    ];
    if(g.isNonNormal && g.curveFit){
      histDatasets.push({ type:'line', label:(g.distName||'Fit')+' (uydurulan)', data:g.curveFit.map(function(p){return {x:p.x,y:p.y};}), borderColor:'#7b1fa2', backgroundColor:'rgba(123,31,162,.06)', pointRadius:0, borderWidth:2.5, tension:0.35, fill:true, order:1, xAxisID:'xLin' });
    } else {
      histDatasets.push({ type:'line', label:'Overall (uzun dönem)', data:g.curveOverall.map(function(p){return {x:p.x,y:p.y};}), borderColor:'#1f2a44', backgroundColor:'rgba(31,42,68,.05)', pointRadius:0, borderWidth:2.4, tension:0.35, fill:true, order:1, xAxisID:'xLin' });
      histDatasets.push({ type:'line', label:'Within (kısa dönem)', data:g.curveWithin.map(function(p){return {x:p.x,y:p.y};}), borderColor:'#c0392b', pointRadius:0, borderWidth:2.2, borderDash:[7,4], tension:0.35, order:2, xAxisID:'xLin' });
    }
    new Chart(hEl,{
      data:{ labels:g.hist.map(function(b){return b.mid.toFixed(1);}), datasets:histDatasets },
      options:{ responsive:true, maintainAspectRatio:false, layout:{padding:{top:14}},
        scales:{ x:{ title:{display:true,text:'Ölçüm'+(R.transform&&R.transform.applied?' (dönüştürülmüş)':'')}, grid:{display:false} },
          xLin:{ type:'linear', display:false, min:xmin, max:xmax },
          y:{ beginAtZero:true, title:{display:true,text:'Frekans'}, grid:{color:'rgba(0,0,0,.05)'} } },
        plugins:{ legend:{display:true,position:'top',labels:{boxWidth:14,font:{size:11.5},filter:function(it){return it.text!=='Frekans';}}} } },
      plugins:[specPlugin]
    });
  }
  function ctrlChart(id, ch, label){
    var el=document.getElementById(id); if(!el)return;
    var n=ch.points.length;
    // UCL/CL/LCL değer etiketleri (sağ kenarda, JASP gibi)
    var limLabels={ id:'lim'+id, afterDatasetsDraw:function(c){ var ctx=c.ctx, y=c.scales.y, xr=c.chartArea.right;
      function lab(val,txt,col){ if(val==null||!isFinite(val))return; var py=y.getPixelForValue(val); if(py<c.chartArea.top-1||py>c.chartArea.bottom+1)return;
        ctx.save(); ctx.fillStyle=col; ctx.font='bold 10px Segoe UI'; ctx.textBaseline='middle'; ctx.fillText(txt,xr+4,py); ctx.restore(); }
      lab(ch.ucl,'UCL = '+Number(ch.ucl).toFixed(3),'#c0392b');
      lab(ch.cl, 'CL = '+Number(ch.cl).toFixed(3),'#1e7e4a');
      lab(ch.lcl,'LCL = '+Number(ch.lcl).toFixed(3),'#c0392b'); }};
    // sınır dışı noktaları kırmızı vurgula
    var ptColors=ch.points.map(function(p){ return (p.y>ch.ucl||p.y<ch.lcl)?'#c0392b':'#667eea'; });
    new Chart(el,{ data:{ labels:ch.points.map(function(p){return p.x;}), datasets:[
      { type:'line', label:label, data:ch.points.map(function(p){return p.y;}), borderColor:'#667eea', backgroundColor:ptColors, pointBackgroundColor:ptColors, pointRadius:3, borderWidth:1.8, tension:0 },
      { type:'line', label:'UCL', data:Array(n).fill(ch.ucl), borderColor:'#c0392b', borderDash:[6,4], pointRadius:0, borderWidth:1.3 },
      { type:'line', label:'CL', data:Array(n).fill(ch.cl), borderColor:'#1e7e4a', pointRadius:0, borderWidth:1.3 },
      { type:'line', label:'LCL', data:Array(n).fill(ch.lcl), borderColor:'#c0392b', borderDash:[6,4], pointRadius:0, borderWidth:1.3 }
    ]},
    options:{ responsive:true, maintainAspectRatio:false, layout:{padding:{right:74}},
      scales:{ x:{title:{display:true,text:(g.chartLabels&&g.chartLabels.xAxis)||'Alt grup'}} },
      plugins:{ legend:{display:false}, tooltip:{ callbacks:{ label:function(c){ return c.dataset.label+': '+Number(c.raw).toFixed(3); } } } } },
      plugins:[limLabels] });
  }
  var cl=g.chartLabels||{topAxis:'X̄',bottomAxis:'S'};
  ctrlChart('chartXbar', g.xbarChart, cl.topAxis);
  ctrlChart('chartS', g.sChart, cl.bottomAxis);

  // Q-Q normal olasılık grafiği
  var qEl=document.getElementById('chartQQ');
  if(qEl && g.qq){
    new Chart(qEl,{ data:{ datasets:[
      { type:'scatter', label:'Gözlem', data:g.qq.points.map(function(p){return {x:p.x,y:p.z};}), pointRadius:3, pointBackgroundColor:'rgba(90,110,150,.55)', borderColor:'#5a6e96', order:3 },
      { type:'line', label:'Referans', data:g.qq.line.map(function(p){return {x:p.x,y:p.z};}), borderColor:'#39415a', borderWidth:1.6, pointRadius:0, order:2 },
      { type:'line', label:'%95 alt', data:g.qq.bandLo.map(function(p){return {x:p.x,y:p.z};}), borderColor:'#c0392b', borderDash:[5,4], borderWidth:1.2, pointRadius:0, order:1 },
      { type:'line', label:'%95 üst', data:g.qq.bandHi.map(function(p){return {x:p.x,y:p.z};}), borderColor:'#c0392b', borderDash:[5,4], borderWidth:1.2, pointRadius:0, order:1 }
    ]},
    options:{ responsive:true, maintainAspectRatio:false,
      scales:{ x:{ type:'linear', title:{display:true,text:'Ölçüm'+(<%= tr.applied?'true':'false' %>?' (dönüştürülmüş)':'')} },
        y:{ title:{display:true,text:'Teorik nicelik (z)'} } },
      plugins:{ legend:{display:true,position:'top',labels:{boxWidth:12,font:{size:11}}} } }
    });
  }
})();

function capReload(){
  var p=[]; function add(k,v){ p.push(encodeURIComponent(k)+'='+encodeURIComponent(v)); }
  var val=function(id){ var e=document.getElementById(id); return e?e.value:''; };
  add('id', <%= study.id %>);
  add('dist', val('optDist'));
  add('within', val('optWithin'));
  add('unbias', document.getElementById('optUnbias').checked?'1':'0');
  add('chart', val('optChart'));
  add('ci', val('optCi'));
  add('sigma', val('optSigma'));
  var sg=val('optSg'); if(sg) add('sg', sg);
  var b=val('optBins'); if(b) add('bins', b);
  var ls=val('optLsl'); add('lsl', ls);
  var us=val('optUsl'); add('usl', us);
  var t=val('optTarget'); add('target', t);
  add('nnmethod', val('optNNMethod'));
  add('lslb', document.getElementById('optLslB') && document.getElementById('optLslB').checked ? '1':'0');
  add('uslb', document.getElementById('optUslB') && document.getElementById('optUslB').checked ? '1':'0');
  location.href='cap-results.html?'+p.join('&');
}
</script>
</body>
</html>
