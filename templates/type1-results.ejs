                                        value: data.reference,
                                        borderColor: '#2d5016',
                                        borderWidth: 2,
                                        label: {
                                            display: true,
                                            content: 'Ref.',
                                            position: 'end',
                                            backgroundColor: 'transparent',
                                            color: '#2d5016',
                                            font: { size: 12, weight: 'bold' }
                                        }
                                    },
                                    refPlus: {
                                        type: 'line',
                                        scaleID: 'y',
                                        value: data.reference + (data.tolerance * data.percentTol / 100),
                                        borderColor: '#c74a4a',
                                        borderWidth: 1.5,
                                        borderDash: [8, 4],
                                        label: {
                                            display: true,
                                            content: 'Ref. + 0.10 * tol.',
                                            position: 'end',
                                            backgroundColor: 'transparent',
                                            color: '#c74a4a',
                                            font: { size: 11, weight: 'bold' }
                                        }
                                    },
                                    refMinus: {
                                        type: 'line',
                                        scaleID: 'y',
                                        value: data.reference - (data.tolerance * data.percentTol / 100),
                                        borderColor: '#c74a4a',
                                        borderWidth: 1.5,
                                        borderDash: [8, 4],
                                        label: {
                                            display: true,
                                            content: 'Ref. - 0.10 * tol.',
                                            position: 'end',
                                            backgroundColor: 'transparent',
                                            color: '#c74a4a',
                                            font: { size: 11, weight: 'bold' }
                                        }
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                title: { display: true, text: 'Observation' },
                                grid: { display: false }
                            },
                            y: {
                                title: { display: true, text: 'Column 1' }
                            }
                        }
                    }
                });
                console.log('Run chart created successfully');
            } catch (error) {
            console.error('Error creating run chart:', error);
        }
    } else {
        console.error('Canvas not found or Chart.js not loaded');
    }
        
        const histChartCanvas = document.getElementById('histogramChart');
        if (histChartCanvas && typeof Chart !== 'undefined') {
            try {
                // Calculate reference tolerance lines (10% of tolerance)
                const refMinus10Percent = data.reference - (data.tolerance * 0.10);
                const refPlus10Percent = data.reference + (data.tolerance * 0.10);
                
                const histChart = new Chart(histChartCanvas, {
                    type: 'bar',
                    data: {
                        labels: data.histBins,  // Bin centers (numeric values)
                        datasets: [
                            {
                                label: 'Frequency',
                                data: data.histFreqs,
                                backgroundColor: 'rgba(169, 169, 169, 0.6)',
                                borderColor: '#666',
                                borderWidth: 1,
                                barPercentage: 1.0,
                                categoryPercentage: 1.0
                            }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        interaction: {
                            mode: 'index',
                            intersect: true
                        },
                        plugins: {
                            tooltip: {
                                enabled: true,
                                backgroundColor: 'rgba(0, 0, 0, 0.8)',
                                titleColor: '#fff',
                                bodyColor: '#fff',
                                borderColor: '#666',
                                borderWidth: 1,
                                padding: 12,
                                displayColors: false,
                                callbacks: {
                                    title: function(context) {
                                        const index = context[0].dataIndex;
                                        const binLabel = currentBinLabels[index] || context[0].label;
                                        return 'Bin: ' + binLabel;
                                    },
                                    label: function(context) {
                                        return 'Count: ' + context.parsed.y + ' measurements';
                                    }
                                }
                            },
                            legend: { 
                                display: true,
                                position: 'right',
                                labels: {
                                    generateLabels: function(chart) {
                                        return [
                                            {
                                                text: 'Mean',
                                                fillStyle: '#1E90FF',
                                                strokeStyle: '#1E90FF',
                                                lineWidth: 1,
                                                hidden: false
                                            },
                                            {
                                                text: 'Mean - 3s',
                                                fillStyle: '#FF6B6B',
                                                strokeStyle: '#FF6B6B',
                                                lineWidth: 1,
                                                lineDash: [5, 5],
                                                hidden: false
                                            },
                                            {
                                                text: 'Mean + 3s',
                                                fillStyle: '#FF6B6B',
                                                strokeStyle: '#FF6B6B',
                                                lineWidth: 1,
                                                lineDash: [5, 5],
                                                hidden: false
                                            },
                                            {
                                                text: 'Reference',
                                                fillStyle: '#8B0000',
                                                strokeStyle: '#8B0000',
                                                lineWidth: 1,
                                                lineDash: [10, 5],
                                                hidden: false
                                            },
                                            {
                                                text: 'Ref. - 0.10 * tol.',
                                                fillStyle: '#8B0000',
                                                strokeStyle: '#8B0000',
                                                lineWidth: 1,
                                                lineDash: [10, 5],
                                                hidden: false
                                            },
                                            {
                                                text: 'Ref. + 0.10 * tol.',
                                                fillStyle: '#228B22',
                                                strokeStyle: '#228B22',
                                                lineWidth: 1,
                                                lineDash: [10, 5],
                                                hidden: false
                                            }
                                        ];
                                    },
                                    usePointStyle: true,
                                    pointStyle: 'line',
                                    boxWidth: 20,
                                    boxHeight: 2,
                                    padding: 8,
                                    font: {
                                        size: 11
                                    }
                                }
                            },
                            annotation: {
                                annotations: {
                                    mean: {
                                        type: 'line',
                                        yMin: 0,
                                        yMax: Math.max(...data.histFreqs) * 1.1,
                                        xMin: data.mean,
                                        xMax: data.mean,
                                        borderColor: '#1E90FF',
                                        borderWidth: 2
                                    },
                                    meanMinus3s: {
                                        type: 'line',
                                        yMin: 0,
                                        yMax: Math.max(...data.histFreqs) * 1.1,
                                        xMin: data.mean - 3 * data.stdev,
                                        xMax: data.mean - 3 * data.stdev,
                                        borderColor: '#FF6B6B',
                                        borderWidth: 2,
                                        borderDash: [5, 5]
                                    },
                                    meanPlus3s: {
                                        type: 'line',
                                        yMin: 0,
                                        yMax: Math.max(...data.histFreqs) * 1.1,
                                        xMin: data.mean + 3 * data.stdev,
                                        xMax: data.mean + 3 * data.stdev,
                                        borderColor: '#FF6B6B',
                                        borderWidth: 2,
                                        borderDash: [5, 5]
                                    },
                                    ref: {
                                        type: 'line',
                                        yMin: 0,
                                        yMax: Math.max(...data.histFreqs) * 1.1,
                                        xMin: data.reference,
                                        xMax: data.reference,
                                        borderColor: '#8B0000',
                                        borderWidth: 2,
                                        borderDash: [10, 5]
                                    },
                                    refMinus10: {
                                        type: 'line',
                                        yMin: 0,
                                        yMax: Math.max(...data.histFreqs) * 1.1,
                                        xMin: refMinus10Percent,
                                        xMax: refMinus10Percent,
                                        borderColor: '#8B0000',
                                        borderWidth: 2,
                                        borderDash: [10, 5]
                                    },
                                    refPlus10: {
                                        type: 'line',
                                        yMin: 0,
                                        yMax: Math.max(...data.histFreqs) * 1.1,
                                        xMin: refPlus10Percent,
                                        xMax: refPlus10Percent,
                                        borderColor: '#228B22',
                                        borderWidth: 2,
                                        borderDash: [10, 5]
                                    }
                                }
                            }
                        },
                        scales: {
                            x: {
                                type: 'linear',
                                title: { display: true, text: 'Column 1' },
                                grid: { display: false }
                            },
                            y: {
                                title: { display: true, text: 'Count' },
                                beginAtZero: true,
                                ticks: { stepSize: 1 }
                            }
                        }
                    }
                });
                console.log('Histogram created successfully');
                
                // Bin width type selector functionality
                const binWidthSelect = document.getElementById('binWidthType');
                const manualBinsInput = document.getElementById('manualBins');
                const binBoundarySelect = document.getElementById('binBoundary');
                const rawMeasurements = data.measurements;
                let currentBinLabels = []; // Store bin boundary labels for tooltip
                
                binWidthSelect.addEventListener('change', function() {
                    if (this.value === 'manual') {
                        manualBinsInput.style.display = 'block';
                    } else {
                        manualBinsInput.style.display = 'none';
                        recalculateHistogram(this.value, null);
                    }
                });
                
                manualBinsInput.addEventListener('change', function() {
                    if (binWidthSelect.value === 'manual') {
                        recalculateHistogram('manual', parseInt(this.value));
                    }
                });
                
                binBoundarySelect.addEventListener('change', function() {
                    console.log('Bin boundary changed to:', this.value);
                    const currentMethod = binWidthSelect.value;
                    const currentBins = binWidthSelect.value === 'manual' ? parseInt(manualBinsInput.value) : null;
                    console.log('Recalculating with method:', currentMethod, 'bins:', currentBins);
                    recalculateHistogram(currentMethod, currentBins);
                });
                
                function recalculateHistogram(method, manualBinCount) {
                    console.log('recalculateHistogram called with method:', method, 'manualBinCount:', manualBinCount);
                    let numBins;
                    const n = rawMeasurements.length;
                    const min = Math.min(...rawMeasurements);
                    const max = Math.max(...rawMeasurements);
                    const range = max - min;
                    
                    // Calculate number of bins based on method
                    if (method === 'manual') {
                        numBins = manualBinCount || 10;
                    } else if (method === 'sturges') {
                        numBins = Math.ceil(Math.log2(n) + 1);
                    } else if (method === 'scott') {
                        const stdev = Math.sqrt(rawMeasurements.reduce((sum, x) => sum + Math.pow(x - data.mean, 2), 0) / n);
                        const binWidth = 3.5 * stdev / Math.pow(n, 1/3);
                        numBins = Math.ceil(range / binWidth);
                    } else if (method === 'doane') {
                        const g1 = rawMeasurements.reduce((sum, x) => sum + Math.pow((x - data.mean) / data.stdev, 3), 0) / n;
                        numBins = Math.ceil(1 + Math.log2(n) + Math.log2(1 + Math.abs(g1) / Math.sqrt((6 * (n - 2)) / ((n + 1) * (n + 3)))));
                    } else if (method === 'fd') {
                        const sorted = [...rawMeasurements].sort((a, b) => a - b);
                        const q1 = sorted[Math.floor(n * 0.25)];
                        const q3 = sorted[Math.floor(n * 0.75)];
                        const iqr = q3 - q1;
                        const binWidth = 2 * iqr / Math.pow(n, 1/3);
                        numBins = Math.ceil(range / binWidth);
                    }
                    
                    numBins = Math.max(1, Math.min(100, numBins)); // Limit between 1-100
                    
                    // Get bin boundary setting
                    const binBoundary = binBoundarySelect.value;
                    const isRightOpen = binBoundary === 'right_open'; // [a, b)
                    
                    // Create bins
                    const binWidth = range / numBins;
                    const binCenters = [];
                    const binLabels = [];
                    const frequencies = [];
                    
                    for (let i = 0; i < numBins; i++) {
                        const binStart = min + i * binWidth;
                        const binEnd = binStart + binWidth;
                        
                        // Position bars based on boundary type
                        // Right-open [a,b): bar aligned to left boundary (binStart)
                        // Left-open (a,b]: bar aligned to right boundary (binEnd)
                        const binPosition = isRightOpen ? binStart : binEnd;
                        
                        binCenters.push(binPosition);
                        
                        // Create label with boundary notation
                        let label;
                        if (isRightOpen) {
                            label = i === numBins - 1 
                                ? `[${binStart.toFixed(2)}, ${binEnd.toFixed(2)}]`
                                : `[${binStart.toFixed(2)}, ${binEnd.toFixed(2)})`;
                        } else {
                            label = i === 0
                                ? `[${binStart.toFixed(2)}, ${binEnd.toFixed(2)}]`
                                : `(${binStart.toFixed(2)}, ${binEnd.toFixed(2)}]`;
                        }
                        binLabels.push(label);
                        
                        // Count based on boundary type
                        const count = rawMeasurements.filter(x => {
                            if (isRightOpen) {
                                // Right-open: [a, b) - includes left, excludes right
                                if (i === numBins - 1) {
                                    return x >= binStart && x <= binEnd; // Last bin includes both boundaries
                                }
                                return x >= binStart && x < binEnd;
                            } else {
                                // Left-open: (a, b] - excludes left, includes right
                                if (i === 0) {
                                    return x >= binStart && x <= binEnd; // First bin includes both boundaries
                                }
                                return x > binStart && x <= binEnd;
                            }
                        }).length;
                        frequencies.push(count);
                    }
                    
                    // Update chart with bin centers and frequencies
                    currentBinLabels = binLabels; // Store for tooltip
                    console.log('Updating histogram - bins:', numBins, 'boundary:', binBoundary);
                    console.log('Bin labels:', binLabels);
                    console.log('Bin labels detail:');
                    binLabels.forEach((label, i) => console.log(`  Bin ${i}: ${label} -> Count: ${frequencies[i]}`));
                    console.log('Bin centers:', binCenters);
                    console.log('Frequencies:', frequencies);
                    histChart.data.labels = binCenters;
                    histChart.data.datasets[0].data = frequencies;
                    histChart.update();
                    console.log('Histogram updated successfully');
                }
                
            } catch (error) {
                console.error('Error creating histogram:', error);
            }
        } else {
            console.error('Histogram canvas not found or Chart.js not loaded');
        }
    </script>
</body>
</html>

