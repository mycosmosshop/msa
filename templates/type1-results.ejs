                        <% } %>
                        
                        <% if (results.percent_var_repeatability >= 30) { %>
                            <li><strong>Yüksek değişkenlik:</strong> %Değişkenlik(tekrarlanabilirlik) = <%= parseFloat(results.percent_var_repeatability).toFixed(1) %>% > 30%. Ölçüm değişkenliğini azaltın.</li>
                        <% } else if (results.percent_var_repeatability >= 10) { %>
                            <li><strong>Orta seviye değişkenlik:</strong> %Değişkenlik(tekrarlanabilirlik) = <%= parseFloat(results.percent_var_repeatability).toFixed(1) %>% (10-30%). İyileştirme fırsatları için izleyin.</li>
