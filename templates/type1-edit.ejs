<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Type 1 Study - <%= branding?.company_name || 'GageAI' %></title>
  
  <!-- Theme Script -->
  <script>
    (function() {
      const theme = localStorage.getItem('theme_mode') || 'light';
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
  
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <link rel="stylesheet" href="css/dark-mode.css">
  <link rel="stylesheet" href="css/responsive.css">
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: var(--bg-secondary);
      min-height: 100vh;
    }
    .navbar {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 2px 20px rgba(0,0,0,0.1);
    }
    .navbar h1 {
      font-size: 24px;
      display: flex;
      align-items: center;
      gap: 15px;
    }
    .container {
      max-width: 900px;
      margin: 30px auto;
      padding: 0 20px;
    }
    .card {
      background: var(--card-bg);
      border-radius: 16px;
      box-shadow: var(--shadow);
      padding: 40px;
      margin-bottom: 20px;
    }
    h2 {
      color: var(--text-primary);
      margin-bottom: 10px;
      font-size: 28px;
    }
    .subtitle {
      color: var(--text-secondary);
      margin-bottom: 30px;
      font-size: 15px;
      line-height: 1.6;
    }
    .form-group {
      margin-bottom: 24px;
    }
    label {
      display: block;
      margin-bottom: 8px;
      color: var(--text-secondary);
      font-weight: 600;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    input[type="text"],
    input[type="number"],
    textarea {
      width: 100%;
      padding: 14px 16px;
      border: 2px solid var(--border-color);
      border-radius: 10px;
      font-size: 14px;
      transition: all 0.3s ease;
      background: var(--input-bg);
      color: var(--text-primary);
      font-family: inherit;
    }
    input:focus, textarea:focus {
      outline: none;
      border-color: #667eea;
      box-shadow: 0 0 0 4px rgba(102, 126, 234, 0.1);
    }
    textarea {
      resize: vertical;
      min-height: 80px;
    }
    .form-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
    .info-box {
      background: var(--bg-tertiary);
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 24px;
      border-left: 4px solid #667eea;
    }
    .info-box p {
      color: var(--text-secondary);
      font-size: 14px;
      line-height: 1.7;
      margin-bottom: 8px;
    }
    .measurements-container {
      background: var(--bg-tertiary);
      padding: 20px;
      border-radius: 12px;
      margin-bottom: 24px;
    }
    .measurement-input {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }
    .measurement-input input {
      flex: 1;
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      padding: 14px 32px;
      border: none;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s;
      box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
    }
    .btn-secondary {
      background: var(--bg-tertiary);
      color: var(--text-primary);
      padding: 14px 32px;
      border: 2px solid var(--border-color);
      border-radius: 10px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      display: inline-block;
      transition: all 0.3s;
    }
    .btn-add {
      background: #10b981;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
      font-weight: 600;
    }
    .btn-remove {
      background: #ef4444;
      color: white;
      padding: 8px 16px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }
    .button-group {
      display: flex;
      gap: 12px;
      margin-top: 30px;
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <div class="navbar">
    <h1>
      <% if (branding?.logo_url) { %>
        <img src="<%= branding.logo_url %>" alt="Logo" style="height: 40px; width: auto;">
      <% } %>
      <%= branding?.company_name || 'GageAI' %>
    </h1>
    <div>
      <a href="type1-results.html?id=<%= study.id %>" style="color: white; text-decoration: none; margin-right: 20px;">← Back to Results</a>
      <a href="index.html" style="color: white; text-decoration: none;">Çıkış</a>
    </div>
  </div>

  <div class="container">
    <div class="card">
      <h2>📏 Edit Type 1 - Instrument Capability Study</h2>
      <p class="subtitle">
        Çalışma bilgilerini düzenleyin. Değerleri güncelledikten sonra "Calculate & Save Study" butonuna tıklayın.
      </p>

      <div class="info-box">
        <p><strong>Not:</strong> Tüm alanları düzenleyebilir, ölçüm ekleyip çıkarabilirsiniz. Değişiklikler sonuçları yeniden hesaplayacaktır.</p>
      </div>

      <form id="type1EditForm">
        <!-- Study Info -->
        <div class="form-group">
          <label for="study_name">Study Name *</label>
          <input type="text" id="study_name" name="study_name" required 
                 value="<%= study.study_name %>">
        </div>

        <div class="form-group">
          <label for="description">Description</label>
          <textarea id="description" name="description"><%= study.description || '' %></textarea>
        </div>

        <!-- Instrument Info -->
        <div class="form-row">
          <div class="form-group">
            <label for="gauge_name">Gauge Name</label>
            <input type="text" id="gauge_name" name="gauge_name" 
                   value="<%= study.gauge_name || '' %>">
          </div>
          <div class="form-group">
            <label for="gauge_number">Gauge Number</label>
            <input type="text" id="gauge_number" name="gauge_number" 
                   value="<%= study.gauge_number || '' %>">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" 
                   value="<%= study.location || '' %>">
          </div>
          <div class="form-group">
            <label for="part_name">Part Name</label>
            <input type="text" id="part_name" name="part_name" 
                   value="<%= study.part_name || '' %>">
          </div>
        </div>

        <div class="form-group">
          <label for="characteristic">Characteristic</label>
          <input type="text" id="characteristic" name="characteristic" 
                 value="<%= study.characteristic || '' %>"
                 placeholder="Ölçülen özellik">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="tolerance_spec">Tolerance (Specification)</label>
            <input type="text" id="tolerance_spec" name="tolerance_spec" 
                   value="<%= study.tolerance_spec || '' %>"
                   placeholder="Örn: ±0.05 veya 10.00 - 10.10">
            <small style="color: var(--text-secondary); font-size: 12px; margin-top: 5px; display: block;">Tolerans aralığı veya üst-alt limitler</small>
          </div>
          <div class="form-group">
            <label for="performed_by">Performed By</label>
            <input type="text" id="performed_by" name="performed_by" 
                   value="<%= study.performed_by || '' %>"
                   placeholder="Çalışmayı yapan kişi">
          </div>
        </div>

        <div class="form-group">
          <label for="study_date">Date</label>
          <input type="date" id="study_date" name="study_date" 
                 value="<%= study.created_at ? new Date(study.created_at).toISOString().split('T')[0] : '' %>"
                 style="padding: 14px 16px; border: 2px solid var(--border-color); border-radius: 10px; font-size: 14px; background: var(--input-bg); color: var(--text-primary);">
          <small style="color: var(--text-secondary); font-size: 12px; margin-top: 5px; display: block;">Bu tarih oluşturulma tarihi olarak kullanılacaktır</small>
        </div>

        <!-- Reference & Tolerance -->
        <div class="form-row">
          <div class="form-group">
            <label for="reference_value">Reference Value (Master) *</label>
            <input type="number" id="reference_value" name="reference_value" 
                   step="any" required value="<%= study.reference_value %>">
          </div>
          <div class="form-group">
            <label for="tolerance">Tolerance (Total) *</label>
            <input type="number" id="tolerance" name="tolerance" 
                   step="any" required value="<%= study.tolerance %>">
          </div>
        </div>

        <!-- Measurements -->
        <div class="form-group">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <label>Measurements * (minimum 5)</label>
            <div style="display: flex; align-items: center; gap: 10px;">
              <label style="margin: 0; font-size: 13px;">Add rows:</label>
              <input type="number" id="rowCountInput" min="1" max="50" value="5" 
                     style="width: 80px; padding: 8px; border: 1px solid var(--border-color); border-radius: 6px; background: var(--bg-secondary);">
              <button type="button" class="btn-add" onclick="addMultipleRows()" style="padding: 8px 16px;">Add Rows</button>
            </div>
          </div>
          <div class="measurements-container" id="measurementsContainer">
            <% measurements.forEach((m, index) => { %>
            <div class="measurement-input">
              <span style="width: 40px; font-weight: 600;">#<%= index + 1 %></span>
              <input type="number" step="any" required class="measurement-value" value="<%= m.measurement_value %>">
              <% if (index >= 5) { %>
              <button type="button" class="btn-remove" onclick="removeMeasurement(this)">×</button>
              <% } %>
            </div>
            <% }); %>
          </div>
        </div>

        <!-- Analysis Options -->
        <div class="form-group" style="border-top: 2px solid var(--border-color); padding-top: 30px; margin-top: 30px;">
          <h3 style="color: var(--text-primary); margin-bottom: 20px; font-size: 20px;">📊 Analysis Options</h3>
          
          <!-- Bias Study Options -->
          <div style="background: var(--bg-tertiary); padding: 20px; border-radius: 10px; margin-bottom: 20px;">
            <h4 style="color: var(--text-primary); margin-bottom: 15px; font-size: 16px;">Bias Study Options</h4>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_bias_table" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Bias and instrument capability table</span>
              </label>
            </div>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_t_test" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">One sample t-test</span>
              </label>
            </div>
            
            <div class="form-row" style="margin-top: 15px;">
              <div class="form-group" style="margin-bottom: 0;">
                <label for="confidence_interval">Confidence Interval for Bias (%)</label>
                <input type="number" id="confidence_interval" name="confidence_interval" 
                       value="<%= analysisOptions.confidence_interval || 95 %>" min="90" max="99" step="1">
              </div>
              <div class="form-group" style="margin-bottom: 0;">
                <label for="percent_tolerance_cg">Percent of Tolerance for Cg (%)</label>
                <input type="number" id="percent_tolerance_cg" name="percent_tolerance_cg" 
                       value="<%= analysisOptions.percent_tolerance_cg || 20 %>" min="5" max="50" step="5">
              </div>
            </div>
          </div>
          
          <!-- Plots Options -->
          <div style="background: var(--bg-tertiary); padding: 20px; border-radius: 10px;">
            <h4 style="color: var(--text-primary); margin-bottom: 15px; font-size: 16px;">Plots</h4>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_run_chart" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Run chart</span>
              </label>
              <div style="margin-left: 28px; margin-top: 8px;">
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                  <input type="checkbox" name="run_chart_individual" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display individual measurements</span>
                </label>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="run_chart_boundaries" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display boundaries of the reference interval</span>
                </label>
              </div>
            </div>
            
            <div style="margin-bottom: 15px;">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_histogram" checked style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Histogram</span>
              </label>
              <div style="margin-left: 28px; margin-top: 8px;">
                <div class="form-row" style="gap: 15px;">
                  <div class="form-group" style="margin-bottom: 8px;">
                    <label for="histogram_bin_type" style="font-size: 12px;">Bin Width Type</label>
                    <select id="histogram_bin_type" name="histogram_bin_type" 
                            style="width: 100%; padding: 10px; border: 2px solid var(--border-color); border-radius: 8px; background: var(--input-bg); color: var(--text-primary);">
                      <option value="sturges" selected>Sturges</option>
                      <option value="fixed">Fixed Number</option>
                    </select>
                  </div>
                  <div class="form-group" style="margin-bottom: 8px;">
                    <label for="num_bins" style="font-size: 12px;">Number of Bins</label>
                    <input type="number" id="num_bins" name="num_bins" value="30" min="5" max="100" 
                           style="padding: 10px;">
                  </div>
                  <div class="form-group" style="margin-bottom: 8px;">
                    <label for="histogram_bin_boundary" style="font-size: 12px;">Bin Boundaries</label>
                    <select id="histogram_bin_boundary" name="histogram_bin_boundary" 
                            style="width: 100%; padding: 10px; border: 2px solid var(--border-color); border-radius: 8px; background: var(--input-bg); color: var(--text-primary);">
                      <option value="right_open" <%= analysisOptions.histogram_bin_boundary === 'right_open' || !analysisOptions.histogram_bin_boundary ? 'selected' : '' %>>Right-open [a, b)</option>
                      <option value="left_open" <%= analysisOptions.histogram_bin_boundary === 'left_open' ? 'selected' : '' %>>Left-open (a, b]</option>
                    </select>
                  </div>
                </div>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="histogram_show_mean" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display mean</span>
                </label>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="histogram_show_ci" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Confidence interval for mean (95%)</span>
                </label>
                <label style="display: flex; align-items: center; cursor: pointer; text-transform: none; margin-top: 5px;">
                  <input type="checkbox" name="histogram_show_reference" checked style="margin-right: 10px; width: 16px; height: 16px;">
                  <span style="font-size: 13px; font-weight: normal; letter-spacing: 0;">Display reference value</span>
                </label>
              </div>
            </div>
            
            <div style="margin-bottom: 15px; margin-top: 20px; padding-top: 15px; border-top: 1px solid var(--border-color);">
              <label style="display: flex; align-items: center; cursor: pointer; text-transform: none;">
                <input type="checkbox" name="show_capa_banner" value="true" <%= analysisOptions.show_capa_banner === true || analysisOptions.show_capa_banner === undefined ? 'checked' : '' %> style="margin-right: 10px; width: 18px; height: 18px;">
                <span style="font-weight: normal; letter-spacing: 0;">Show CAPA Alert Banner (for Unacceptable results)</span>
              </label>
              <div style="margin-left: 28px; margin-top: 5px; font-size: 12px; color: var(--text-secondary);">
                Automatically creates CAPA when Cg < 1.33 or |Bias| > 10% tolerance
              </div>
            </div>
          </div>
        </div>

        <div class="button-group">
          <a href="type1-results.html?id=<%= study.id %>" class="btn-secondary">Cancel</a>
          <button type="submit" class="btn-primary">Calculate & Save Study</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let measurementCount = <%= measurements.length %>;

    function addMultipleRows() {
      const rowCount = parseInt(document.getElementById('rowCountInput').value) || 1;
      if (rowCount < 1 || rowCount > 50) {
        alert('Please enter a number between 1 and 50');
        return;
      }

      const container = document.getElementById('measurementsContainer');
      for (let i = 0; i < rowCount; i++) {
        measurementCount++;
        const div = document.createElement('div');
        div.className = 'measurement-input';
        div.innerHTML = `
          <span style="width: 40px; font-weight: 600;">#${measurementCount}</span>
          <input type="number" step="any" class="measurement-value" placeholder="Enter measurement value">
          <button type="button" class="btn-remove" onclick="removeMeasurement(this)">×</button>
        `;
        container.appendChild(div);
      }
    }

    function addMeasurement() {
      measurementCount++;
      const container = document.getElementById('measurementsContainer');
      const div = document.createElement('div');
      div.className = 'measurement-input';
      div.innerHTML = `
        <span style="width: 40px; font-weight: 600;">#${measurementCount}</span>
        <input type="number" step="any" required class="measurement-value" placeholder="Enter measurement value">
        <button type="button" class="btn-remove" onclick="removeMeasurement(this)">×</button>
      `;
      container.appendChild(div);
    }

    function removeMeasurement(btn) {
      if (document.querySelectorAll('.measurement-input').length > 5) {
        btn.parentElement.remove();
        renumberMeasurements();
      } else {
        alert('Minimum 5 measurements required');
      }
    }

    function renumberMeasurements() {
      const inputs = document.querySelectorAll('.measurement-input');
      inputs.forEach((input, index) => {
        input.querySelector('span').textContent = `#${index + 1}`;
      });
      measurementCount = inputs.length;
    }

    document.getElementById('type1EditForm').addEventListener('submit', async (e) => {
      e.preventDefault();

      const measurements = Array.from(document.querySelectorAll('.measurement-value'))
        .map(input => parseFloat(input.value))
        .filter(v => !isNaN(v));

      if (measurements.length < 5) {
        alert('Please enter at least 5 measurements');
        return;
      }

      // Collect analysis options
      const currentOptions = <%- JSON.stringify(analysisOptions) %>;
      const analysisOptions = {
        show_bias_table: document.querySelector('[name="show_bias_table"]')?.checked ?? currentOptions.show_bias_table ?? true,
        show_t_test: document.querySelector('[name="show_t_test"]')?.checked ?? currentOptions.show_t_test ?? true,
        confidence_interval: parseInt(document.getElementById('confidence_interval').value) || 95,
        percent_tolerance_cg: parseInt(document.getElementById('percent_tolerance_cg').value) || 20,
        show_run_chart: currentOptions.show_run_chart ?? true,
        run_chart_individual: currentOptions.run_chart_individual ?? true,
        run_chart_boundaries: currentOptions.run_chart_boundaries ?? true,
        show_histogram: currentOptions.show_histogram ?? true,
        histogram_bin_type: currentOptions.histogram_bin_type || 'sturges',
        num_bins: currentOptions.num_bins || 30,
        histogram_show_mean: currentOptions.histogram_show_mean ?? true,
        histogram_show_ci: currentOptions.histogram_show_ci ?? true,
        histogram_show_reference: currentOptions.histogram_show_reference ?? true,
        show_capa_banner: document.querySelector('[name="show_capa_banner"]')?.checked ?? false
      };

      const formData = {
        study_name: document.getElementById('study_name').value,
        description: document.getElementById('description').value,
        gauge_name: document.getElementById('gauge_name').value,
        gauge_number: document.getElementById('gauge_number').value,
        location: document.getElementById('location').value,
        part_name: document.getElementById('part_name').value,
        characteristic: document.getElementById('characteristic').value,
        tolerance_spec: document.getElementById('tolerance_spec').value,
        performed_by: document.getElementById('performed_by').value,
        study_date: document.getElementById('study_date').value,
        reference_value: document.getElementById('reference_value').value,
        tolerance: document.getElementById('tolerance').value,
        measurements: measurements,
        analysis_options: analysisOptions
      };

      try {
        const result = await window.msaType1Update(formData);

        if (result.success) {
          // Force fresh page load by adding timestamp (prevents browser cache)
          window.location.href = `type1-results.html?id=<%= study.id %>&t=${Date.now()}`;
        } else {
          alert('Error: ' + result.message);
        }
      } catch (error) {
        console.error('Error:', error);
        alert('Failed to update study');
      }
    });
  </script>

  <!-- Theme Switcher -->
  <script src="js/theme-switcher.js"></script>
</body>
</html>
